# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables (keep .env.example tracked as the template)
.env*
!.env.example

# stale lint-tool dumps (not produced by any npm script in this repo)
eslint-report.json

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# docs temporary files
docs/*.tmp
docs/*.temp
docs/*~
docs/Thumbs.db

# legacy docs archive (superseded by root + docs/, kept locally for reference only)
docs.archive/

# planner-only docs, not for the public repo (see docs/DOCUMENTS_REGISTRY.md)
docs/_planner/

# scratch/intermediate files, not for commit
tmp/

# agent memory / local state (project-shared Claude Code config lives in .claude/settings.json,
# which stays tracked; only personal/local overrides and other assistants' local state are ignored).
# Claude Code is the sole executor for this project (see CLAUDE.md) - .qwen/ is ignored so it can
# never accidentally get re-tracked if that tooling is ever run here again.
.claude/settings.local.json
.agent/
.qwen/

# test coverage output (no test runner is configured yet, but reserve the path)
coverage/