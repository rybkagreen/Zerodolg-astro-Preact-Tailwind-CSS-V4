{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    // Базовые настройки
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,

    // JSX конфигурация для Preact
    "jsx": "react-jsx",
    "jsxImportSource": "preact",

    // Типы и модули
    "types": ["astro/client", "@types/node", "vite/client"],
    "allowJs": true,
    "checkJs": false,

    // Максимальная строгость TypeScript для 2025
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,

    // Дополнительные проверки
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,

    // Современные настройки ES модулей
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "preserveWatchOutput": true,

    // Эмиттинг
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": false,
    "importHelpers": true,
    "downlevelIteration": true,

    // Пути и базовый URL
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@app/*": ["src/app/*"],
      "@entities/*": ["src/entities/*"],
      "@features/*": ["src/features/*"],
      "@widgets/*": ["src/widgets/*"],
      "@shared/*": ["src/shared/*"],
      "@shared/ui/*": ["src/shared/ui/*"],
      "@shared/lib/*": ["src/shared/lib/*"],
      "@shared/config/*": ["src/shared/config/*"],
      "@shared/types/*": ["src/shared/types/*"],
      "@shared/api/*": ["src/shared/api/*"],
      "@shared/hooks/*": ["src/shared/hooks/*"],
      "@pages/*": ["src/pages/*"]
    }
  },
  "include": [".astro/types.d.ts", "src/**/*", "src/astro-env.d.ts", "src/env.d.ts", "*.d.ts"],
  "exclude": [
    "dist",
    "dist/**/*",
    "node_modules",
    "node_modules/**/*",
    ".astro",
    ".astro/**/*",
    "coverage",
    "coverage/**/*",
    "public",
    "public/**/*",
    "scripts",
    "scripts/**/*",
    "tools",
    "tools/**/*",
    "astro.config.mjs",
    "astro.config.prod.mjs",
    "eslint.config.js",
    "tailwind.config.js",
    "postcss.config.cjs",
    "*.min.js",
    "**/*.min.js"
  ]
}
