{
  "mcpServers": {
    "astro-mcp": {
      "command": "npx",
      "args": [
        "astro",
        "mcp"
      ],
      "env": {}
    },
    "puppeteer-browser": {
      "command": "node",
      "args": [
        "mcp-puppeteer-server.js"
      ],
      "env": {}
    }
  },
  "servers": {
    "astro": {
      "type": "sse",
      "url": "http://localhost:4321/__mcp/sse"
    },
    "puppeteer": {
      "type": "stdio",
      "command": "node",
      "args": [
        "mcp-puppeteer-server.js"
      ]
    }
  }
}
