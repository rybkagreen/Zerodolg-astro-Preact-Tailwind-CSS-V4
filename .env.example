# Environment / server (present in production .env; not read by astro.config.mjs's
# hardcoded dev server block or any src/ code as of 2026-07-14 - see ARCHITECTURE.md §3)
NODE_ENV=production
HOST=localhost
PORT=3000

# Bitrix24 Configuration (required - see scripts/dev/validate-env.js)
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-webhook-key/

# Site Configuration (required)
PUBLIC_SITE_URL=https://your-domain.ru
PUBLIC_SITE_PHONE=+7 (905) 577-33-87
PUBLIC_SITE_EMAIL=info@your-domain.ru

# Astro Dev Toolbar (disable in production)
PUBLIC_ASTRO_TOOLBAR=false

# Google Analytics
PUBLIC_GA_ID=G-XXXXXXXXXX

# Yandex Metrika - code reads PUBLIC_YM_ID (src/shared/config/env.ts,
# src/shared/lib/analytics-manager.ts). YANDEX_METRIKA_ID/YANDEX_VERIFICATION/
# YANDEX_SEARCH_API_KEY are present in production but unused in src/ as of this
# writing - keep as placeholders, don't assume they're wired up (see BL-004/BL-005
# in docs/IMPLEMENTATION_PLAN.md).
PUBLIC_YM_ID=XXXXXXXXX
YANDEX_METRIKA_ID=XXXXXXXXX
YANDEX_VERIFICATION=your-yandex-webmaster-verification-token
YANDEX_SEARCH_API_KEY=your-yandex-search-api-key

# Additional Analytics - present in production .env but no confirmed src/ usage yet
PUBLIC_GTM_ID=GTM-XXXXXXX
PUBLIC_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
PUBLIC_FACEBOOK_PIXEL_ID=XXXXXXXXXXXXXXX

# Recaptcha v3 - PUBLIC_RECAPTCHA_SITE_KEY/RECAPTCHA_SECRET are present in production
# but no confirmed src/ usage yet (see BL-004 in docs/IMPLEMENTATION_PLAN.md)
PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET=your-recaptcha-secret-key

# CMS Configuration - not present in production .env, no confirmed src/ usage (see BL-005)
CMS_API_BASE=https://your-cms-endpoint.alibabacloud.com
CMS_API_KEY=your-api-key-here

# API Keys for third-party services - not present in production .env, no confirmed src/ usage
PUBLIC_MAP_API_KEY=your-map-api-key