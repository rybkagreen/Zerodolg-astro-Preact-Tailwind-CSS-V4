{
  "mcpServers": {
    "astro-mcp": {
      "command": "npx",
      "args": ["astro", "mcp"],
      "env": {}
    },
    "astro-docs": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.docs.astro.build/mcp"],
      "env": {}
    },
    "puppeteer-browser": {
      "command": "node",
      "args": ["mcp-puppeteer-server.js"],
      "env": {}
    }
  }
}
