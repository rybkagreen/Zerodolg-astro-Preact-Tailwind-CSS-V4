---
export interface Props {
  title: string;
  description: string;
  icon?: string; // URL to icon
  iconPosition?: 'top' | 'left';
  size?: 'sm' | 'md' | 'lg';
  color?: 'primary' | 'secondary' | 'accent';
  hoverEffect?: boolean;
  rounded?: 'none' | 'sm' | 'md' | 'lg' | 'full';
  className?: string;
  gradient?: boolean;
}

const {
  title,
  description,
  icon,
  iconPosition = 'top',
  size = 'md',
  color = 'primary',
  hoverEffect = true,
  rounded = 'lg',
  className = '',
  gradient = false,
} = Astro.props;

// Size classes mapping
const sizeClasses = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

// Rounded classes mapping
const roundedClasses = {
  none: 'rounded-none',
  sm: 'rounded-sm',
  md: 'rounded-md',
  lg: 'rounded-lg',
  full: 'rounded-full',
};

// Color classes mapping
const colorClasses = {
  primary: gradient
    ? 'bg-gradient-to-r from-primary to-primary-light text-white'
    : 'bg-primary-light/10 text-primary border border-primary/20',
  secondary: gradient
    ? 'bg-gradient-to-r from-gray-700 to-gray-900 text-white'
    : 'bg-gray-100 text-gray-800 border border-gray-200',
  accent: gradient
    ? 'bg-gradient-to-r from-accent to-accent-light text-white'
    : 'bg-accent-light/10 text-accent border border-accent/20',
};

// Hover effect classes
const hoverClass = hoverEffect
  ? 'transition-all duration-300 hover:-translate-y-1 hover:shadow-xl'
  : '';
---

<div
  class:list={`${sizeClasses[size]} ${roundedClasses[rounded]} ${colorClasses[color]} ${hoverClass} ${className}`}
  style={`box-shadow: ${
    gradient
      ? '0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)'
      : '0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)'
  }`}
>
  <div
    class:list={[
      `flex `,
      {
        'items-center': iconPosition === 'left',
        'flex-col items-center text-center': iconPosition !== 'left',
      },
    ]}
  >
    {
      icon && (
        <div
          class:list={{
            'mr-4 flex-shrink-0': iconPosition === 'left',
            'mb-4': iconPosition !== 'left',
          }}
        >
          <img
            src={icon}
            alt={`${title} icon`}
            class:list={[`w-10 h-10 object-contain `, { 'filter invert': gradient }]}
            width='40'
            height='40'
          />
        </div>
      )
    }

    <div>
      <h3
        class:list={`font-semibold mb-2 ${gradient ? 'text-white' : `text-${color === 'primary' ? 'primary' : color === 'accent' ? 'accent' : 'gray'}-700`}`}
      >
        {title}
      </h3>
      <p class:list={{ 'text-white/90': gradient, 'text-gray-600 dark:text-gray-300': !gradient }}>
        {description}
      </p>
    </div>
  </div>
</div>
