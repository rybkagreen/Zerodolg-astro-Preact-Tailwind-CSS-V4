---
import { organizationSchema } from '@shared/lib/structured-data';

interface Props {
  /** Page title */
  title: string;
  /** Page description */
  description: string;
  /** SEO keywords */
  keywords?: string;
  /** Page image for social sharing */
  image?: string;
  /** Canonical URL */
  canonical?: string;
  /** No index flag */
  noindex?: boolean;
  /** Open Graph type */
  type?: string;
  /** Locale for Open Graph */
  locale?: string;
}

const {
  title,
  description,
  keywords,
  image = '/images/og-image.jpg',
  canonical,
  noindex = false,
  type = 'website',
  locale = 'ru_RU',
} = Astro.props;

const siteConfig = {
  name: 'ZeroDolg',
  url: 'https://zerodolg.ru',
  description: 'Юридическая помощь при банкротстве физических лиц',
};
---

<title>{title}</title>
<meta name='description' content={description} />
{keywords && <meta name='keywords' content={keywords} />}
<link rel='canonical' href={canonical || siteConfig.url} />

<!-- Geographical meta tags for local SEO -->
<meta name='geo.region' content='RU-MOW' />
<meta name='geo.placename' content='Москва' />
<meta name='geo.position' content='55.704061;37.508087' />
<meta name='ICBM' content='55.704061, 37.508087' />

<!-- Open Graph / Facebook -->
<meta property='og:type' content={type} />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:image' content={image} />
<meta property='og:url' content={canonical || siteConfig.url} />
<meta property='og:site_name' content={siteConfig.name} />
<meta property='og:locale' content={locale} />

<!-- Twitter -->
<meta property='twitter:card' content='summary_large_image' />
<meta property='twitter:title' content={title} />
<meta property='twitter:description' content={description} />
<meta property='twitter:image' content={image} />

<!-- No index -->
{noindex && <meta name='robots' content='noindex, nofollow' />}

{/* Structured data */}
{
  organizationSchema && (
    <script type='application/ld+json' set:text={JSON.stringify(organizationSchema, null, 2)} />
  )
}
