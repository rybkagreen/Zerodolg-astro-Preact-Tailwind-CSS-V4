---
import TimelineComponent from '../../islands/shared/interactive/timeline.tsx';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Данные о процессе банкротства из index.json
const process = {
  title: 'Как проходит банкротство',
  subtitle: 'Пошаговый процесс освобождения от долгов через суд',
  steps: [
    {
      number: 1,
      title: 'Консультация',
      description: 'Анализируем вашу ситуацию и определяем возможность банкротства',
      duration: '1 день',
      difficulty: 'easy',
      icon: '/icons/process/01-analysis.svg',
      details: [
        'Бесплатная оценка перспектив',
        'Анализ всех долгов и кредиторов',
        'Определение оптимальной стратегии',
        'Расчет стоимости процедуры',
      ],
    },
    {
      number: 2,
      title: 'Подготовка документов',
      description: 'Собираем и готовим все необходимые документы',
      duration: '5-7 дней',
      difficulty: 'medium',
      icon: '/icons/process/02-docs.svg',
      details: [
        'Помощь в сборе документов',
        'Подготовка списка кредиторов',
        'Оформление заявления в суд',
      ],
      documents: [
        'Паспорт и СНИЛС',
        'ИНН и свидетельство о рождении',
        'Справки о доходах за 3 года',
        'Кредитные договоры и решения судов',
      ],
    },
    {
      number: 3,
      title: 'Подача заявления',
      description: 'Подаем заявление в Арбитражный суд',
      duration: '1 день',
      difficulty: 'easy',
      icon: '/icons/process/03-court.svg',
      details: [
        'Подача через электронную систему суда',
        'Оплата госпошлины 300 рублей',
        'Получение входящего номера дела',
      ],
      warning: 'С момента подачи заявления коллекторы не могут вам звонить',
    },
    {
      number: 4,
      title: 'Судебная процедура',
      description: 'Представляем ваши интересы на всех заседаниях',
      duration: '4-6 месяцев',
      difficulty: 'hard',
      icon: '/icons/process/04-restruct.svg',
      details: [
        'Первое судебное заседание',
        'Назначение финансового управляющего',
        'Реализация имущества (если есть)',
        'Собрание кредиторов',
      ],
      warning: 'Единственное жилье и предметы обычного обихода остаются у вас',
    },
    {
      number: 5,
      title: 'Списание долгов',
      description: 'Получаем решение суда о списании всех долгов',
      duration: '1 день',
      difficulty: 'easy',
      icon: '/icons/process/06-discharge.svg',
      details: [
        'Окончательное судебное заседание',
        'Получение решения суда',
        'Списание всех долгов',
        'Начало новой жизни без долгов',
      ],
    },
  ],
};
---

<section class:list={`timeline-bg section-padding ${className}`} id='process'>
  <!-- Background decoration -->
  <div class='absolute inset-0'>
    <div class='absolute top-40 left-20 w-64 h-64 bg-blue-300/10 rounded-full blur-3xl'></div>
    <div class='absolute bottom-40 right-20 w-80 h-80 bg-indigo-300/10 rounded-full blur-3xl'></div>
  </div>

  <div class='container-custom'>
    <!-- Header -->
    <header class='text-center mb-16 md:mb-20 lg:mb-24'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-indigo-100/80 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-indigo-700 ring-1 ring-indigo-200/50 mb-8'
      >
        <svg class='h-4 w-4 text-indigo-600' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2'
          ></path>
        </svg>
        Процесс банкротства
      </div>
      <h2
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 tracking-tight leading-tight'
      >
        {process.title}
      </h2>
      <p class='text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-medium'>
        {process.subtitle}
      </p>
    </header>

    <!-- Modern Vertical Timeline -->
    <div class='relative'>
      <!-- Timeline line -->
      <div
        class='absolute left-8 top-8 bottom-8 w-0.5 bg-gradient-to-b from-blue-500 via-indigo-500 to-purple-500 opacity-20'
      >
      </div>

      <div class='space-y-12'>
        {
          process.steps.map((step, index) => {
            const iconColors = [
              'from-blue-500 to-indigo-600',
              'from-indigo-500 to-purple-600',
              'from-purple-500 to-pink-600',
              'from-pink-500 to-rose-600',
              'from-rose-500 to-orange-600',
            ];
            const iconColor = iconColors[index % iconColors.length];

            return (
              <div class='group relative flex items-start gap-8'>
                {/* Step icon with gradient */}
                <div class='relative z-10 flex-shrink-0'>
                  <div
                    class:list={`flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br ${iconColor} shadow-xl transition-transform duration-300 group-hover:scale-110`}
                  >
                    <span class='text-2xl font-bold text-white'>{step.number}</span>
                  </div>
                  {/* Connection line */}
                  {index < process.steps.length - 1 && (
                    <div class='absolute top-16 left-1/2 h-12 w-0.5 -translate-x-1/2 bg-gradient-to-b from-white to-transparent' />
                  )}
                </div>

                {/* Card content */}
                <div class='flex-1'>
                  <div class='enhanced-card p-8'>
                    {/* Header */}
                    <div class='mb-6'>
                      <div class='mb-2 flex items-center gap-3'>
                        <h3 class='text-2xl font-bold text-slate-900'>{step.title}</h3>
                        <div class='flex items-center gap-2 rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-600'>
                          <svg
                            class='h-4 w-4'
                            fill='none'
                            viewBox='0 0 24 24'
                            stroke='currentColor'
                          >
                            <path
                              stroke-linecap='round'
                              stroke-linejoin='round'
                              stroke-width='2'
                              d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'
                            />
                          </svg>
                          {step.duration}
                        </div>
                      </div>
                      <p class='text-slate-600 text-lg leading-relaxed'>{step.description}</p>
                    </div>

                    {/* Details */}
                    <div class='space-y-6'>
                      <div>
                        <h4 class='mb-4 text-lg font-semibold text-slate-900'>Что включает:</h4>
                        <ul class='space-y-3'>
                          {step.details.map((detail, idx) => (
                            <li key={idx} class='flex items-start gap-3'>
                              <div class='mt-1 flex h-5 w-5 items-center justify-center rounded-full bg-green-500/10 ring-1 ring-green-500/20'>
                                <svg
                                  class='h-3 w-3 text-green-600'
                                  fill='none'
                                  viewBox='0 0 24 24'
                                  stroke='currentColor'
                                >
                                  <path
                                    stroke-linecap='round'
                                    stroke-linejoin='round'
                                    stroke-width='3'
                                    d='M5 13l4 4L19 7'
                                  />
                                </svg>
                              </div>
                              <span class='text-slate-700'>{detail}</span>
                            </li>
                          ))}
                        </ul>
                      </div>

                      {/* Documents */}
                      {step.documents && (
                        <div class='rounded-2xl bg-slate-50/80 p-6'>
                          <h4 class='mb-4 flex items-center gap-2 text-lg font-semibold text-slate-900'>
                            <svg
                              class='h-5 w-5 text-slate-600'
                              fill='none'
                              viewBox='0 0 24 24'
                              stroke='currentColor'
                            >
                              <path
                                stroke-linecap='round'
                                stroke-linejoin='round'
                                stroke-width='2'
                                d='M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                              />
                            </svg>
                            Необходимые документы:
                          </h4>
                          <ul class='grid grid-cols-1 gap-2 sm:grid-cols-2'>
                            {step.documents.map((doc, idx) => (
                              <li key={idx} class='flex items-center gap-2 text-sm text-slate-600'>
                                <div class='h-1.5 w-1.5 rounded-full bg-slate-400' />
                                {doc}
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}

                      {/* Warning */}
                      {step.warning && (
                        <div class='rounded-2xl bg-amber-50 p-6 ring-1 ring-amber-200'>
                          <div class='flex gap-3'>
                            <div class='mt-0.5 flex h-6 w-6 items-center justify-center rounded-full bg-amber-500/10'>
                              <svg
                                class='h-4 w-4 text-amber-600'
                                fill='none'
                                viewBox='0 0 24 24'
                                stroke='currentColor'
                              >
                                <path
                                  stroke-linecap='round'
                                  stroke-linejoin='round'
                                  stroke-width='2'
                                  d='M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
                                />
                              </svg>
                            </div>
                            <p class='text-amber-800 font-medium'>{step.warning}</p>
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>

    <!-- Enhanced CTA Section -->
    <div class='mt-20'>
      <div
        class='relative overflow-hidden rounded-3xl bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-700 p-12 shadow-2xl'
      >
        {/* Background decoration */}
        <div class='absolute -top-10 -right-10 h-40 w-40 rounded-full bg-white/10 blur-3xl'></div>
        <div class='absolute -bottom-10 -left-10 h-32 w-32 rounded-full bg-purple-300/20 blur-2xl'>
        </div>

        <div class='relative text-center'>
          <div
            class='mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-white/10 backdrop-blur-sm'
          >
            <svg class='h-8 w-8 text-white' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M13 10V3L4 14h7v7l9-11h-7z'></path>
            </svg>
          </div>

          <h3 class='mb-4 text-3xl font-bold text-white lg:text-4xl'>
            Готовы начать новую жизнь без долгов?
          </h3>
          <p class='mb-8 text-lg text-blue-100 lg:text-xl'>
            Оставьте заявку и мы поможем на каждом этапе
          </p>

          <div class='flex flex-col gap-4 sm:flex-row sm:justify-center'>
            <button
              class='group inline-flex items-center justify-center gap-2 rounded-2xl bg-white px-8 py-4 text-lg font-bold text-blue-600 shadow-xl transition-all duration-300 hover:scale-105 hover:bg-blue-50 hover:shadow-2xl'
              data-modal='consultation'
              data-modal-type='consultation'
            >
              Начать процедуру
              <svg
                class='h-5 w-5 transition-transform duration-300 group-hover:translate-x-1'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M13 7l5 5m0 0l-5 5m5-5H6'></path>
              </svg>
            </button>

            <button
              class='group inline-flex items-center justify-center gap-2 rounded-2xl border-2 border-white/30 bg-white/10 px-8 py-4 text-lg font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:bg-white/20'
              data-modal='callback'
            >
              <svg class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'
                ></path>
              </svg>
              Заказать звонок
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Using Preact component for interactivity -->
<TimelineComponent client:load />
