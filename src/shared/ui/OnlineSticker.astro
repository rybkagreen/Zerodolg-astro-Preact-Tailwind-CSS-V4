---
// OnlineSticker component with improved functionality
---

<!-- Online Visitors Sticker with Glassmorphism -->
<div class='online-sticker' aria-live='polite' aria-atomic='true'>
  <!-- Animated gradient background -->
  <div class='online-sticker__gradient'></div>

  <!-- Content -->
  <div class='online-sticker__content'>
    <!-- Pulse indicator -->
    <div class='online-sticker__pulse-container'>
      <div class='online-sticker__pulse'></div>
      <div class='online-sticker__pulse-ring'></div>
    </div>

    <!-- Icon -->
    <svg class='online-sticker__icon' width='18' height='18' viewBox='0 0 24 24' fill='none'>
      <path
        d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'
        stroke='currentColor'
        stroke-width='2'
        stroke-linecap='round'
        stroke-linejoin='round'></path>
      <circle
        cx='9'
        cy='7'
        r='4'
        stroke='currentColor'
        stroke-width='2'
        stroke-linecap='round'
        stroke-linejoin='round'></circle>
      <path
        d='M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75'
        stroke='currentColor'
        stroke-width='2'
        stroke-linecap='round'
        stroke-linejoin='round'></path>
    </svg>

    <!-- Count with label -->
    <div class='online-sticker__info'>
      <span class='online-sticker__count'>5</span>
      <span class='online-sticker__label'>онлайн</span>
    </div>
  </div>
</div>

<script>
  class OnlineSticker {
    constructor() {
      this.element = document.querySelector('.online-sticker');
      this.countElement = document.querySelector('.online-sticker__count');
      this.minVisitors = 2;
      this.maxVisitors = 7;
      this.showDuration = 3000; // 3 seconds
      this.hideDuration = 45000; // 45 seconds
      this.isVisible = false;

      this.init();
    }

    init() {
      // Initial delay before first show
      setTimeout(() => {
        this.show();
        this.startCycle();
      }, 5000); // Start after 5 seconds
    }

    getRandomCount() {
      return (
        Math.floor(Math.random() * (this.maxVisitors - this.minVisitors + 1)) + this.minVisitors
      );
    }

    updateCount() {
      const newCount = this.getRandomCount();

      // Add animation class
      this.countElement?.classList.add('online-sticker__count--updating');

      // Update count
      setTimeout(() => {
        if (this.countElement) {
          this.countElement.textContent = newCount.toString();
        }
      }, 150);

      // Remove animation class
      setTimeout(() => {
        this.countElement?.classList.remove('online-sticker__count--updating');
      }, 300);
    }

    show() {
      if (!this.element || this.isVisible) return;

      this.updateCount();
      this.element.classList.add('online-sticker--visible');
      this.isVisible = true;

      // Hide after duration
      setTimeout(() => {
        this.hide();
      }, this.showDuration);
    }

    hide() {
      if (!this.element || !this.isVisible) return;

      this.element.classList.remove('online-sticker--visible');
      this.isVisible = false;
    }

    startCycle() {
      setInterval(() => {
        if (!this.isVisible) {
          this.show();
        }
      }, this.hideDuration + this.showDuration);
    }

    // Removed scroll handling - sticker should be visible everywhere
  }

  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    new OnlineSticker();
  });

  // Analytics tracking (optional)
  document.addEventListener('DOMContentLoaded', () => {
    const stickerElement = document.querySelector('.online-sticker');

    stickerElement?.addEventListener('transitionend', (e) => {
      if (
        e.propertyName === 'opacity' &&
        stickerElement.classList.contains('online-sticker--visible')
      ) {
        // Track sticker display
        if (typeof window.gtag !== 'undefined') {
          window.gtag('event', 'online_sticker_shown', {
            event_category: 'engagement',
            event_label: 'sticker_display',
          });
        }
      }
    });
  });
</script>
