---
import StatsComponent from '../../islands/shared/interactive/statsEnhanced.tsx';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Данные статистики
const stats = [
  {
    id: 'clients',
    icon: 'users',
    number: '847',
    suffix: '+',
    label: 'Счастливых клиентов',
    animateFrom: 0,
  },
  {
    id: 'debt',
    icon: 'dollar',
    number: '327',
    suffix: ' млн ₽',
    label: 'Списанных долгов',
    animateFrom: 0,
  },
  {
    id: 'experience',
    icon: 'chart',
    number: '12',
    suffix: ' лет',
    label: 'На рынке юруслуг',
    animateFrom: 0,
  },
  {
    id: 'success',
    icon: 'check',
    number: '98',
    suffix: '%',
    label: 'Побед в суде',
    animateFrom: 0,
  },
  {
    id: 'time',
    icon: 'clock',
    number: '4-6',
    suffix: ' мес.',
    label: 'Срок процедуры',
    animate: false,
  },
];

const ticker = [
  '✅ Анна К. списала 750 тыс. ₽ — 3 месяца',
  '✅ Дмитрий П. освободился от 1.2 млн ₽ — 4 месяца',
  '✅ Елена С. избавилась от долгов на 580 тыс. ₽ — 3 месяца',
  '✅ Максим В. списал 2.1 млн ₽ — 5 месяцев',
  '✅ Ольга Р. закрыла долги на 920 тыс. ₽ — 4 месяца',
];

const company = {
  fullName: 'ООО «ЮрПомощь»',
  legal: {
    inn: '7707123456',
    ogrn: '1187746123456',
  },
};
---

<section
  class:list={`stats-section section-padding ${className}`}
  id='stats'
  aria-labelledby='stats-title'
  itemscope
  itemtype='https://schema.org/LegalService'
>
  <div class='container-custom'>
    <!-- Section Header -->
    <header class='text-center mb-10 md:mb-14'>
      <h2 id='stats-title' class='section-title text-white'>
        Нам доверяют уже <span class='text-accent-300'>847+</span> клиентов
      </h2>
      <p class='section-subtitle text-white/90'>Опыт, цифры и гарантии — все прозрачно</p>
    </header>

    <!-- Statistics Grid -->
    <div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 md:gap-6' role='list' aria-label='Статистика компании'>
      {
        stats.map((stat) => (
          <div class='glass-card p-5' role='listitem' data-stat={stat.id}>
            <div
              class='flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-slate-50 text-slate-700 ring-1 ring-slate-200'
              aria-hidden='true'
            >
              {stat.icon === 'users' && (
                <svg width='24' height='24' viewBox='0 0 24 24' fill='none'>
                  <path
                    d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                  <circle
                    cx='9'
                    cy='7'
                    r='4'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                  <path
                    d='M23 21v-2a4 4 0 0 0-3-3.87'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                  <path
                    d='M16 3.13a4 4 0 0 1 0 7.75'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              )}
              {stat.icon === 'dollar' && (
                <svg width='24' height='24' viewBox='0 0 24 24' fill='none'>
                  <path
                    d='M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              )}
              {stat.icon === 'chart' && (
                <svg width='24' height='24' viewBox='0 0 24 24' fill='none'>
                  <polyline
                    points='22 12 18 12 15 21 9 3 6 12 2 12'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              )}
              {stat.icon === 'check' && (
                <svg width='24' height='24' viewBox='0 0 24 24' fill='none'>
                  <path
                    d='M22 11.08V12a10 10 0 1 1-5.93-9.14'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                  <polyline
                    points='22 4 12 14.01 9 11.01'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              )}
              {stat.icon === 'clock' && (
                <svg width='24' height='24' viewBox='0 0 24 24' fill='none'>
                  <circle
                    cx='12'
                    cy='12'
                    r='10'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                  <polyline
                    points='12 6 12 12 16 14'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              )}
            </div>
            <div class='flex flex-col'>
              <div class='text-2xl font-bold leading-tight text-slate-900'>
                {stat.number}
                {stat.suffix}
              </div>
              <div class='text-sm text-slate-600'>{stat.label}</div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Guarantees & Legal Info -->
    <div class='mt-10 grid grid-cols-1 gap-4 lg:grid-cols-3'>
      <div
        class='flex items-center gap-4 rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200 lg:col-span-2'
      >
        <div
          class='flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary ring-1 ring-primary/20'
        >
          <svg class='h-6 w-6' viewBox='0 0 24 24' fill='none' aria-hidden='true'>
            <path
              d='M12 2L4 7V12C4 16.5 6.84 20.74 11 21.96C11.33 22.01 11.67 22.01 12 21.96C16.16 20.74 20 16.5 20 12V7L12 2Z'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
            <path
              d='M9 12L11 14L15 10'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </div>
        <div class='flex-1'>
          <p class='text-sm text-slate-700'>
            <strong class='font-semibold text-slate-900'>Гарантия возврата:</strong>
            100% возврат средств при отказе суда в признании банкротом по вине юриста
            <span class='ml-1 text-slate-500'>(действует весь период ведения дела)</span>
          </p>
        </div>
        <img
          class='hidden h-16 w-auto sm:block rounded-md ring-1 ring-slate-200'
          src='/images/Judge.png'
          alt='Судья'
          loading='lazy'
        />
      </div>
      <div
        class='rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200'
        itemscope
        itemtype='https://schema.org/Organization'
      >
        <p class='text-sm text-slate-700'>
          <strong class='font-semibold text-slate-900'>Юридические реквизиты:</strong>
          {company.fullName}, ИНН <span itemprop='taxID'>{company.legal.inn}</span>, ОГРН <span
            >{company.legal.ogrn}</span
          >
        </p>
      </div>
    </div>

    <!-- Social Proof Ticker -->
    <div class='mt-8 overflow-hidden rounded-xl ring-1 ring-slate-200 bg-white'>
      <div
        class='flex min-w-max animate-[ticker_30s_linear_infinite] gap-6 whitespace-nowrap p-4 text-sm text-slate-700'
        data-ticker
      >
        {
          ticker.map((item) => (
            <div class='inline-flex items-center gap-2'>
              <span class='text-green-600'>●</span>
              {item}
            </div>
          ))
        }
        {
          ticker.map((item) => (
            <div class='inline-flex items-center gap-2'>
              <span class='text-green-600'>●</span>
              {item}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style is:inline>
  @keyframes ticker {
    to {
      transform: translateX(-50%);
    }
  }
</style>

<!-- Load interactive logic when component is visible -->
<StatsComponent client:visible />
