---
import StatsComponent from '../../islands/shared/interactive/statsEnhanced.tsx';
import { SITE_CONSTANTS, getActualStats } from '../config/constants';
import SectionSemantics from './SectionSemantics.astro';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Получаем актуальные данные из констант
const actualStats = getActualStats();
const companyData = SITE_CONSTANTS.company;

// Данные статистики с актуальными значениями
const stats = [
  {
    id: 'clients',
    icon: 'users',
    number: actualStats.clients.count.toString(),
    suffix: '+',
    label: actualStats.clients.label,
    animateFrom: 0,
  },
  {
    id: 'debt',
    icon: 'dollar',
    number: actualStats.debtCleared.amount.toString(),
    suffix: ` ${actualStats.debtCleared.unit}`,
    label: actualStats.debtCleared.label,
    animateFrom: 0,
  },
  {
    id: 'experience',
    icon: 'chart',
    number: actualStats.experience.years.toString(),
    suffix: ' лет',
    label: actualStats.experience.label,
    animateFrom: 0,
  },
  {
    id: 'success',
    icon: 'check',
    number: actualStats.successRate.percent.toString(),
    suffix: '%',
    label: 'Побед в суде',
    animateFrom: 0,
  },
  {
    id: 'time',
    icon: 'clock',
    number: actualStats.averageTime.months,
    suffix: ' мес.',
    label: actualStats.averageTime.label,
    animate: false,
  },
];

// Используем данные из констант
const ticker = SITE_CONSTANTS.testimonials.examples.map(
  (testimonial) => `✅ ${testimonial.name} списала ${testimonial.amount} — ${testimonial.time}`
);

// Используем данные из констант
const company = {
  fullName: companyData.fullName,
  legal: {
    inn: companyData.inn,
    ogrn: companyData.ogrn,
  },
};
---

<section
  class:list={`stats-section section-padding relative overflow-hidden ${className}`}
  id='stats'
  aria-labelledby='stats-title'
  itemscope
  itemtype='https://schema.org/LegalService'
>
  <!-- Reset background to white to override any previous section's background -->
  <div class='absolute inset-0 bg-white z-0'></div>

  <!-- Digital artwork background pattern with financial relief scale -->
  <div
    class='absolute inset-0 z-10 bg-cover bg-center bg-no-repeat opacity-25'
    style='background-image: url("/patterns/stats-pattern.png"); mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 100%);'
  >
  </div>

  <!-- Soft gradient overlay to harmonize with neighboring sections -->
  <div
    class='absolute inset-0 bg-gradient-to-br from-slate-50/40 via-white/60 to-blue-50/30 z-20'
    style='mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 100%);'
  >
  </div>

  <!-- Subtle dot pattern overlay -->
  <div
    class='absolute inset-0 opacity-5 z-30'
    style='background-image: url("/patterns/hero-dots.svg"); background-size: 80px 80px; mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 100%);'
  >
  </div>
  <div class='container-custom relative z-40'>
    <!-- Section Header -->
    <header class='text-center mb-16 md:mb-20 lg:mb-24'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-emerald-100/80 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-emerald-700 ring-1 ring-emerald-200/50 mb-8'
        role='text'
        aria-label='Наши успешные кейсы и результаты'
      >
        <svg
          class='h-4 w-4 text-emerald-600'
          fill='none'
          viewBox='0 0 24 24'
          stroke='currentColor'
          aria-hidden='true'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'></path>
        </svg>
        <span itemscope itemtype='https://schema.org/AggregateRating'>
          <meta itemprop='ratingValue' content='4.9' />
          <meta itemprop='reviewCount' content='{actualStats.clients.count}' />
          <meta itemprop='bestRating' content='5' />
          Доверие клиентов
        </span>
      </div>
      <h2
        id='stats-title'
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 tracking-tight leading-tight'
      >
        Нам доверяют уже <span class='text-blue-600'>{actualStats.clients.display}</span> клиентов
      </h2>
      <p class='text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-medium'>
        Опыт, цифры и гарантии — все прозрачно
      </p>
    </header>

    <!-- Statistics Grid -->
    <div
      class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 md:gap-6'
      role='list'
      aria-label='Статистика компании'
    >
      {
        stats.map((stat) => (
          <div
            class='glass-card p-5'
            role='listitem'
            data-stat={stat.id}
            style='background: transparent !important; backdrop-filter: blur(8px);'
          >
            <div
              class='flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-slate-50 text-slate-700 ring-1 ring-slate-200'
              aria-hidden='true'
            >
              {stat.icon === 'users' && (
                <svg width='24' height='24' viewBox='0 0 24 24' fill='none'>
                  <path
                    d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                  <circle
                    cx='9'
                    cy='7'
                    r='4'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                  <path
                    d='M23 21v-2a4 4 0 0 0-3-3.87'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                  <path
                    d='M16 3.13a4 4 0 0 1 0 7.75'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              )}
              {stat.icon === 'dollar' && (
                <svg width='24' height='24' viewBox='0 0 24 24' fill='none'>
                  <path
                    d='M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              )}
              {stat.icon === 'chart' && (
                <svg width='24' height='24' viewBox='0 0 24 24' fill='none'>
                  <polyline
                    points='22 12 18 12 15 21 9 3 6 12 2 12'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              )}
              {stat.icon === 'check' && (
                <svg width='24' height='24' viewBox='0 0 24 24' fill='none'>
                  <path
                    d='M22 11.08V12a10 10 0 1 1-5.93-9.14'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                  <polyline
                    points='22 4 12 14.01 9 11.01'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              )}
              {stat.icon === 'clock' && (
                <svg width='24' height='24' viewBox='0 0 24 24' fill='none'>
                  <circle
                    cx='12'
                    cy='12'
                    r='10'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                  <polyline
                    points='12 6 12 12 16 14'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                  />
                </svg>
              )}
            </div>
            <div class='flex flex-col'>
              <div class='text-2xl font-bold leading-tight text-slate-900'>
                {stat.number}
                {stat.suffix}
              </div>
              <div class='text-sm text-slate-600'>{stat.label}</div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Guarantees & Legal Info -->
    <div class='mt-10 grid grid-cols-1 gap-4 lg:grid-cols-3'>
      <div
        class='flex items-center gap-4 rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200 lg:col-span-2'
      >
        <div
          class='flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary ring-1 ring-primary/20'
        >
          <svg class='h-6 w-6' viewBox='0 0 24 24' fill='none' aria-hidden='true'>
            <path
              d='M12 2L4 7V12C4 16.5 6.84 20.74 11 21.96C11.33 22.01 11.67 22.01 12 21.96C16.16 20.74 20 16.5 20 12V7L12 2Z'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
            <path
              d='M9 12L11 14L15 10'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </div>
        <div class='flex-1'>
          <p class='text-sm text-slate-700 mb-3'>
            <strong class='font-semibold text-slate-900'>100% побед в суде:</strong>
            Подтверждено данными Федерального реестра сведений о банкротстве
          </p>
          <a
            href='https://old.bankrot.fedresurs.ru/ArbitrManagerCard.aspx?ID=0fe01101-9000-45a5-9a14-31d86002b6ba'
            class='inline-flex items-center text-xs text-blue-600 hover:text-blue-800 transition-colors'
            target='_blank'
            rel='noopener nofollow'
            title='Проверить в реестре Федресурс'
          >
            <svg class='w-3 h-3 mr-1' viewBox='0 0 24 24' fill='none' stroke='currentColor'>
              <path d='M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6'></path>
              <polyline points='15 3 21 3 21 9'></polyline>
              <line x1='10' y1='14' x2='21' y2='3'></line>
            </svg>
            Проверить в реестре Федресурс
          </a>
        </div>
        <img
          class='hidden h-16 w-auto sm:block rounded-md ring-1 ring-slate-200'
          src='/images/Judge.png'
          alt='Судья'
          loading='lazy'
        />
      </div>
      <div
        class='rounded-xl bg-white p-6 shadow-sm ring-1 ring-slate-200'
        itemscope
        itemtype='https://schema.org/Organization'
      >
        <p class='text-sm text-slate-700'>
          <strong class='font-semibold text-slate-900'>Юридические реквизиты:</strong>
          {company.fullName}, ИНН <span itemprop='taxID'>{company.legal.inn}</span>, ОГРН <span
            >{company.legal.ogrn}</span
          >
        </p>
      </div>
    </div>

    <!-- Social Proof Ticker -->
    <div class='mt-8 overflow-hidden rounded-xl ring-1 ring-slate-200 bg-white'>
      <div
        class='flex min-w-max animate-[ticker_30s_linear_infinite] gap-6 whitespace-nowrap p-4 text-sm text-slate-700'
        data-ticker
      >
        {
          ticker.map((item) => (
            <div class='inline-flex items-center gap-2'>
              <span class='text-green-600'>●</span>
              {item}
            </div>
          ))
        }
        {
          ticker.map((item) => (
            <div class='inline-flex items-center gap-2'>
              <span class='text-green-600'>●</span>
              {item}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<!-- Семантические данные для SEO -->
<SectionSemantics sectionId='stats' />

<style is:inline>
  @keyframes ticker {
    to {
      transform: translateX(-50%);
    }
  }

  /* Принудительно делаем карточки статистики полностью прозрачными */
  .stats-section .glass-card {
    background: transparent !important;
    backdrop-filter: blur(8px);
  }

  .stats-section .glass-card:hover {
    background: rgba(255, 255, 255, 0.05) !important;
  }
</style>

<!-- Load interactive logic when component is visible -->
<StatsComponent client:visible />
