---
export interface Props {
  type?: 'wave' | 'curve' | 'slash' | 'triangle' | 'fade';
  position?: 'top' | 'bottom';
  height?: string;
  color?: string;
  bgColor?: string;
  opacity?: number;
  flip?: boolean;
  className?: string;
}

const {
  type = 'wave',
  position = 'bottom',
  height = '70px',
  color = 'white',
  bgColor = 'transparent',
  opacity = 0.8,
  flip = false,
  className = '',
} = Astro.props;

// SVG paths for different divider types
const svgPaths = {
  wave: 'M0,0 C30,60 70,60 100,0 L100,100 L0,100 Z',
  curve: 'M0,100 C50,0 50,0 100,100 L100,100 L0,100 Z',
  slash: 'M0,100 L100,0 L100,100 L0,100 Z',
  triangle: 'M0,100 L50,0 L100,100 L0,100 Z',
  fade: 'M0,0 L100,0 L100,100 L0,100 Z',
};

const path = svgPaths[type] || svgPaths.wave;
const transform = flip ? 'scale(-1, 1)' : '';
---

<div
  class:list={[
    `absolute ${position}-0 left-0 w-full overflow-hidden leading-none z-50 pointer-events-none`,
    className,
  ]}
  style={`height: ${height}`}
>
  {
    type === 'fade' ? (
      <div
        style={`position: absolute; inset: 0; opacity: ${opacity}; background: linear-gradient(to ${position === 'top' ? 'bottom' : 'top'}, ${color} 0%, transparent 100%); height: ${height};`}
      />
    ) : (
      <svg
        class:list={[`relative block w-full text-${color}`]}
        viewBox='0 0 100 100'
        preserveAspectRatio='none'
        aria-hidden='true'
        style={`height: ${height}; opacity: ${opacity};`}
        fill='currentColor'
      >
        <path d={path} transform={transform} />
      </svg>
    )
  }
</div>

<style>
  /* Fix for Safari - ensure the SVG fills the width */
  svg {
    width: 100%;
    height: 100%;
  }
</style>
