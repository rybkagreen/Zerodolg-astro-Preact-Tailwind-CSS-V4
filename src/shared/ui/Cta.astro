---
// Cta.astro
import CTAForm from '../../components/forms/CTAForm.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  data?: Record<string, unknown>;
  [key: string]: unknown;
}

const { title, subtitle } = Astro.props;

// Данные для CTA секции
const cta = {
  title: title || 'Готовы начать жизнь без долгов?',
  subtitle:
    subtitle || 'Оставьте заявку и получите бесплатную консультацию юриста в течение 15 минут',
  form: {
    fields: {
      name: {
        label: 'Ваше имя',
        placeholder: 'Введите ваше имя',
        required: true,
      },
      phone: {
        label: 'Телефон',
        placeholder: '+7 (___) ___-__-__',
        required: true,
      },
      debt: {
        label: 'Сумма долга (необязательно)',
        placeholder: 'Например: 500 000 руб',
      },
    },
    button: 'Готов к консультации? Нажми здесь!',
    agreement: 'Нажимая кнопку, вы соглашаетесь с условиями',
  },
};
---

<!-- Final CTA Section -->
<section
  class='relative py-20 bg-gradient-to-br from-blue-900 to-indigo-900 overflow-hidden'
  id='contact'
  aria-labelledby='cta-title'
>
  <!-- Декоративные плавающие элементы -->
  <div class='absolute inset-0 pointer-events-none' aria-hidden='true'>
    <div
      class='absolute top-10 left-10 w-20 h-20 bg-blue-400 rounded-full opacity-20 animate-float'
    >
    </div>
    <div
      class='absolute top-32 right-20 w-16 h-16 bg-indigo-400 rounded-full opacity-15 animate-float-delayed'
    >
    </div>
    <div
      class='absolute bottom-20 left-20 w-12 h-12 bg-purple-400 rounded-full opacity-25 animate-float'
    >
    </div>
    <div
      class='absolute bottom-32 right-10 w-24 h-24 bg-blue-300 rounded-full opacity-10 animate-float-delayed'
    >
    </div>
  </div>

  <div class='relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
    <header class='text-center mb-16 md:mb-20 lg:mb-24'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-white/20 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-white ring-1 ring-white/30 mb-8'
        aria-label='Бесплатная консультация юриста по банкротству'
      >
        <svg
          class='h-4 w-4 text-white'
          fill='none'
          viewBox='0 0 24 24'
          stroke='currentColor'
          aria-hidden='true'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M13 10V3L4 14h7v7l9-11h-7z'></path>
        </svg>
        <span itemscope itemtype='https://schema.org/Offer'>
          <meta itemprop='name' content='Бесплатная консультация' />
          <meta itemprop='price' content='0' />
          <meta itemprop='priceCurrency' content='RUB' />
          Бесплатная консультация
        </span>
      </div>
      <h2
        id='cta-title'
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight leading-tight'
      >
        {cta.title}
      </h2>
      <p class='text-xl md:text-2xl text-blue-100 max-w-3xl mx-auto leading-relaxed font-medium'>
        {cta.subtitle}
      </p>
    </header>

    <!-- CTA Content Wrapper with Form and Manager Info -->
    <div class='grid lg:grid-cols-2 gap-12 items-start'>
      <!-- Left Column: Form -->
      <div class='bg-white/10 backdrop-blur-sm rounded-xl p-8 border border-white/20'>
        <CTAForm
          formId='cta-consultation-form'
          showDebtField={true}
          submitText='Готов к консультации? Нажми здесь!'
          variant='stacked'
          className='space-y-4 form-on-gradient'
        />
      </div>

      <!-- Right Column: Manager Info with Emblem -->
      <div class='bg-white/10 backdrop-blur-sm rounded-xl p-8 border border-white/20'>
        <!-- Emblem -->
        <div class='flex justify-center mb-6'>
          <img
            src='/icons/ui/emblem.webp'
            alt='Герб Российской Федерации'
            class='w-20 h-20 object-contain'
            loading='lazy'
            width='100'
            height='100'
          />
        </div>

        <!-- Manager Card Link -->
        <div class='text-center'>
          <h3 class='text-lg font-semibold text-white mb-2'>Арбитражный финансовый управляющий</h3>
          <p class='text-xl font-bold text-blue-200 mb-4'>Масхулиа Леван Зурабович</p>
          <p class='text-sm text-blue-100 mb-6 leading-relaxed'>
            ИНН: 505014806562<br />
            Ассоциация арбитражных управляющих саморегулируемая организация "Центральное агентство арбитражных
            управляющих"<br />
            Стаж работы: более 11 лет
          </p>

          <a
            href='https://old.bankrot.fedresurs.ru/ArbitrManagerCard.aspx?ID=0fe01101-9000-45a5-9a14-31d86002b6ba'
            class='inline-flex items-center justify-center px-6 py-3 bg-white/20 hover:bg-white/30 text-white font-medium rounded-lg transition-colors duration-200 backdrop-blur-sm border border-white/30'
            target='_blank'
            rel='noopener nofollow'
            title='Карточка арбитражного управляющего в Едином федеральном реестре сведений о банкротстве'
          >
            <svg
              class='w-5 h-5 mr-2'
              width='20'
              height='20'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
            >
              <path d='M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6'></path>
              <polyline points='15 3 21 3 21 9'></polyline>
              <line x1='10' y1='14' x2='21' y2='3'></line>
            </svg>
            Посмотреть карточку в реестре Федресурс
          </a>

          <div class='mt-6'>
            <p class='text-sm text-blue-100 space-y-1'>
              <span class='block'>✓ Официальный реестр арбитражных управляющих</span>
              <span class='block'>✓ Проверенные данные Федресурс</span>
              <span class='block'>✓ Более 1000 успешных дел</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

