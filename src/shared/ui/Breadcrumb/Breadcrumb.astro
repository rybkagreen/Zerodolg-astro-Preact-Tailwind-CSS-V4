---
/**
 * Breadcrumb component with Schema.org BreadcrumbList markup
 * Улучшает навигацию и SEO сайта через структурированные данные
 */

export interface BreadcrumbItem {
  name: string;
  url: string;
}

export interface Props {
  items: BreadcrumbItem[];
  className?: string;
  showHome?: boolean;
}

const { items, className = '', showHome = true } = Astro.props;

// Всегда добавляем главную страницу в начало
const breadcrumbItems: BreadcrumbItem[] = showHome
  ? [{ name: 'Главная', url: 'https://zerodolg.ru/' }, ...items]
  : items;

// Генерация Schema.org BreadcrumbList
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    item: item.url,
  })),
};
---

<!-- Schema.org BreadcrumbList для поисковых систем --><!-- eslint-disable-next-line astro/no-set-html-directive -->
<script type='application/ld+json' set:html={JSON.stringify(breadcrumbSchema)} />

<!-- Визуальные хлебные крошки -->
<nav
  aria-label='Хлебные крошки'
  class:list={['breadcrumb', className]}
  itemscope
  itemtype='https://schema.org/BreadcrumbList'
>
  <ol class='breadcrumb-list'>
    {
      breadcrumbItems.map((item, index) => {
        const isLast = index === breadcrumbItems.length - 1;
        return (
          <li
            class='breadcrumb-item'
            itemprop='itemListElement'
            itemscope
            itemtype='https://schema.org/ListItem'
          >
            {!isLast ? (
              <>
                <a
                  href={item.url}
                  itemprop='item'
                  class='breadcrumb-link'
                  title={`Перейти к: ${item.name}`}
                >
                  <span itemprop='name'>{item.name}</span>
                </a>
                <meta itemprop='position' content={String(index + 1)} />
                <span class='breadcrumb-separator' aria-hidden='true'>
                  /
                </span>
              </>
            ) : (
              <>
                <span itemprop='name' class='breadcrumb-current'>
                  {item.name}
                </span>
                <meta itemprop='position' content={String(index + 1)} />
              </>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>

<style>
  .breadcrumb {
    padding: 1rem 0;
    margin-bottom: 1.5rem;
  }

  .breadcrumb-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
  }

  .breadcrumb-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumb-link {
    color: #6b7280;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumb-link:hover {
    color: #2563eb;
    text-decoration: underline;
  }

  .breadcrumb-link:focus {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
    border-radius: 2px;
  }

  .breadcrumb-current {
    color: #111827;
    font-weight: 500;
  }

  .breadcrumb-separator {
    color: #d1d5db;
    user-select: none;
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .breadcrumb {
      padding: 0.75rem 0;
      margin-bottom: 1rem;
    }

    .breadcrumb-list {
      font-size: 0.8125rem;
      gap: 0.375rem;
    }

    .breadcrumb-item {
      gap: 0.375rem;
    }
  }

  /* Print styles */
  @media print {
    .breadcrumb {
      display: none;
    }
  }
</style>
