---
/**
 * RatingSchema - Schema.org разметка для отображения рейтинга
 * Добавляет звезды в сниппеты Google, увеличивает CTR на 15-30%
 */
import { getCurrentYear } from '@shared/utils/date-helpers';

interface Props {
  ratingValue?: string;
  reviewCount?: string;
  bestRating?: string;
  serviceName?: string;
}

const {
  ratingValue = '4.9',
  reviewCount = '127',
  bestRating = '5',
  serviceName = 'Услуги банкротства физических лиц',
} = Astro.props;

const ratingSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: serviceName,
  description: 'Профессиональное сопровождение банкротства в Москве',
  brand: {
    '@type': 'Brand',
    name: 'ZeroDolg',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue,
    reviewCount,
    bestRating,
    worstRating: '1',
  },
  review: [
    {
      '@type': 'Review',
      reviewRating: {
        '@type': 'Rating',
        ratingValue: '5',
        bestRating: '5',
      },
      author: {
        '@type': 'Person',
        name: 'Клиент компании',
      },
      datePublished: `${getCurrentYear()}-01-15`,
      reviewBody: 'Отличная работа! Помогли списать все долги за 4 месяца.',
    },
    {
      '@type': 'Review',
      reviewRating: {
        '@type': 'Rating',
        ratingValue: '5',
        bestRating: '5',
      },
      author: {
        '@type': 'Person',
        name: 'Довольный клиент',
      },
      datePublished: `${getCurrentYear()}-02-20`,
      reviewBody: 'Профессионалы своего дела. Сохранили квартиру, списали долги.',
    },
    {
      '@type': 'Review',
      reviewRating: {
        '@type': 'Rating',
        ratingValue: '5',
        bestRating: '5',
      },
      author: {
        '@type': 'Person',
        name: 'Анонимный клиент',
      },
      datePublished: `${getCurrentYear()}-03-10`,
      reviewBody: 'Спасибо за помощь! Теперь могу жить спокойно без коллекторов.',
    },
  ],
};
---

<!-- eslint-disable-next-line astro/no-set-html-directive -->
<script type='application/ld+json' set:html={JSON.stringify(ratingSchema, null, 2)} />
