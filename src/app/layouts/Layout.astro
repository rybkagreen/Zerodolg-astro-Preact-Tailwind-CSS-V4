---
import '../../styles/test.css'; // Импорт тестовых стилей
import { SEO } from '@shared/ui/SEO';
import CookieBanner from '@shared/ui/CookieBanner';

export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  canonical?: string;
  type?: string;
  noindex?: boolean;
  preloadAuthorImage?: boolean;
}

const {
  title = 'ZeroDolg - Банкротство физических лиц в Москве',
  description = '⭐ 98% успешных дел! Законное списание долгов через банкротство физических лиц. ✅ Остановим проценты ✅ Защитим имущество ✅ Гарантия по договору.',
  keywords = 'банкротство физических лиц, списание долгов, банкротство физлиц 2024, защита от коллекторов, реструктуризация долгов, арбитражный управляющий, Москва',
  image = '/images/og-image.jpg',
  canonical = 'https://zerodolg.ru/',
  type = 'website',
  noindex = false,
  preloadAuthorImage = false,
} = Astro.props;
---

<!doctype html>
<html lang='ru'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta name='theme-color' content='#2563eb' />

    <!-- SEO Component -->
    <SEO
      title={title}
      description={description}
      keywords={keywords}
      image={image}
      canonical={canonical}
      type={type}
      noindex={noindex}
    />
    <style is:inline>
      /* Critical above-the-fold styles */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html {
        line-height: 1.15;
        -webkit-text-size-adjust: 100%;
      }
      body {
        margin: 0;
        font-family:
          'Inter Variable',
          'Inter',
          system-ui,
          -apple-system,
          sans-serif;
        font-size: 1rem;
        line-height: 1.5;
        color: #1f2937;
        background-color: #fff;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      /* Global utility classes are defined in critical.css and imported via build process */
    </style>

    <!-- Main CSS will be imported through Astro's build process -->

    <!-- Preconnect to important third-party origins for faster DNS lookup -->
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />

    <!-- Load fonts from Google Fonts with optimized display strategy -->
    <link
      rel='preload'
      as='style'
      href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap'
    />
    <link
      rel='stylesheet'
      href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap'
      media='print'
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel='stylesheet'
        href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap'
      />
    </noscript>

    <!-- Preload critical resources -->
    {preloadAuthorImage && <link rel='preload' href='/images/team/mashulia.webp' as='image' />}
    <link rel='preload' href='/images/logo.png' as='image' />
    <link rel='preload' href='/images/og-image.jpg' as='image' />

    <!-- Prefetch likely next pages -->
    <link rel='prefetch' href='/#reviews' />
    <link rel='prefetch' href='/#faq' />
    <link rel='prefetch' href='/restrukturizaciya-dolgov' />
    <link rel='prefetch' href='/bankrotstvo-s-sokhraneniyem-imushchestva' />

    <!-- DNS prefetch for external domains -->
    <link rel='dns-prefetch' href='//fonts.googleapis.com' />
    <link rel='dns-prefetch' href='//fonts.gstatic.com' />
    <link rel='dns-prefetch' href='//www.googletagmanager.com' />
    <link rel='dns-prefetch' href='//mc.yandex.ru' />

    <!-- Resource hints for better performance -->
    <link rel='preconnect' href='https://mc.yandex.ru' />
    <link rel='preconnect' href='https://www.googletagmanager.com' />

    <!-- Preload critical CSS - handled through import mechanism -->

    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='icon' type='image/png' href='/favicon.png' />
    <link rel='apple-touch-icon' href='/apple-touch-icon.png' />

    <!-- Web App Manifest -->
    <link rel='manifest' href='/manifest.json' />

    <meta name='generator' content={Astro.generator} />

    <!-- Yandex.Metrika counter -->
    <!-- eslint-disable-next-line astro/no-set-html-directive -- Safe: Yandex Metrika standard code -->
    <script is:inline>
      /* eslint-disable */
      (function (m, e, t, r, i, k, a) {
        m[i] =
          m[i] ||
          function () {
            (m[i].a = m[i].a || []).push(arguments);
          };
        m[i].l = 1 * new Date();
        for (var j = 0; j < document.scripts.length; j++) {
          if (document.scripts[j].src === r) {
            return;
          }
        }
        ((k = e.createElement(t)),
          (a = e.getElementsByTagName(t)[0]),
          (k.async = 1),
          (k.src = r),
          a.parentNode.insertBefore(k, a));
      })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js', 'ym');

      ym(103604926, 'init', {
        defer: true,
        clickmap: true,
        trackLinks: true,
        accurateTrackBounce: true,
        webvisor: true,
        ecommerce: 'dataLayer',
        triggerEvent: true,
      });
      /* eslint-enable */
    </script>
    <noscript
      ><div>
        <img
          src='https://mc.yandex.ru/watch/103604926'
          style='position:absolute; left:-9999px;'
          alt=''
        />
      </div></noscript
    >
    <!-- /Yandex.Metrika counter -->

    <!-- Google Analytics -->
    <!-- eslint-disable-next-line astro/no-set-html-directive -- Safe: Google Analytics standard code -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500,
      });
      gtag('js', new Date());
      gtag('config', 'G-BDDN306E94', {
        anonymize_ip: true,
        cookie_flags: 'SameSite=None;Secure',
      });
    </script>
    <script async src='https://www.googletagmanager.com/gtag/js?id=G-BDDN306E94' is:inline></script>
    <!-- /Google Analytics -->

    <!-- Bitrix24 Tracking Script -->
    <!-- eslint-disable-next-line astro/no-set-html-directive -- Safe: Bitrix24 standard tracking code -->
    <script is:inline>
      /* eslint-disable-next-line @typescript-eslint/no-unused-expressions */
      !(function (w, d, s, h, id) {
        w.Bitrix24FormObject = w.Bitrix24FormObject || [];
        w.Bitrix24FormObject.push(id);
        const js = d.createElement(s);
        js.async = 1;
        js.src = 'https://cdn.bitrix24.ru/b24/crm/sitebutton/js/code.js';
        js.onload = function () {
          if (typeof B24FormUtils !== 'undefined') {
            B24FormUtils.init();
          }
        };
        const sc = d.getElementsByTagName(s)[0];
        sc.parentNode.insertBefore(js, sc);
      })(window, document, 'script', '', 'b24-web-form-1');
    </script>
    <!-- /Bitrix24 Tracking Script -->

    <!-- Bitrix24 Call Tracking Script -->
    <!-- eslint-disable-next-line astro/no-set-html-directive -- Safe: Bitrix24 call tracking code -->
    <script is:inline>
      (function (w, d, u) {
        const s = d.createElement('script');
        s.async = true;
        s.src = u + '?' + ((Date.now() / 60000) | 0);
        const h = d.getElementsByTagName('script')[0];
        h.parentNode.insertBefore(s, h);
      })(window, document, 'https://cdn-ru.bitrix24.ru/b34776794/crm/tag/call.tracker.js');
    </script>
    <!-- /Bitrix24 Call Tracking Script -->
  </head>
  <body>
    <slot />

    <!-- Cookie Consent Banner -->
    <CookieBanner client:load />

    <!-- Service Worker Removal Script - temporary -->
    <script is:inline defer src='/js/service-worker-register.js'></script>

    <!-- Passive Event Listeners for better performance -->
    <script is:inline defer src='/js/passive-event-listeners.js'></script>
  </body>
</html>
