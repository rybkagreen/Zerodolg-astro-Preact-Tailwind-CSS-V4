---
import '../styles/globals.css'; // Импорт Tailwind CSS
import '../../styles/sections.css'; // Импорт единых стилей секций
import { SEO } from '@shared/ui/SEO';
import CookieBanner from '@shared/ui/CookieBanner';

export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  canonical?: string;
  type?: string;
  noindex?: boolean;
  preloadAuthorImage?: boolean;
}

const {
  title = 'ZeroDolg - Банкротство физических лиц в Москве',
  description = '⭐ 98% успешных дел! Законное списание долгов через банкротство физических лиц. ✅ Остановим проценты ✅ Защитим имущество ✅ Гарантия по договору.',
  keywords = 'банкротство физических лиц, списание долгов, банкротство физлиц 2024, защита от коллекторов, реструктуризация долгов, арбитражный управляющий, Москва',
  image = '/images/og-image.jpg',
  canonical = 'https://zerodolg.ru/',
  type = 'website',
  noindex = false,
  preloadAuthorImage = false,
} = Astro.props;
---

<!doctype html>
<html lang='ru'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta name='theme-color' content='#2563eb' />

    <!-- SEO Component -->
    <SEO
      title={title}
      description={description}
      keywords={keywords}
      image={image}
      canonical={canonical}
      type={type}
      noindex={noindex}
    />

    <!-- Critical CSS inlined for optimal performance -->
    <style is:inline>
      /* Critical above-the-fold styles */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html {
        line-height: 1.15;
        -webkit-text-size-adjust: 100%;
      }
      body {
        margin: 0;
        font-family:
          'Inter Variable',
          'Inter',
          system-ui,
          -apple-system,
          sans-serif;
        font-size: 1rem;
        line-height: 1.5;
        color: #1f2937;
        background-color: #fff;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      /* Global utility classes are defined in critical.css and imported via build process */
    </style>

    <!-- Main CSS will be imported through Astro's build process -->

    <!-- Preconnect to important third-party origins -->
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />

    <!-- Load fonts from Google Fonts -->
    <link
      rel='stylesheet'
      href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap'
    />

    <!-- Preload critical resources -->
    {preloadAuthorImage && <link rel='preload' href='/images/team/mashulia.webp' as='image' />}

    <!-- Prefetch likely next pages -->
    <link rel='prefetch' href='/#reviews' />
    <link rel='prefetch' href='/#faq' />

    <!-- DNS prefetch for external domains -->
    <link rel='dns-prefetch' href='//fonts.googleapis.com' />
    <link rel='dns-prefetch' href='//fonts.gstatic.com' />

    <!-- Preload critical CSS - handled through import mechanism -->

    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='icon' type='image/png' href='/favicon.png' />
    <link rel='apple-touch-icon' href='/apple-touch-icon.png' />

    <!-- Web App Manifest -->
    <link rel='manifest' href='/manifest.json' />

    <meta name='generator' content={Astro.generator} />
  </head>
  <body>
    <slot />

    <!-- Cookie Consent Banner -->
    <CookieBanner client:load />

    <!-- Service Worker Removal Script - temporary -->
    <script is:inline defer src='/js/service-worker-register.js'></script>

    <!-- Initialize analytics after DOM is ready -->
    <script type='module'>
      import { initAnalytics } from '/src/features/analytics/analytics';
      import { measurePageLoad } from '/src/shared/lib/performance';

      document.addEventListener('DOMContentLoaded', () => {
        if (typeof initAnalytics === 'function') {
          initAnalytics();
        }
        if (typeof measurePageLoad === 'function') {
          measurePageLoad();
        }
      });
    </script>
  </body>
</html>
