---
import Layout from '@app/layouts/Layout.astro';
import CallbackModal from '@features/modals/ui/CallbackModal.astro';
import SimpleModalInit from '../islands/utils/SimpleModalInit.tsx';
---

<Layout title='Тест модальных окон - ZeroDolg'>
  <div class='container mx-auto px-4 py-8'>
    <h1 class='text-3xl font-bold mb-8 text-center'>🧪 Тест модальных окон</h1>

    <div class='grid gap-6 max-w-2xl mx-auto'>
      <div class='bg-white p-6 rounded-lg shadow-md'>
        <h2 class='text-xl font-semibold mb-4'>Тесты кнопок</h2>

        <div class='space-y-4'>
          <button
            data-modal='callback'
            class='w-full bg-primary text-white px-6 py-3 rounded-lg hover:bg-primary-600 transition-colors'
          >
            🔓 Открыть модальное окно "Обратный звонок"
          </button>

          <button
            onclick='window.modalManager && window.modalManager.open("callback")'
            class='w-full bg-accent text-white px-6 py-3 rounded-lg hover:bg-accent-600 transition-colors'
          >
            🔧 Открыть через JavaScript API
          </button>

          <button
            onclick='window.modalDebug && window.modalDebug.debug()'
            class='w-full bg-gray-600 text-white px-6 py-3 rounded-lg hover:bg-gray-700 transition-colors'
          >
            🔍 Запустить отладку (см. консоль)
          </button>

          <button
            onclick='window.modalDebug && window.modalDebug.testModal("callback")'
            class='w-full bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors'
          >
            🧪 Протестировать модаль "callback"
          </button>
        </div>
      </div>

      <div class='bg-gray-50 p-6 rounded-lg'>
        <h2 class='text-xl font-semibold mb-4'>Инструкции</h2>
        <div class='text-sm text-gray-600 space-y-2'>
          <p>• Откройте консоль разработчика (F12)</p>
          <p>• Нажмите кнопку "Запустить отладку" для диагностики</p>
          <p>• Попробуйте открыть модальное окно разными способами</p>
          <p>• Используйте <code>window.modalDebug.debug()</code> в консоли</p>
          <p>• Используйте <code>window.modalManager</code> для управления модалями</p>
        </div>
      </div>

      <div class='bg-blue-50 p-6 rounded-lg border border-blue-200'>
        <h2 class='text-xl font-semibold mb-4 text-blue-800'>Доступные команды в консоли</h2>
        <div class='text-sm text-blue-700 font-mono space-y-1'>
          <p>window.modalDebug.debug() - полная отладочная информация</p>
          <p>window.modalDebug.testModal('callback') - тест конкретной модали</p>
          <p>window.modalManager.open('callback') - открыть модаль</p>
          <p>window.modalManager.close() - закрыть текущую модаль</p>
          <p>window.modalManager.debug() - статистика модального менеджера</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Модальные окна -->
  <CallbackModal modalId='callback' />

  <!-- Простой инициализатор модального менеджера -->
  <SimpleModalInit client:load />
</Layout>

<style>
  .container {
    min-height: 100vh;
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  }

  code {
    background: rgba(0, 0, 0, 0.1);
    padding: 2px 4px;
    border-radius: 3px;
  }
</style>
