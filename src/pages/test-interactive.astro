---
import Layout from '../layouts/Layout.astro';
import Header from '../components/static/Header.astro';
import Timeline from '../components/islands/Timeline.astro';
import TeamInteractive from '../components/sections/TeamInteractive.astro';
---

<Layout title="Тест интерактивности">
  <Header />
  
  <main style="padding-top: 100px;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 20px;">
      <h1>Тестирование интерактивных компонентов</h1>
      
      <section style="margin: 40px 0;">
        <h2>Timeline компонент:</h2>
        <Timeline />
      </section>
      
      <section style="margin: 40px 0;">
        <h2>Team компонент:</h2>
        <TeamInteractive />
      </section>
    </div>
  </main>
  
  <script>
    // Отладочный скрипт для проверки загрузки компонентов
    document.addEventListener('DOMContentLoaded', () => {
      console.log('DOM loaded');
      
      // Проверяем Timeline
      const timeline = document.querySelector('.timeline');
      console.log('Timeline found:', !!timeline);
      if (timeline) {
        const steps = timeline.querySelectorAll('.timeline__step');
        console.log('Timeline steps:', steps.length);
        
        const buttons = timeline.querySelectorAll('[data-action]');
        console.log('Timeline action buttons:', buttons.length);
      }
      
      // Проверяем Team
      const team = document.querySelector('.team-interactive');
      console.log('Team found:', !!team);
      if (team) {
        const tabs = team.querySelectorAll('.team-tab');
        console.log('Team tabs:', tabs.length);
      }
      
      // Проверяем загрузку Preact компонентов
      setTimeout(() => {
        console.log('Checking Preact components after delay...');
        const astroIslands = document.querySelectorAll('astro-island');
        console.log('Astro islands found:', astroIslands.length);
        astroIslands.forEach((island, i) => {
          console.log(`Island ${i}:`, {
            component: island.getAttribute('component-url'),
            props: island.getAttribute('props'),
            hydrate: island.getAttribute('client')
          });
        });
      }, 1000);
    });
  </script>
</Layout>
