                </div>
                <p class='text-gray-300 text-sm'>Квартира, автомобиль и ценности остаются у вас</p>
              </div>

              <div
                class='rounded-xl bg-gradient-to-br from-emerald-500/10 to-teal-600/10 backdrop-blur-sm border border-emerald-500/30 p-5'
              >
                <div class='flex items-center gap-3 mb-3'>
                  <div
                    class='w-10 h-10 rounded-full bg-emerald-500/20 flex items-center justify-center'
                  >
                    <svg
                      class='w-5 h-5 text-emerald-400'
                      fill='none'
                      stroke='currentColor'
                      viewBox='0 0 24 24'
