                    <a
                      href='https://yandex.ru/maps/?pt=37.504754,55.724143&z=16&l=map'
                      target='_blank'
                      rel='noopener noreferrer'
                      class='text-emerald-400 hover:text-emerald-300 transition-colors flex items-center gap-2'
