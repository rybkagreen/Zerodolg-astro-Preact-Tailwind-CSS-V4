                          <span itemprop='addressCountry'>Россия</span>
                        </div>
                        <meta itemprop='postalCode' content='119590' />
                      </div>
                    </div>
                  </div>

                  <!-- Structured Data for Location -->
                  <meta itemprop='name' content='ZeroDolg - Юридическая помощь по банкротству' />
                  <meta itemprop='telephone' content='+7-905-577-33-87' />
                  <div itemprop='geo' itemscope itemtype='https://schema.org/GeoCoordinates'>
                    <meta itemprop='latitude' content='55.724143' />
                    <meta itemprop='longitude' content='37.504754' />
