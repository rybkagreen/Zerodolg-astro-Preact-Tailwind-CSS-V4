              </div>
            </div>

            <!-- Office Location Map -->
            <div class='mt-8'>
              <div
                class='rounded-2xl overflow-hidden border-2 border-emerald-500/30 shadow-2xl backdrop-blur-sm h-full flex flex-col'
                itemscope
                itemtype='https://schema.org/Place'
              >
                <!-- Map Container -->
                <div class='relative flex-1 w-full bg-gray-900 min-h-[400px]'>
                  <iframe
                    src='https://yandex.ru/map-widget/v1/?ll=37.504754%2C55.724143&z=16&l=map&pt=37.504754%2C55.724143%2Cpmwtm'
                    frameborder='0'
                    allowfullscreen='true'
                    style='position:absolute;top:0;left:0;width:100%;height:100%;border:0;'
                    loading='lazy'
                    title='Офис ZeroDolg - Юридическая помощь по банкротству и реструктуризации долгов в Москве'
                    aria-label='Карта с местоположением офиса ZeroDolg в Москве'></iframe>

                  <!-- Map Overlay Info -->
                  <div
                    class='absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-4'
