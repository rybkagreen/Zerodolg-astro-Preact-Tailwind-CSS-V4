---
import { getCollection } from 'astro:content';
import Layout from '@app/layouts/Layout.astro';
import Header from '@widgets/header/Header.astro';
import Footer from '@widgets/footer/Footer.astro';
import Breadcrumb from '@shared/ui/Breadcrumb/Breadcrumb.astro';
import CallbackModal from '@features/modals/ui/CallbackModal.astro';
import SimpleModalInit from '../../islands/utils/SimpleModalInit.tsx';
import OnlineSticker from '@shared/ui/OnlineSticker.astro';
import BitrixCallback from '@shared/ui/BitrixCallback.astro';
import ClientInteractions from '../../islands/utils/client-interactions.tsx';

const blogPosts = await getCollection('blog');

// Sort posts by date (newest first)
blogPosts.sort((a, b) => {
  return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
});

// Filter out posts without proper title
const validPosts = blogPosts.filter(
  (post) => post.data.title && post.data.title !== 'Без названия'
);

// Get unique tags
const allTags = [...new Set(validPosts.flatMap((post) => post.data.tags || []))];

// Format reading time
function _getReadingTime(content: string): string {
  const wordsPerMinute = 200;
  const words = content.split(/\s+/).length;
  const minutes = Math.ceil(words / wordsPerMinute);
  return `${minutes} мин`;
}

// SEO данные
const pageTitle = 'Блог о банкротстве физических лиц 2025 | Статьи и советы экспертов ZeroDolg';
const pageDescription =
  'Актуальные статьи о банкротстве физических лиц, реструктуризации долгов и защите от кредиторов ⚡ Экспертные советы ⚡ Пошаговые инструкции ⚡ Реальный опыт';
const canonical = 'https://zerodolg.ru/blog/';
---

<Layout title={pageTitle} description={pageDescription} canonical={canonical} type='blog'>
  <Header currentPage='blog' />

  <!-- Breadcrumb Navigation -->
  <div class='container mx-auto px-4'>
    <Breadcrumb
      items={[
        {
          name: 'Блог',
          url: canonical,
        },
      ]}
    />
  </div>

  <main>
    <!-- Hero Section -->
    <section
      class='relative bg-gradient-to-br from-blue-900 via-slate-800 to-blue-800 text-white py-16'
    >
      <div class='absolute inset-0 opacity-10'>
        <div class='absolute top-0 left-0 w-96 h-96 bg-blue-500 rounded-full filter blur-3xl'></div>
        <div class='absolute bottom-0 right-0 w-96 h-96 bg-indigo-500 rounded-full filter blur-3xl'>
        </div>
      </div>

      <div class='container mx-auto px-4 relative z-10'>
        <div class='max-w-4xl mx-auto text-center'>
          <h1 class='text-4xl md:text-5xl font-bold mb-6 leading-tight'>
            Блог о банкротстве физических лиц
          </h1>
          <p class='text-xl md:text-2xl text-blue-100 mb-8'>
            Экспертные статьи, пошаговые инструкции и реальные кейсы по списанию долгов и
            финансовому восстановлению
          </p>
          <div class='flex flex-wrap gap-4 justify-center items-center'>
            <div
              class='flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full'
            >
              <svg class='w-5 h-5 text-blue-300' fill='currentColor' viewBox='0 0 20 20'>
                <path
                  d='M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z'
                ></path>
              </svg>
              <span class='text-sm'>{validPosts.length} статей</span>
            </div>
            <div
              class='flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full'
            >
              <svg class='w-5 h-5 text-blue-300' fill='currentColor' viewBox='0 0 20 20'>
                <path
                  fill-rule='evenodd'
                  d='M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z'
                  clip-rule='evenodd'></path>
              </svg>
              <span class='text-sm'>Обновлено в октябре 2025</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Blog Posts Grid -->
    <section class='py-16 bg-white'>
      <div class='container mx-auto px-4'>
        <!-- Popular Tags -->
        {
          allTags.length > 0 && (
            <div class='max-w-6xl mx-auto mb-12'>
              <h2 class='text-lg font-semibold text-gray-700 mb-4'>Популярные темы:</h2>
              <div class='flex flex-wrap gap-3'>
                {allTags.slice(0, 8).map((tag) => (
                  <span class='inline-flex items-center gap-1 bg-blue-50 text-blue-700 px-4 py-2 rounded-full text-sm font-medium hover:bg-blue-100 transition-colors cursor-pointer'>
                    <svg class='w-4 h-4' fill='currentColor' viewBox='0 0 20 20'>
                      <path
                        fill-rule='evenodd'
                        d='M17.707 9.293a1 1 0 010 1.414l-7 7a1 1 0 01-1.414 0l-7-7A.997.997 0 012 10V5a3 3 0 013-3h5c.256 0 .512.098.707.293l7 7zM5 6a1 1 0 100-2 1 1 0 000 2z'
                        clip-rule='evenodd'
                      />
                    </svg>
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )
        }

        <!-- Articles Grid -->
        <div class='max-w-6xl mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-8'>
          {
            validPosts.map((post) => (
              <article class='group bg-white rounded-xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 flex flex-col'>
                {/* Article Image/Icon */}
                <div class='relative h-48 bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center overflow-hidden'>
                  <div class='absolute inset-0 opacity-20'>
                    <div class='absolute top-0 left-0 w-32 h-32 bg-white rounded-full filter blur-2xl' />
                    <div class='absolute bottom-0 right-0 w-32 h-32 bg-white rounded-full filter blur-2xl' />
                  </div>
                  <div class='relative z-10'>
                    <svg
                      class='w-20 h-20 text-white/90'
                      fill='none'
                      stroke='currentColor'
                      viewBox='0 0 24 24'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                      />
                    </svg>
                  </div>
                  {/* Featured Badge */}
                  {post.data.tags?.includes('популярное') && (
                    <div class='absolute top-4 right-4 bg-amber-500 text-white px-3 py-1 rounded-full text-xs font-bold'>
                      ⭐ Популярное
                    </div>
                  )}
                </div>

                {/* Article Content */}
                <div class='p-6 flex-1 flex flex-col'>
                  {/* Tags */}
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class='flex flex-wrap gap-2 mb-3'>
                      {post.data.tags.slice(0, 2).map((tag) => (
                        <span class='inline-block bg-blue-50 text-blue-600 px-2 py-1 rounded text-xs font-medium'>
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}

                  {/* Title */}
                  <h2 class='text-xl font-bold mb-3 group-hover:text-blue-600 transition-colors line-clamp-2'>
                    <a href={`/blog/${post.slug}`} class='hover:underline'>
                      {post.data.title}
                    </a>
                  </h2>

                  {/* Description */}
                  {post.data.description && (
                    <p class='text-gray-600 mb-4 line-clamp-3 flex-1'>{post.data.description}</p>
                  )}

                  {/* Meta Info */}
                  <div class='flex items-center justify-between text-sm text-gray-500 mt-auto pt-4 border-t border-gray-100'>
                    <div class='flex items-center gap-4'>
                      {post.data.pubDate && (
                        <time
                          datetime={post.data.pubDate.toISOString()}
                          class='flex items-center gap-1'
                        >
                          <svg class='w-4 h-4' fill='currentColor' viewBox='0 0 20 20'>
                            <path
                              fill-rule='evenodd'
                              d='M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z'
                              clip-rule='evenodd'
                            />
                          </svg>
                          {post.data.pubDate.toLocaleDateString('ru-RU', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric',
                          })}
                        </time>
                      )}
                    </div>
                    <a
                      href={`/blog/${post.slug}`}
                      class='text-blue-600 font-medium hover:text-blue-700 flex items-center gap-1 group-hover:gap-2 transition-all'
                    >
                      Читать
                      <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                        <path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2'
                          d='M9 5l7 7-7 7'
                        />
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        <!-- Empty State -->
        {
          validPosts.length === 0 && (
            <div class='max-w-2xl mx-auto text-center py-16'>
              <svg
                class='w-24 h-24 text-gray-300 mx-auto mb-4'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                />
              </svg>
              <h3 class='text-2xl font-bold text-gray-700 mb-2'>Статьи скоро появятся</h3>
              <p class='text-gray-500'>Мы работаем над созданием полезного контента для вас</p>
            </div>
          )
        }
      </div>
    </section>

    <!-- CTA Section -->
    <section class='py-16 bg-gradient-to-br from-blue-50 to-indigo-50'>
      <div class='container mx-auto px-4'>
        <div class='max-w-4xl mx-auto bg-white rounded-2xl shadow-xl p-8 md:p-12 text-center'>
          <h2 class='text-3xl font-bold mb-4 text-gray-900'>Не нашли ответ на свой вопрос?</h2>
          <p class='text-lg text-gray-600 mb-8'>
            Получите бесплатную консультацию от наших экспертов по банкротству и реструктуризации
            долгов
          </p>
          <div class='flex flex-col sm:flex-row gap-4 justify-center'>
            <button
              class='bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-8 rounded-lg transition-colors inline-flex items-center justify-center gap-2'
              data-modal='consultation'
            >
              <svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z'
                ></path>
              </svg>
              Получить консультацию
            </button>
            <a
              href='tel:+79055773387'
              class='bg-white border-2 border-blue-600 text-blue-600 hover:bg-blue-50 font-bold py-4 px-8 rounded-lg transition-colors inline-flex items-center justify-center gap-2'
            >
              <svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'
                ></path>
              </svg>
              +7 (905) 577-33-87
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Auxiliary Components -->
  <OnlineSticker />
  <BitrixCallback />

  <!-- Modals -->
  <CallbackModal modalId='callback' />
  <CallbackModal modalId='consultation' />
  <SimpleModalInit client:idle />

  <!-- Client Interactions Handler -->
  <ClientInteractions client:idle />
</Layout>
