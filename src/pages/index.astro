---
import Layout from '../layouts/Layout.astro';
import Header from '../components/static/Header.astro';
import Hero from '../components/islands/Hero.astro';
import Stats from '../components/islands/Stats.astro';
import Calculator from '../components/islands/Calculator.astro';
import Benefits from '../components/sections/Benefits.astro';
import Timeline from '../components/islands/Timeline.astro';
import TeamInteractive from '../components/sections/TeamInteractive.astro';
import LeadMagnets from '../components/sections/LeadMagnets.astro';
import Reviews from '../components/sections/Reviews.astro';
import Faq from '../components/islands/Faq.astro';
import Cta from '../components/static/Cta.astro';
import Footer from '../components/static/Footer.astro';
import CallbackModal from '../components/dynamic/CallbackModal.astro';
import ModalManager from '../components/preact/modal-manager.tsx';
import SocialLinks from '../components/sections/SocialLinks.astro';
import ScrollAnimations from '../components/preact/scroll-animations.tsx';
import OnlineSticker from '../components/islands/OnlineSticker.astro';
import BitrixCallback from '../components/islands/BitrixCallback.astro';
import SpecialOffers from '../components/islands/SpecialOffers.astro';
---

<Layout title="Банкротство физических лиц под ключ - ZeroDolg">
  <Header />
  
  <main>
    <!-- Correct order: Hero, Problems, Stats, Calculator, Benefits, Timeline, Reviews, Team, Lead Magnets, FAQ, CTA -->
    <Hero />
    
    <!-- Problems section - to be migrated -->
    <!-- <Problems /> -->
    
    <div data-aos="fade-up" data-aos-duration="800">
      <Stats />
    </div>
    
    <div data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
      <Calculator />
    </div>
    
    <div data-aos="fade-up" data-aos-duration="800">
      <Benefits />
    </div>
    
    <div data-aos="fade-up" data-aos-duration="800">
      <Timeline />
    </div>
    
    <div data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
      <Reviews />
    </div>
    
    <div data-aos="fade-up" data-aos-duration="800">
      <TeamInteractive />
    </div>
    
    <div data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
      <LeadMagnets />
    </div>
    
    <div data-aos="fade-up" data-aos-duration="800">
      <Faq />
    </div>
    
    <div data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
      <Cta />
    </div>
  </main>
  
  <Footer />
  
  <!-- Auxiliary Components -->
  <OnlineSticker />
  <BitrixCallback />
  
  <!-- Social Links in Footer Section -->
  <div class="social-links-wrapper">
    <SocialLinks />
  </div>
  
  <!-- Modals -->
  <CallbackModal />
  
  <!-- Modal Manager for handling all modals -->
  <ModalManager client:idle />
  
  <!-- Special Offers Components -->
  <SpecialOffers client:idle />
  
  <!-- Scroll Animations Handler -->
  <ScrollAnimations client:idle once={true} offset={100} duration={800} />
</Layout>
