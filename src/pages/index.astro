---
// Enable static pre-rendering for the homepage in hybrid mode
export const prerender = true;

import Layout from '@app/layouts/Layout.astro';
import Header from '@widgets/header/Header.astro';
import OrganizationSchema from '../shared/seo/OrganizationSchema.astro';
import Hero from '../components/sections/Hero.astro';
import Problems from '../components/sections/Problems.astro';
import SolutionChoice from '../components/sections/SolutionChoice.astro';
import Stats from '@shared/ui/Stats.astro';
import Calculator from '@features/calculator/ui/Calculator.astro';
import Benefits from '../components/sections/Benefits.astro';
import Process from '../components/sections/Process.astro';
import TeamInteractive from '../components/sections/TeamInteractive.astro';
import PrivacyApproach from '../components/sections/PrivacyApproach.astro';
import LeadMagnets from '../components/sections/LeadMagnets.astro';
import Reviews from '@widgets/reviews/Reviews.astro';
import Faq from '@widgets/faq/Faq.astro';
import Cta from '@shared/ui/Cta.astro';
import Footer from '@widgets/footer/Footer.astro';
import CallbackModal from '@features/modals/ui/CallbackModal.astro';
import LeadMagnetsModals from '@features/modals/ui/LeadMagnetsModals.astro';
import SimpleModalInit from '../islands/utils/SimpleModalInit.tsx';
import SocialLinks from '../islands/shared/interactive/social-links.tsx';

import OnlineSticker from '@shared/ui/OnlineSticker.astro';
import BitrixCallback from '@shared/ui/BitrixCallback.astro';
import SpecialOffers from '@shared/ui/SpecialOffers.astro';
import ClientInteractions from '../islands/utils/client-interactions.tsx';
import FaqAccordion from '../islands/utils/faq-accordion.tsx';
import { SEO_CONFIG } from '@shared/config/seo-config';

// Получаем SEO-данные для главной страницы
const { title, description, keywords, canonical } = SEO_CONFIG.home;
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonical={canonical}
  includeLocalBusiness={true}
  howTo={{
    name: 'Как пройти процедуру банкротства физического лица',
    description:
      'Пошаговая инструкция прохождения процедуры банкротства физического лица через арбитражный суд для полного списания долгов',
    totalTime: 'P6M',
    estimatedCost: { currency: 'RUB', value: '50000' },
    steps: [
      {
        name: 'Бесплатная консультация',
        text: 'Запишитесь на консультацию к юристу. Мы проанализируем вашу ситуацию и определим оптимальную стратегию банкротства.',
      },
      {
        name: 'Сбор и подготовка документов',
        text: 'Соберем все необходимые документы: справки о доходах, выписки по счетам, договоры займов и кредитов, документы на имущество.',
      },
      {
        name: 'Подача заявления в арбитражный суд',
        text: 'Подготовим и подадим заявление о признании банкротом в арбитражный суд по вашему месту жительства.',
      },
      {
        name: 'Назначение финансового управляющего',
        text: 'Суд назначит финансового управляющего для проведения процедуры банкротства и работы с кредиторами.',
      },
      {
        name: 'Реализация имущества или реструктуризация',
        text: 'В зависимости от ситуации суд применит процедуру реализации имущества или реструктуризации долгов.',
      },
      {
        name: 'Завершение процедуры и списание долгов',
        text: 'После завершения процедуры суд выносит решение о списании оставшихся долгов. Вы получаете свободу от финансовых обязательств.',
      },
    ],
  }}
>
  <OrganizationSchema services='both' pageType='homepage' slot='head' />
  <Header />

  <main>
    <!-- Correct order: Hero, Problems, Stats, Calculator, Benefits, Timeline, Reviews, Team, Lead Magnets, FAQ, CTA -->
    <Hero />

    <!-- Use fade-up for sections without conflicting animations -->
    <div style='z-index: 10; position: relative;'>
      <Problems />
    </div>

    <div style='z-index: 1; position: relative;'>
      <SolutionChoice />
    </div>

    <div style='z-index: 1; position: relative;'>
      <Stats />
    </div>

    <div style='z-index: 10; position: relative;'>
      <Calculator />
    </div>

    <!-- Use fade (no transform) for sections with native card animations -->
    <div style='z-index: 10; position: relative;'>
      <Benefits />
    </div>

    <div style='z-index: 1; position: relative;'>
      <Process />
    </div>

    <div style='z-index: 10; position: relative;'>
      <Reviews />
    </div>

    <div style='z-index: 10; position: relative;'>
      <TeamInteractive />
    </div>

    <div style='z-index: 1; position: relative;'>
      <PrivacyApproach />
    </div>

    <!-- FAQ has native animations, use simple fade -->
    <div style='z-index: 1; position: relative;'>
      <Faq />
    </div>

    <div style='z-index: 1; position: relative;'>
      <LeadMagnets />
    </div>

    <div style='z-index: 10; position: relative;'>
      <Cta />
    </div>
  </main>

  <Footer />

  <!-- Auxiliary Components -->
  <OnlineSticker />
  <BitrixCallback />

  <!-- Social Links in Footer Section -->
  <div class='social-links-wrapper'>
    <SocialLinks />
  </div>

  <!-- Modals -->
  <CallbackModal modalId='callback' />

  <!-- Lead Magnets Modals -->
  <LeadMagnetsModals />

  <!-- Simple Modal Manager for handling all modals -->
  <SimpleModalInit client:idle />

  <!-- Special Offers Components -->
  <SpecialOffers />

  <!-- Client Interactions Handler for buttons, links, and dynamic elements -->
  <ClientInteractions client:idle />

  <!-- FAQ Accordion Handler -->
  <FaqAccordion client:load />
</Layout>
