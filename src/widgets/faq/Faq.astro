---
// Faq.astro
import { SITE_CONSTANTS } from '../../shared/config/constants';
import { getFAQSchemaData } from '../../shared/data/faq-data';
import { faqSchema } from '../../shared/lib/structured-data';

interface FaqQuestion {
  question: string;
  answer: string;
}

interface FaqGroup {
  title: string;
  questions: FaqQuestion[];
}

export interface Props {
  title?: string;
  data?: FaqGroup[];
  [key: string]: unknown;
}

// Get FAQ data for structured schema
const faqSchemaData = getFAQSchemaData();

// Interactive logic is handled by FaqAccordion component in main layout
---

<!-- FAQ Section - Modern Accordion Style -->
<section class='faq-section section-padding relative overflow-hidden' id='faq' data-section='faq'>
  <!-- Background gradient - NO MASK (always visible) -->
  <div
    class='absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-blue-50/40'
    style='z-index: -12; pointer-events: none;'
  >
  </div>

  <!-- Background with watercolor pattern - fade-out at bottom (ONLY THIS HAS MASK) -->
  <div
    class='absolute inset-0 opacity-15'
    style='z-index: -11; background-image: url("/patterns/leadmagnets-pattern.png"); background-size: cover; background-position: center; background-repeat: no-repeat; pointer-events: none; mask-image: linear-gradient(to bottom, black 0%, black 85%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 85%, transparent 100%);'
  >
  </div>

  <div class='container mx-auto px-4 sm:px-6 lg:px-8 relative z-10'>
    <!-- Section Header -->
    <header class='text-center mb-12 md:mb-16 lg:mb-20'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-white/95 border border-blue-100 px-6 py-3 text-sm font-semibold text-blue-700 shadow-sm mb-8'
      >
        <svg class='h-4 w-4 text-blue-600' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
          ></path>
        </svg>
        Часто задаваемые вопросы
      </div>
      <h2
        class='faq__title text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 tracking-tight leading-tight'
      >
        Ответы на ваши вопросы
      </h2>
      <p
        class='faq__subtitle text-lg sm:text-xl md:text-2xl text-slate-600 max-w-4xl mx-auto leading-relaxed font-medium'
      >
        Разбираем самые популярные вопросы о банкротстве физических лиц
      </p>
    </header>

    <!-- FAQ Accordion Container -->
    <div class='faq__accordion max-w-4xl mx-auto' role='region' aria-label='Вопросы и ответы'>
      <!-- FAQ Item 1 -->
      <div
        class='faq__item group relative overflow-hidden rounded-2xl bg-white border border-gray-200 shadow-md shadow-slate-900/10 mb-4 sm:mb-6 transition-all duration-500 ease-out transform hover:scale-[1.02] hover:-translate-y-2 hover:bg-gray-50 hover:shadow-xl hover:shadow-slate-900/15 hover:border-gray-300 faq-item-wrapper'
        data-faq-item
      >
        <button
          class='faq__question w-full flex justify-between items-start sm:items-center p-6 md:p-8 text-left bg-transparent hover:bg-gray-50/60 transition-all duration-300 faq-question-button'
          aria-expanded='false'
          aria-controls='faq-answer-1'
          data-faq-trigger
        >
          <span
            class='faq__question-text text-base sm:text-lg md:text-xl font-semibold text-slate-900 group-hover:text-blue-700 transition-colors duration-300 leading-snug faq-question-text'
          >
            Какие долги можно списать через банкротство?
          </span>
          <svg
            class='faq__icon flex-shrink-0 w-6 h-6 text-blue-600 transition-all duration-300 group-hover:text-blue-700 group-hover:rotate-180 faq-question-icon'
            width='24'
            height='24'
            viewBox='0 0 24 24'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M6 9l6 6 6-6'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </button>
        <div class='faq__answer bg-white' id='faq-answer-1' aria-hidden='true' data-faq-content>
          <div class='faq__answer-inner px-6 md:px-8 pb-6 md:pb-8 pt-0'>
            <p class='mb-6 text-slate-700 text-base sm:text-lg leading-relaxed'>
              Через процедуру банкротства можно списать практически все виды долгов:
            </p>
            <ul class='faq__list space-y-3 mb-6'>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700 text-base sm:text-lg leading-relaxed'
                  >Кредиты в банках и МФО</span
                >
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'>Займы у физических и юридических лиц</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'>Долги по ЖКХ и коммунальным услугам</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'>Налоговые задолженности</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'>Долги по распискам и договорам</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'>Штрафы ГИБДД и административные штрафы</span>
              </li>
            </ul>
            <div
              class='faq__note bg-blue-50 border-l-4 border-blue-500 p-4 sm:p-6 text-base sm:text-lg leading-relaxed'
            >
              <strong class='text-slate-900'>Важно:</strong>
              <span class='text-slate-700'
                >Не списываются алименты, возмещение вреда жизни и здоровью, субсидиарная
                ответственность.</span
              >
            </div>
          </div>
        </div>
      </div>

      <!-- FAQ Item 2 -->
      <div
        class='faq__item group relative overflow-hidden rounded-2xl bg-white border border-gray-200 shadow-md shadow-slate-900/10 mb-4 sm:mb-6 transition-all duration-500 ease-out transform hover:scale-[1.02] hover:-translate-y-2 hover:bg-gray-50 hover:shadow-xl hover:shadow-slate-900/15 hover:border-gray-300 faq-item-wrapper'
        data-faq-item
      >
        <button
          class='faq__question w-full flex justify-between items-start sm:items-center p-6 md:p-8 text-left bg-transparent hover:bg-gray-50/60 transition-all duration-300 faq-question-button'
          aria-expanded='false'
          aria-controls='faq-answer-2'
          data-faq-trigger
        >
          <span
            class='faq__question-text text-base sm:text-lg md:text-xl font-semibold text-slate-900 group-hover:text-blue-700 transition-colors duration-300 leading-snug faq-question-text'
          >
            Сколько времени занимает процедура банкротства?
          </span>
          <svg
            class='faq__icon flex-shrink-0 w-6 h-6 text-blue-600 transition-all duration-300 group-hover:text-blue-700 group-hover:rotate-180 faq-question-icon'
            width='24'
            height='24'
            viewBox='0 0 24 24'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M6 9l6 6 6-6'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </button>
        <div class='faq__answer bg-white' id='faq-answer-2' aria-hidden='true' data-faq-content>
          <div class='faq__answer-inner px-6 md:px-8 pb-6 md:pb-8 pt-0'>
            <p class='mb-4 text-slate-700'>Сроки зависят от выбранной процедуры:</p>
            <div class='faq__timeline space-y-4 mb-4'>
              <div class='faq__timeline-item flex items-start gap-3'>
                <span class='faq__timeline-icon text-xl'>⚡</span>
                <div>
                  <strong class='text-slate-900'>Внесудебное банкротство</strong>
                  <p class='text-slate-600'>
                    {SITE_CONSTANTS.services.timeline.extrajudicial.display} через МФЦ
                  </p>
                </div>
              </div>
              <div class='faq__timeline-item flex items-start gap-3'>
                <span class='faq__timeline-icon text-xl'>⚖️</span>
                <div>
                  <strong class='text-slate-900'>Судебное банкротство</strong>
                  <p class='text-slate-600'>
                    {SITE_CONSTANTS.services.timeline.judicial.display} через Арбитражный суд
                  </p>
                </div>
              </div>
            </div>
            <p
              class='faq__highlight bg-yellow-50 border-l-4 border-yellow-500 p-4 font-medium text-slate-700'
            >
              💡 {SITE_CONSTANTS.services.timeline.average.note} процедура проходит за {
                SITE_CONSTANTS.services.timeline.average.display
              } благодаря профессиональной подготовке документов.
            </p>
          </div>
        </div>
      </div>

      <!-- FAQ Item 3 -->
      <div
        class='faq__item group relative overflow-hidden rounded-2xl bg-white border border-gray-200 shadow-md shadow-slate-900/10 mb-4 sm:mb-6 transition-all duration-500 ease-out transform hover:scale-[1.02] hover:-translate-y-2 hover:bg-gray-50 hover:shadow-xl hover:shadow-slate-900/15 hover:border-gray-300 faq-item-wrapper'
        data-faq-item
      >
        <button
          class='faq__question w-full flex justify-between items-start sm:items-center p-6 md:p-8 text-left bg-transparent hover:bg-gray-50/60 transition-all duration-300 faq-question-button'
          aria-expanded='false'
          aria-controls='faq-answer-3'
          data-faq-trigger
        >
          <span
            class='faq__question-text text-base sm:text-lg md:text-xl font-semibold text-slate-900 group-hover:text-blue-700 transition-colors duration-300 leading-snug faq-question-text'
          >
            Какое имущество можно сохранить при банкротстве?
          </span>
          <svg
            class='faq__icon flex-shrink-0 w-6 h-6 text-blue-600 transition-all duration-300 group-hover:text-blue-700 group-hover:rotate-180 faq-question-icon'
            width='24'
            height='24'
            viewBox='0 0 24 24'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M6 9l6 6 6-6'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </button>
        <div class='faq__answer bg-white' id='faq-answer-3' aria-hidden='true' data-faq-content>
          <div class='faq__answer-inner px-6 md:px-8 pb-6 md:pb-8 pt-0'>
            <p class='mb-4 text-slate-700'>По закону нельзя забрать:</p>
            <ul class='faq__list space-y-2 mb-4'>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'>Единственное жилье (если не в ипотеке)</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'>Земельный участок под единственным жильем</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'>Предметы обычной домашней обстановки</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'>Личные вещи и одежда</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'>Профессиональные инструменты до 100 МРОТ</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'
                  >Продукты питания и деньги до прожиточного минимума</span
                >
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                <span class='text-slate-700'>Награды, призы и государственные награды</span>
              </li>
            </ul>
            <div class='faq__action-box bg-blue-50 border border-blue-200 rounded-lg p-4'>
              <p class='font-semibold mb-3'>
                <strong class='text-slate-900'
                  >Наши юристы помогут максимально защитить ваше имущество!</strong
                >
              </p>
              <button
                class='faq__cta-button px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700'
                data-modal='consultation'
              >
                Получить консультацию
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- FAQ Item 4 -->
      <div
        class='faq__item group relative overflow-hidden rounded-2xl bg-white border border-gray-200 shadow-md shadow-slate-900/10 mb-4 sm:mb-6 transition-all duration-500 ease-out transform hover:scale-[1.02] hover:-translate-y-2 hover:bg-gray-50 hover:shadow-xl hover:shadow-slate-900/15 hover:border-gray-300 faq-item-wrapper'
        data-faq-item
      >
        <button
          class='faq__question w-full flex justify-between items-start sm:items-center p-6 md:p-8 text-left bg-transparent hover:bg-gray-50/60 transition-all duration-300 faq-question-button'
          aria-expanded='false'
          aria-controls='faq-answer-4'
          data-faq-trigger
        >
          <span
            class='faq__question-text text-base sm:text-lg md:text-xl font-semibold text-slate-900 group-hover:text-blue-700 transition-colors duration-300 leading-snug faq-question-text'
          >
            Какие последствия банкротства для должника?
          </span>
          <svg
            class='faq__icon flex-shrink-0 w-6 h-6 text-blue-600 transition-all duration-300 group-hover:text-blue-700 group-hover:rotate-180 faq-question-icon'
            width='24'
            height='24'
            viewBox='0 0 24 24'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M6 9l6 6 6-6'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </button>
        <div class='faq__answer bg-white' id='faq-answer-4' aria-hidden='true' data-faq-content>
          <div class='faq__answer-inner px-6 md:px-8 pb-6 md:pb-8 pt-0'>
            <p class='mb-4 text-slate-700'>После признания банкротом:</p>
            <div class='faq__consequences grid grid-cols-1 md:grid-cols-2 gap-6 mb-4'>
              <div
                class='faq__consequence faq__consequence--positive bg-green-50 border border-green-200 rounded-lg p-4'
              >
                <h4 class='font-bold text-green-800 mb-3'>✅ Положительные последствия:</h4>
                <ul class='space-y-2 text-slate-700'>
                  <li>Полное списание долгов</li>
                  <li>Прекращение начисления процентов и штрафов</li>
                  <li>Остановка исполнительных производств</li>
                  <li>Защита от коллекторов</li>
                </ul>
              </div>
              <div
                class='faq__consequence faq__consequence--temporary bg-yellow-50 border border-yellow-200 rounded-lg p-4'
              >
                <h4 class='font-bold text-yellow-800 mb-3'>⏰ Временные ограничения:</h4>
                <ul class='space-y-2 text-slate-700'>
                  <li>5 лет — запрет на повторное банкротство</li>
                  <li>5 лет — обязанность сообщать о банкротстве при взятии кредита</li>
                  <li>3 года — запрет занимать руководящие должности</li>
                  <li>10 лет — для банков и страховых компаний</li>
                </ul>
              </div>
            </div>
            <p class='faq__info bg-blue-50 border-l-4 border-blue-500 p-4 text-slate-700'>
              <strong class='text-slate-900'>📌 Важно:</strong> Эти ограничения не мешают обычной жизни,
              работе по найму и ведению малого бизнеса.
            </p>
          </div>
        </div>
      </div>

      <!-- FAQ Item 5 -->
      <div
        class='faq__item group relative overflow-hidden rounded-2xl bg-white border border-gray-200 shadow-md shadow-slate-900/10 mb-4 sm:mb-6 transition-all duration-500 ease-out transform hover:scale-[1.02] hover:-translate-y-2 hover:bg-gray-50 hover:shadow-xl hover:shadow-slate-900/15 hover:border-gray-300 faq-item-wrapper'
        data-faq-item
      >
        <button
          class='faq__question w-full flex justify-between items-start sm:items-center p-6 md:p-8 text-left bg-transparent hover:bg-gray-50/60 transition-all duration-300 faq-question-button'
          aria-expanded='false'
          aria-controls='faq-answer-5'
          data-faq-trigger
        >
          <span
            class='faq__question-text text-base sm:text-lg md:text-xl font-semibold text-slate-900 group-hover:text-blue-700 transition-colors duration-300 leading-snug faq-question-text'
          >
            Сколько стоит процедура банкротства?
          </span>
          <svg
            class='faq__icon flex-shrink-0 w-6 h-6 text-blue-600 transition-all duration-300 group-hover:text-blue-700 group-hover:rotate-180 faq-question-icon'
            width='24'
            height='24'
            viewBox='0 0 24 24'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M6 9l6 6 6-6'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </button>
        <div class='faq__answer bg-white' id='faq-answer-5' aria-hidden='true' data-faq-content>
          <div class='faq__answer-inner px-6 md:px-8 pb-6 md:pb-8 pt-0'>
            <div class='faq__pricing grid grid-cols-1 md:grid-cols-2 gap-6 mb-6'>
              <div class='faq__price-card bg-white border border-gray-200 rounded-lg p-6'>
                <h4 class='text-xl font-bold text-gray-900 mb-4'>Внесудебное банкротство</h4>
                <div class='faq__price text-2xl font-bold text-blue-600 mb-4'>
                  {SITE_CONSTANTS.services.pricing.extrajudicial.display}
                </div>
                <ul class='faq__price-includes space-y-2'>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                    <span class='text-slate-700'>Подготовка документов</span>
                  </li>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                    <span class='text-slate-700'>Подача заявления в МФЦ</span>
                  </li>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                    <span class='text-slate-700'>Сопровождение процедуры</span>
                  </li>
                </ul>
              </div>
              <div
                class='faq__price-card faq__price-card--popular bg-white border-2 border-blue-500 rounded-lg p-6 relative'
              >
                <span
                  class='faq__badge absolute -top-3 left-1/2 transform -translate-x-1/2 bg-blue-500 text-white text-xs font-bold px-3 py-1 rounded-full'
                  >Популярный выбор</span
                >
                <h4 class='text-xl font-bold text-gray-900 mb-4 pt-3'>Судебное банкротство</h4>
                <div class='faq__price text-2xl font-bold text-blue-600 mb-4'>
                  {SITE_CONSTANTS.services.pricing.judicial.display}
                </div>
                <ul class='faq__price-includes space-y-2'>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                    <span class='text-slate-700'>Полное юридическое сопровождение</span>
                  </li>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                    <span class='text-slate-700'>Работа с финансовым управляющим</span>
                  </li>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                    <span class='text-slate-700'>Представительство в суде</span>
                  </li>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                    <span class='text-slate-700'>Рассрочка до 24 месяцев</span>
                  </li>
                </ul>
              </div>
            </div>
            <div class='faq__payment-info bg-green-50 border-l-4 border-green-500 p-4'>
              <p class='font-bold mb-2 text-slate-900'>
                💳 <strong>Доступна рассрочка без процентов!</strong>
              </p>
              <p class='text-slate-700'>
                Первый платеж от {SITE_CONSTANTS.services.pricing.judicial.monthly} ₽. Остальное — после
                списания долгов.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- FAQ Item 6 -->
      <div
        class='faq__item group relative overflow-hidden rounded-2xl bg-white border border-gray-200 shadow-md shadow-slate-900/10 mb-4 sm:mb-6 transition-all duration-500 ease-out transform hover:scale-[1.02] hover:-translate-y-2 hover:bg-gray-50 hover:shadow-xl hover:shadow-slate-900/15 hover:border-gray-300 faq-item-wrapper'
        data-faq-item
      >
        <button
