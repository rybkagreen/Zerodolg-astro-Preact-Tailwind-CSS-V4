---
// Faq.astro
interface FaqQuestion {
  question: string;
  answer: string;
}

interface FaqGroup {
  title: string;
  questions: FaqQuestion[];
}

export interface Props {
  title?: string;
  data?: FaqGroup[];
  [key: string]: unknown;
}

// Import interactive logic
import FaqComponent from '../../islands/layout/faqEnhanced.tsx';
---

<!-- FAQ Section - Modern Accordion Style -->
<section
  class='section-padding bg-gray-50'
  id='faq'
  data-section='faq'
  data-aos='fade-up'
>
  <div class='container-custom'>
    <!-- Section Header - сохраняем текущий стиль заголовка -->
    <div class='faq__header text-center mb-12 md:mb-16'>
      <h2
        class='faq__title text-3xl md:text-4xl font-bold text-gray-900 mb-4 flex items-center justify-center gap-3'
      >
        <span class='faq__title-icon'>❓</span>
        Часто задаваемые вопросы
      </h2>
      <p class='faq__subtitle text-lg text-gray-600 max-w-3xl mx-auto'>
        Ответы на популярные вопросы о процедуре банкротства физических лиц
      </p>
    </div>

    <!-- FAQ Accordion Container -->
    <div class='faq__accordion' role='region' aria-label='Вопросы и ответы'>
      <!-- FAQ Item 1 -->
      <div class='faq__item card mb-4 overflow-hidden' data-faq-item>
        <button
          class='faq__question w-full flex justify-between items-center p-6 text-left bg-white hover:bg-gray-50 transition-colors duration-200'
          aria-expanded='false'
          aria-controls='faq-answer-1'
          data-faq-trigger
        >
          <span class='faq__question-text text-lg font-medium text-gray-900'>
            Какие долги можно списать через банкротство?
          </span>
          <svg
            class='faq__icon flex-shrink-0 w-6 h-6 text-gray-500 ml-4 transition-transform duration-200'
            width='24'
            height='24'
            viewBox='0 0 24 24'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M6 9l6 6 6-6'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </button>
        <div class='faq__answer bg-gray-50' id='faq-answer-1' aria-hidden='true' data-faq-content>
          <div class='faq__answer-inner p-6 pt-0'>
            <p class='mb-4'>
              Через процедуру банкротства можно списать практически все виды долгов:
            </p>
            <ul class='faq__list space-y-2 mb-4'>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span> Кредиты в банках и МФО
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span> Займы у физических и юридических
                лиц
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span> Долги по ЖКХ и коммунальным
                услугам
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span> Налоговые задолженности
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span> Долги по распискам и договорам
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span> Штрафы ГИБДД и административные
                штрафы
              </li>
            </ul>
            <div class='faq__note bg-blue-50 border-l-4 border-blue-500 p-4'>
              <strong>Важно:</strong> Не списываются алименты, возмещение вреда жизни и здоровью, субсидиарная
              ответственность.
            </div>
          </div>
        </div>
      </div>

      <!-- FAQ Item 2 -->
      <div class='faq__item card mb-4 overflow-hidden' data-faq-item>
        <button
          class='faq__question w-full flex justify-between items-center p-6 text-left bg-white hover:bg-gray-50 transition-colors'
          aria-expanded='false'
          aria-controls='faq-answer-2'
          data-faq-trigger
        >
          <span class='faq__question-text text-lg font-medium text-gray-900'>
            Сколько времени занимает процедура банкротства?
          </span>
          <svg
            class='faq__icon flex-shrink-0 w-6 h-6 text-gray-500 ml-4 transition-transform duration-200'
            width='24'
            height='24'
            viewBox='0 0 24 24'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M6 9l6 6 6-6'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </button>
        <div class='faq__answer bg-gray-50' id='faq-answer-2' aria-hidden='true' data-faq-content>
          <div class='faq__answer-inner p-6 pt-0'>
            <p class='mb-4'>Сроки зависят от выбранной процедуры:</p>
            <div class='faq__timeline space-y-4 mb-4'>
              <div class='faq__timeline-item flex items-start gap-3'>
                <span class='faq__timeline-icon text-xl'>⚡</span>
                <div>
                  <strong>Внесудебное банкротство</strong>
                  <p class='text-gray-600'>От 3 до 6 месяцев через МФЦ</p>
                </div>
              </div>
              <div class='faq__timeline-item flex items-start gap-3'>
                <span class='faq__timeline-icon text-xl'>⚖️</span>
                <div>
                  <strong>Судебное банкротство</strong>
                  <p class='text-gray-600'>От 6 до 12 месяцев через Арбитражный суд</p>
                </div>
              </div>
            </div>
            <p class='faq__highlight bg-yellow-50 border-l-4 border-yellow-500 p-4 font-medium'>
              💡 С нашей помощью процедура проходит максимально быстро благодаря профессиональной
              подготовке документов.
            </p>
          </div>
        </div>
      </div>

      <!-- FAQ Item 3 -->
      <div class='faq__item card mb-4 overflow-hidden' data-faq-item>
        <button
          class='faq__question w-full flex justify-between items-center p-6 text-left bg-white hover:bg-gray-50 transition-colors'
          aria-expanded='false'
          aria-controls='faq-answer-3'
          data-faq-trigger
        >
          <span class='faq__question-text text-lg font-medium text-gray-900'>
            Какое имущество можно сохранить при банкротстве?
          </span>
          <svg
            class='faq__icon flex-shrink-0 w-6 h-6 text-gray-500 ml-4 transition-transform duration-200'
            width='24'
            height='24'
            viewBox='0 0 24 24'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M6 9l6 6 6-6'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </button>
        <div class='faq__answer bg-gray-50' id='faq-answer-3' aria-hidden='true' data-faq-content>
          <div class='faq__answer-inner p-6 pt-0'>
            <p class='mb-4'>По закону нельзя забрать:</p>
            <ul class='faq__list space-y-2 mb-4'>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span> Единственное жилье (если не
                в ипотеке)
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span>
                <span>Земельный участок под единственным жильем</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span> Предметы обычной домашней обстановки
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span> Личные вещи и одежда
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span>
                <span>Профессиональные инструменты до 100 МРОТ</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span>
                <span>Продукты питания и деньги до прожиточного минимума</span>
              </li>
              <li class='flex items-start'>
                <span class='faq__checkmark text-green-500 mr-2'>✓</span>
                <span>Награды, призы и государственные награды</span>
              </li>
            </ul>
            <div class='faq__action-box bg-blue-50 border border-blue-200 rounded-lg p-4'>
              <p class='font-semibold mb-3'>
                <strong>Наши юристы помогут максимально защитить ваше имущество!</strong>
              </p>
              <button
                class='faq__cta-button px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700'
                data-modal='consultation'
              >
                Получить консультацию
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- FAQ Item 4 -->
      <div class='faq__item card mb-4 overflow-hidden' data-faq-item>
        <button
          class='faq__question w-full flex justify-between items-center p-6 text-left bg-white hover:bg-gray-50 transition-colors'
          aria-expanded='false'
          aria-controls='faq-answer-4'
          data-faq-trigger
        >
          <span class='faq__question-text text-lg font-medium text-gray-900'>
            Какие последствия банкротства для должника?
          </span>
          <svg
            class='faq__icon flex-shrink-0 w-6 h-6 text-gray-500 ml-4 transition-transform duration-200'
            width='24'
            height='24'
            viewBox='0 0 24 24'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M6 9l6 6 6-6'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </button>
        <div class='faq__answer bg-gray-50' id='faq-answer-4' aria-hidden='true' data-faq-content>
          <div class='faq__answer-inner p-6 pt-0'>
            <p class='mb-4'>После признания банкротом:</p>
            <div class='faq__consequences grid grid-cols-1 md:grid-cols-2 gap-6 mb-4'>
              <div
                class='faq__consequence faq__consequence--positive bg-green-50 border border-green-200 rounded-lg p-4'
              >
                <h4 class='font-bold text-green-800 mb-3'>✅ Положительные последствия:</h4>
                <ul class='space-y-2'>
                  <li>Полное списание долгов</li>
                  <li>Прекращение начисления процентов и штрафов</li>
                  <li>Остановка исполнительных производств</li>
                  <li>Защита от коллекторов</li>
                </ul>
              </div>
              <div
                class='faq__consequence faq__consequence--temporary bg-yellow-50 border border-yellow-200 rounded-lg p-4'
              >
                <h4 class='font-bold text-yellow-800 mb-3'>⏰ Временные ограничения:</h4>
                <ul class='space-y-2'>
                  <li>5 лет — запрет на повторное банкротство</li>
                  <li>5 лет — обязанность сообщать о банкротстве при взятии кредита</li>
                  <li>3 года — запрет занимать руководящие должности</li>
                  <li>10 лет — для банков и страховых компаний</li>
                </ul>
              </div>
            </div>
            <p class='faq__info bg-blue-50 border-l-4 border-blue-500 p-4'>
              <strong>📌 Важно:</strong> Эти ограничения не мешают обычной жизни, работе по найму и ведению
              малого бизнеса.
            </p>
          </div>
        </div>
      </div>

      <!-- FAQ Item 5 -->
      <div class='faq__item card mb-4 overflow-hidden' data-faq-item>
        <button
          class='faq__question w-full flex justify-between items-center p-6 text-left bg-white hover:bg-gray-50 transition-colors'
          aria-expanded='false'
          aria-controls='faq-answer-5'
          data-faq-trigger
        >
          <span class='faq__question-text text-lg font-medium text-gray-900'>
            Сколько стоит процедура банкротства?
          </span>
          <svg
            class='faq__icon flex-shrink-0 w-6 h-6 text-gray-500 ml-4 transition-transform duration-200'
            width='24'
            height='24'
            viewBox='0 0 24 24'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M6 9l6 6 6-6'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </button>
        <div class='faq__answer bg-gray-50' id='faq-answer-5' aria-hidden='true' data-faq-content>
          <div class='faq__answer-inner p-6 pt-0'>
            <div class='faq__pricing grid grid-cols-1 md:grid-cols-2 gap-6 mb-6'>
              <div class='faq__price-card bg-white border border-gray-200 rounded-lg p-6'>
                <h4 class='text-xl font-bold text-gray-900 mb-4'>Внесудебное банкротство</h4>
                <div class='faq__price text-2xl font-bold text-blue-600 mb-4'>от 10 000 ₽</div>
                <ul class='faq__price-includes space-y-2'>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-2'>✓</span> Подготовка документов
                  </li>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-2'>✓</span> Подача заявления в МФЦ
                  </li>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-2'>✓</span> Сопровождение процедуры
                  </li>
                </ul>
              </div>
              <div
                class='faq__price-card faq__price-card--popular bg-white border-2 border-blue-500 rounded-lg p-6 relative'
              >
                <span
                  class='faq__badge absolute -top-3 left-1/2 transform -translate-x-1/2 bg-blue-500 text-white text-xs font-bold px-3 py-1 rounded-full'
                  >Популярный выбор</span
                >
                <h4 class='text-xl font-bold text-gray-900 mb-4 pt-3'>Судебное банкротство</h4>
                <div class='faq__price text-2xl font-bold text-blue-600 mb-4'>от 5 900 ₽/мес</div>
                <ul class='faq__price-includes space-y-2'>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-2'>✓</span> Полное юридическое сопровождение
                  </li>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-2'>✓</span> Работа с финансовым управляющим
                  </li>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-2'>✓</span> Представительство в суде
                  </li>
                  <li class='flex items-start'>
                    <span class='text-green-500 mr-2'>✓</span> Рассрочка до 24 месяцев
                  </li>
                </ul>
              </div>
            </div>
            <div class='faq__payment-info bg-green-50 border-l-4 border-green-500 p-4'>
              <p class='font-bold mb-2'>💳 <strong>Доступна рассрочка без процентов!</strong></p>
              <p>Первый платеж от 5 900 ₽. Остальное — после списания долгов.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- FAQ Item 6 -->
      <div class='faq__item card mb-4 overflow-hidden' data-faq-item>
        <button
          class='faq__question w-full flex justify-between items-center p-6 text-left bg-white hover:bg-gray-50 transition-colors'
          aria-expanded='false'
          aria-controls='faq-answer-6'
          data-faq-trigger
        >
          <span class='faq__question-text text-lg font-medium text-gray-900'>
            Можно ли пройти банкротство без юриста?
          </span>
          <svg
            class='faq__icon flex-shrink-0 w-6 h-6 text-gray-500 ml-4 transition-transform duration-200'
            width='24'
            height='24'
            viewBox='0 0 24 24'
            fill='none'
            aria-hidden='true'
          >
            <path
              d='M6 9l6 6 6-6'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
        </button>
        <div class='faq__answer bg-gray-50' id='faq-answer-6' aria-hidden='true' data-faq-content>
          <div class='faq__answer-inner p-6 pt-0'>
            <p class='mb-4'>Теоретически — да, но на практике это очень сложно и рискованно:</p>
            <div class='faq__comparison grid grid-cols-1 md:grid-cols-2 gap-6 mb-4'>
              <div
                class='faq__compare-item faq__compare-item--negative bg-red-50 border border-red-200 rounded-lg p-4'
              >
                <h4 class='font-bold text-red-800 mb-3'>❌ Без юриста:</h4>
                <ul class='space-y-2'>
                  <li>Высокий риск отказа в списании долгов</li>
                  <li>Ошибки в документах</li>
                  <li>Потеря имущества из-за незнания законов</li>
                  <li>Затягивание процедуры</li>
                  <li>Дополнительные расходы на исправление ошибок</li>
                </ul>
              </div>
              <div
                class='faq__compare-item faq__compare-item--positive bg-green-50 border border-green-200 rounded-lg p-4'
              >
                <h4 class='font-bold text-green-800 mb-3'>✅ С нашей помощью:</h4>
                <ul class='space-y-2'>
                  <li>Гарантия результата по договору</li>
                  <li>Защита имущества</li>
                  <li>Минимальные сроки процедуры</li>
                  <li>Полное сопровождение</li>
                  <li>Более 500 успешных дел</li>
                </ul>
              </div>
            </div>
            <div
              class='faq__guarantee bg-blue-50 border border-blue-200 rounded-lg p-4 text-center'
            >
              <p class='font-bold text-blue-800'>
                🛡️ <strong>Мы гарантируем результат или вернем деньги!</strong>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class='faq__cta text-center mt-12 md:mt-16'>
      <h3 class='text-2xl md:text-3xl font-bold text-gray-900 mb-4'>Остались вопросы?</h3>
      <p class='text-lg text-gray-600 mb-6'>
        Получите бесплатную консультацию нашего юриста по банкротству
      </p>
      <div class='faq__cta-buttons flex flex-col sm:flex-row gap-4 justify-center'>
        <button
          class='btn-primary inline-flex items-center'
          data-modal='consultation'
        >
          <span>Задать вопрос юристу</span>
        </button>
        <a
          href='tel:+79055773387'
          class='btn-secondary inline-flex items-center gap-2'
        >
          <svg width='20' height='20' viewBox='0 0 24 24' fill='none' aria-hidden='true'>
            <path
              d='M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'></path>
          </svg>
          <span>+7 (905) 577-33-87</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- FAQ interactivity is handled by Faq Preact component -->
<FaqComponent client:load />
