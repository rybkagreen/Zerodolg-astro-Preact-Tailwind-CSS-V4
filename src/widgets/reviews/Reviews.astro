// Calculate statistics
const calculateStats = (reviews: DetailedReview[]): ReviewStats => {
  const distribution: Record<number, number> = { 5: 0, 4: 0, 3: 0, 2: 0, 1: 0 };
  let totalRating = 0;

  reviews.forEach((review) => {
    distribution[review.rating]++;
    totalRating += review.rating;
  });

  return {
    total: reviews.length,
    average: reviews.length > 0 ? totalRating / reviews.length : 0,
    distribution,
  };
};

const stats = calculateStats(reviews);

// Format date for display
const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return new Intl.DateTimeFormat('ru-RU', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
};

// Get initials from name - used in script section
const getInitials = (name: string) => {
  return name
    .split(' ')
    .map((word) => word[0])
    .join('')
    .toUpperCase();
};

// Declare global interface for window extensions
declare global {
  interface Window {
    getInitials: (name: string) => string;
    formatDate: (dateStr: string) => string;
    reviews: DetailedReview[];
    reviewsIncrement: number;
    visibleReviews: number;
  }
}

// Make functions available globally for script usage
if (typeof window !== 'undefined') {
  window.getInitials = getInitials;
  window.formatDate = formatDate;
  window.reviews = reviews;
  window.reviewsIncrement = reviewsIncrement;
  window.visibleReviews = visibleReviews;
}

// State for reviews display
let visibleReviews = 3;
const reviewsIncrement = 3;
---

<section class='section-padding bg-blue-600 text-white' id='reviews' data-aos='fade-up'>
