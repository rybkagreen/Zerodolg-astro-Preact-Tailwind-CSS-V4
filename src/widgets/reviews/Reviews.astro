---
// Import new components and data
import ReviewsEnhanced from '../../islands/sections/ReviewsEnhanced.tsx';
import { reviews, reviewsStats } from '../../shared/data/reviews-data';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Calculate rating distribution for stats display
const calculateDistribution = () => {
  const distribution: Record<number, number> = { 5: 0, 4: 0, 3: 0, 2: 0, 1: 0 };
  reviews.forEach((review) => {
    distribution[review.rating]++;
  });
  return distribution;
};

const ratingDistribution = calculateDistribution();
---

<section
  class:list={`reviews-section relative py-20 md:py-28 lg:py-36 overflow-hidden ${className}`}
  id='reviews'
  aria-labelledby='reviews-title'
  itemscope
  itemtype='https://schema.org/AggregateRating'
>
  <!-- Animated Gradient Background - Similar to Calculator -->
  <div
    class='absolute inset-0 bg-gradient-to-r from-slate-900 via-blue-900 to-indigo-900'
    style='background-size: 400% 400%; animation: gradient-rotate 20s ease infinite;'
  >
  </div>

  <!-- Dark overlay for contrast and depth -->
  <div class='absolute inset-0 bg-gradient-to-br from-transparent via-black/20 to-black/40'></div>

  <!-- Animated mesh pattern overlay -->
  <div
    class='absolute inset-0 opacity-30'
    style='background-image: radial-gradient(circle at 30% 70%, rgba(245, 158, 11, 0.15) 0%, transparent 50%), radial-gradient(circle at 70% 30%, rgba(37, 99, 235, 0.15) 0%, transparent 50%), radial-gradient(circle at 50% 50%, rgba(255, 215, 0, 0.1) 0%, transparent 50%); animation: mesh-float 30s ease-in-out infinite;'
  >
  </div>

  <div class='relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
    <!-- Section Header -->
    <header class='text-center mb-16 md:mb-20 lg:mb-24'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-white/20 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-white ring-1 ring-white/30 mb-8'
        role='text'
        aria-label='Реальные отзывы клиентов'
        style='animation: fadeInUp 0.6s ease-out;'
      >
        <svg
          class='h-4 w-4 text-white'
          fill='none'
          viewBox='0 0 24 24'
          stroke='currentColor'
          aria-hidden='true'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z'
          ></path>
        </svg>
        <span itemscope itemtype='https://schema.org/Review'>
          <meta itemprop='name' content='Отзывы клиентов' />
          <meta itemprop='reviewRating' itemscope itemtype='https://schema.org/Rating' />
          <meta itemprop='ratingValue' content='4.9' />
          Реальные истории
        </span>
      </div>
      <h2
        id='reviews-title'
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight leading-tight drop-shadow-lg'
        style='text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);'
      >
        Отзывы наших клиентов
      </h2>
      <p
        class='text-xl md:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed font-medium drop-shadow-sm'
      >
        Более 1200+ довольных клиентов, которые полностью освободились от долгов
      </p>
    </header>

    <!-- Glass Morphism Stats Container -->
    <div
      class='bg-white/10 backdrop-blur-lg rounded-3xl p-6 md:p-8 mb-12 border border-white/20 shadow-2xl'
      style='box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.5);'
    >
      <!-- Top accent line -->
      <div
        class='h-1 w-full bg-gradient-to-r from-orange-400 via-yellow-500 to-red-500 rounded-t-3xl mx-0 -mt-6 md:-mt-8 mb-8'
        style='animation: shimmer 3s ease-in-out infinite;'
      >
      </div>
      <div class='flex flex-col md:flex-row items-center justify-between gap-8'>
        <div class='text-center'>
          <meta itemprop='ratingValue' content={reviewsStats.averageRating.toFixed(1)} />
          <meta itemprop='reviewCount' content={reviewsStats.total.toString()} />
          <meta itemprop='bestRating' content='5' />
          <span class='text-5xl md:text-6xl font-bold text-white drop-shadow-lg'>
            {reviewsStats.averageRating.toFixed(1)}
          </span>
          <div class='flex justify-center gap-1 my-2'>
            {
              Array.from({ length: 5 }).map((_, i) => (
                <span
                  class:list={[
                    `text-2xl drop-shadow-sm`,
                    {
                      'text-yellow-400': i < Math.floor(reviewsStats.averageRating),
                      'text-white/40': !(i < Math.floor(reviewsStats.averageRating)),
                    },
                  ]}
                  aria-label={
                    i < Math.floor(reviewsStats.averageRating) ? 'Полная звезда' : 'Пустая звезда'
                  }
                >
                  ★
                </span>
              ))
            }
          </div>
          <span class='text-white/70 font-medium drop-shadow-sm'
            >На основе {reviewsStats.total} отзывов</span
          >
        </div>
        <div class='w-full md:w-2/3'>
          {
            Object.entries(ratingDistribution)
              .sort(([a], [b]) => parseInt(b) - parseInt(a))
              .map(([rating, count]) => {
                const percentage = (count / reviewsStats.total) * 100;
                return (
                  <div class='flex items-center gap-3 mb-3 last:mb-0' key={rating}>
                    <span class='w-8 text-right text-white/80 font-medium drop-shadow-sm'>
                      {rating}★
                    </span>
                    <div class='flex-1 h-3 bg-white/20 rounded-full overflow-hidden backdrop-blur-sm'>
                      <div
                        class='h-full bg-gradient-to-r from-orange-400 to-yellow-500 rounded-full shadow-inner'
                        style={`width: ${percentage}%; animation: progressFill 2s ease-out;`}
                      />
                    </div>
                    <span class='w-12 text-right text-white/70 font-medium drop-shadow-sm'>
                      {Math.round(percentage)}%
                    </span>
                  </div>
                );
              })
          }
        </div>
      </div>
    </div>

    <!-- Interactive Reviews Component -->
    <ReviewsEnhanced client:visible reviews={reviews} initialVisible={3} loadMoreCount={3} />
  </div>
</section>

<!-- CSS Animations for Reviews Section -->
<style>
  /* Rotating gradient animation similar to calculator */
  @keyframes gradient-rotate {
    0% {
      background-position: 0% 50%;
      filter: hue-rotate(0deg);
    }
    25% {
      background-position: 50% 100%;
    }
    50% {
      background-position: 100% 50%;
      filter: hue-rotate(10deg);
    }
    75% {
      background-position: 50% 0%;
    }
    100% {
      background-position: 0% 50%;
      filter: hue-rotate(0deg);
    }
  }

  /* Floating mesh animation */
  @keyframes mesh-float {
    0%,
    100% {
      transform: translate(0, 0) rotate(0deg);
    }
    33% {
      transform: translate(-30px, 30px) rotate(120deg);
    }
    66% {
      transform: translate(20px, -20px) rotate(240deg);
    }
  }

  /* Shimmer animation for accent line */
  @keyframes shimmer {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }

  /* Progress fill animation */
  @keyframes progressFill {
    from {
      width: 0%;
    }
    to {
      width: var(--target-width);
    }
  }

  /* Card entrance animation - applied in component */
  @keyframes cardSlideIn {
    from {
      opacity: 0;
      transform: translateY(30px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    * {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
