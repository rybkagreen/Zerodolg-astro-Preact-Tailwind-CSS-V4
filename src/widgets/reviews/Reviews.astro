  <div class='relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
    <div class='text-center mb-16 md:mb-20 lg:mb-24'>
      <h2
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight leading-tight drop-shadow-lg'
        style='text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);'
      >
        Отзывы наших клиентов
      </h2>
      <p
        class='text-xl md:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed font-medium drop-shadow-sm'
      >
        Более 847+ довольных клиентов, которые полностью освободились от долгов
      </p>
    </div>

    <!-- Glass Morphism Stats Container -->
    <div
      class='bg-white/10 backdrop-blur-lg rounded-3xl p-6 md:p-8 mb-12 border border-white/20 shadow-2xl'
      style='box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.5);'
    >
      <!-- Top accent line -->
      <div
        class='h-1 w-full bg-gradient-to-r from-orange-400 via-yellow-500 to-red-500 rounded-t-3xl -mx-6 md:-mx-8 -mt-6 md:-mt-8 mb-8'
        style='animation: shimmer 3s ease-in-out infinite;'
      >
      </div>

      <div class='flex flex-col md:flex-row items-center justify-between gap-8'>
        <div class='text-center'>
          <span class='text-5xl md:text-6xl font-bold text-white drop-shadow-lg'
            >{stats.average.toFixed(1)}</span
          >
          <div class='flex justify-center gap-1 my-2'>
            {
              Array.from({ length: 5 }).map((_, i) => (
                <span
                  class:list={[
                    `text-2xl drop-shadow-sm`,
                    {
                      'text-yellow-400': i < Math.floor(stats.average),
                      'text-white/40': !(i < Math.floor(stats.average)),
                    },
                  ]}
                >
                  ★
                </span>
              ))
            }
          </div>
          <span class='text-white/70 font-medium drop-shadow-sm'
            >На основе {stats.total * 230} отзывов</span
          >
        </div>
        <div class='w-full md:w-2/3'>
          {
            Object.entries(stats.distribution)
              .sort(([a], [b]) => parseInt(b) - parseInt(a))
              .map(([rating, count]) => {
                const percentage = (count / stats.total) * 100;
                return (
                  <div class='flex items-center gap-3 mb-3 last:mb-0' key={rating}>
                    <span class='w-8 text-right text-white/80 font-medium drop-shadow-sm'>
                      {rating}★
                    </span>
                    <div class='flex-1 h-3 bg-white/20 rounded-full overflow-hidden backdrop-blur-sm'>
                      <div
                        class='h-full bg-gradient-to-r from-orange-400 to-yellow-500 rounded-full shadow-inner'
                        style={`width: ${percentage}%; animation: progressFill 2s ease-out;`}
                      />
                    </div>
                    <span class='w-12 text-right text-white/70 font-medium drop-shadow-sm'>
                      {Math.round(percentage)}%
                    </span>
                  </div>
                );
              })
          }
        </div>
      </div>
    </div>

    <!-- Чистый компонент отзывов -->
    <ReviewsCardsClean client:load reviews={reviews} initialVisible={visibleReviews} />
  </div>
</section>

<!-- CSS Animations for Reviews Section -->
<style>
  /* Rotating gradient animation similar to calculator */
  @keyframes gradient-rotate {
    0% {
      background-position: 0% 50%;
      filter: hue-rotate(0deg);
    }
    25% {
      background-position: 50% 100%;
    }
    50% {
      background-position: 100% 50%;
      filter: hue-rotate(10deg);
    }
    75% {
      background-position: 50% 0%;
    }
    100% {
      background-position: 0% 50%;
      filter: hue-rotate(0deg);
    }
  }

  /* Shimmer animation for accent line */
  @keyframes shimmer {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }

  /* Progress fill animation */
  @keyframes progressFill {
    from {
      width: 0%;
    }
    to {
      width: var(--target-width);
    }
  }

  /* Card entrance animation - applied in component */
  @keyframes cardSlideIn {
    from {
      opacity: 0;
      transform: translateY(30px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    * {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
