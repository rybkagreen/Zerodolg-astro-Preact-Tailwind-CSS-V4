                <span
                  class:list={[
                    `text-2xl `,
                    {
                      'text-yellow-400': i < Math.floor(stats.average),
                      'text-gray-400': !(i < Math.floor(stats.average)),
                    },
                  ]}
                >
                  ★
                </span>
              ))
            }
          </div>
          <span class='text-blue-200'>На основе {stats.total * 230} отзывов</span>
        </div>
        <div class='w-full md:w-2/3'>
          {
            Object.entries(stats.distribution)
              .sort(([a], [b]) => parseInt(b) - parseInt(a))
              .map(([rating, count]) => {
                const percentage = (count / stats.total) * 100;
                return (
                  <div class='flex items-center gap-3 mb-2 last:mb-0' key={rating}>
                    <span class='w-8 text-right text-blue-200'>{rating}★</span>
                    <div class='flex-1 h-2 bg-blue-800 rounded-full overflow-hidden'>
                      <div
                        class='h-full bg-yellow-400 rounded-full'
                        style={`width: ${percentage}%`}
                      />
                    </div>
                    <span class='w-12 text-right text-blue-200'>{Math.round(percentage)}%</span>
                  </div>
                );
              })
          }
        </div>
      </div>
    </div>

    <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6'>
      {
        reviews.slice(0, visibleReviews).map((review, index) => (
          <article
            class='card bg-white/10 backdrop-blur-sm border-white/20 hover:border-white/30 text-white'
            data-index={index}
            key={review.id}
          >
            <div class='mb-4'>
              <div class='flex items-start gap-3'>
                <div class='w-12 h-12 rounded-full bg-blue-700 flex items-center justify-center text-white font-bold'>
                  {review.author.charAt(0)}
                </div>
                <div>
                  <h3 class='text-lg font-bold text-white mb-1'>{review.author || review.name}</h3>
                  <time class='text-sm text-blue-200 block'>{formatDate(review.date)}</time>
                </div>
                {review.verified && (
                  <div class='ml-auto'>
                    <span class='inline-flex items-center gap-1 px-2 py-1 bg-green-500/20 text-green-300 text-xs rounded-full'>
                      <svg width='16' height='16' viewBox='0 0 24 24' fill='none'>
                        <path
                          d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'
                          stroke='currentColor'
                          stroke-width='2'
                          stroke-linecap='round'
                          stroke-linejoin='round'
                        />
                      </svg>
                      Проверено
                    </span>
                  </div>
                )}
              </div>
            </div>
            <div class='review-card__rating flex gap-1 mb-3'>
              {Array.from({ length: 5 }).map((_, i) => (
                <span
                  class:list={[
                    `review-card__star text-lg `,
                    {
                      'review-card__star--filled text-yellow-400': i < review.rating,
                      'text-gray-400': !(i < review.rating),
                    },
                  ]}
                >
                  ★
                </span>
              ))}
            </div>
            <p class='review-card__text text-blue-100 mb-4'>{review.text}</p>
            {review.tags && review.tags.length > 0 && (
              <div class='review-card__tags flex flex-wrap gap-2 mb-4'>
                {review.tags.map((tag) => (
                  <span class='review-card__tag px-2 py-1 bg-blue-700/50 text-blue-200 text-xs rounded-full'>
                    {tag}
                  </span>
                ))}
              </div>
            )}
            <div class='review-card__footer flex justify-between items-center'>
              <button
                class='review-card__helpful inline-flex items-center gap-1 text-blue-200 hover:text-white transition-colors'
