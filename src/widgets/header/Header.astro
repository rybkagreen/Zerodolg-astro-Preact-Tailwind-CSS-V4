---
import HeaderComponent from '../../islands/layout/headerEnhanced.tsx';

export interface Props {
  currentPage?: string;
}

const { currentPage } = Astro.props;
const isRestructuringPage =
  currentPage === 'restrukturizaciya-dolgov' ||
  Astro.url.pathname.includes('restrukturizaciya-dolgov');
const isBlogPage = currentPage === 'blog' || Astro.url.pathname.includes('/blog');

// Данные компании (можно вынести в отдельный конфиг)
const company = {
  name: 'ZeroDolg',
  phone: '+7 (905) 577-33-87',
  workHours: 'Ежедневно: 9:00-21:00',
  social: {
    whatsapp: 'https://wa.me/79055773387',
    telegram: 'https://t.me/zerodolg',
    vk: 'https://vk.com/zerodolg',
  },
};

// Навигационные элементы
const navItems = {
  services: [
    {
      href: isBlogPage
        ? '/#solution-choice'
        : isRestructuringPage
          ? '/restrukturizaciya-dolgov.html#solution-choice'
          : '/#solution-choice',
      icon: '🎆',
      title: 'Выбор решения',
      desc: 'Банкротство или реструктуризация',
    },
    // Show appropriate link based on current page
    isRestructuringPage
      ? {
          href: '/',
          icon: '🏠',
          title: 'Банкротство физических лиц',
          desc: 'Полное списание долгов',
        }
      : {
          href: '/restrukturizaciya-dolgov.html',
          icon: '🏠',
          title: 'Реструктуризация долгов',
          desc: 'Сохраните имущество, снизьте платежи',
        },
    {
      href: isBlogPage
        ? '/#problems'
        : isRestructuringPage
          ? '/restrukturizaciya-dolgov.html#problems'
          : '/#problems',
      icon: '⚡',
      title: 'Решаемые проблемы',
      desc: 'Какие долговые проблемы мы решаем',
    },
    {
      href: isBlogPage
        ? '/#calculator'
        : isRestructuringPage
          ? '/restrukturizaciya-dolgov.html#calculator'
          : '/#calculator',
      icon: '💰',
      title: 'Калькулятор стоимости',
      desc: 'Рассчитайте стоимость услуг',
      highlight: true,
    },
  ],
  about: [
    {
      href: isBlogPage
        ? '/#benefits'
        : isRestructuringPage
          ? '/restrukturizaciya-dolgov.html#benefits'
          : '/#benefits',
      icon: '🏆',
      title: 'Наши преимущества',
      desc: 'Почему выбирают нас',
    },
    {
      href: isBlogPage
        ? '/#team'
        : isRestructuringPage
          ? '/restrukturizaciya-dolgov.html#team'
          : '/#team',
      icon: '👥',
      title: 'Команда',
      desc: 'Наши юристы и специалисты',
    },
    {
      href: isBlogPage
        ? '/#reviews'
        : isRestructuringPage
          ? '/restrukturizaciya-dolgov.html#reviews'
          : '/#reviews',
      icon: '⭐',
      title: 'Отзывы клиентов',
      desc: 'Истории успеха',
    },
  ],
  info: [
    {
      href: isBlogPage
        ? '/#faq'
        : isRestructuringPage
          ? '/restrukturizaciya-dolgov.html#faq'
          : '/#faq',
      icon: '❓',
      title: 'Частые вопросы',
      desc: 'Ответы на популярные вопросы',
    },
    { href: '/blog/', icon: '📚', title: 'Блог', desc: 'Полезные статьи и новости' },
    {
      href: isBlogPage
        ? '/#contact'
        : isRestructuringPage
          ? '/restrukturizaciya-dolgov.html#contact'
          : '/#contact',
      icon: '📍',
      title: 'Контакты',
      desc: 'Как с нами связаться',
    },
    {
      href: '/privacy',
      icon: '🔒',
      title: 'Конфиденциальность',
      desc: 'Политика обработки данных',
    },
    { href: '/terms', icon: '📋', title: 'Соглашение', desc: 'Условия использования сайта' },
  ],
};

const mobileMenuItems = [
  {
    href: isBlogPage
      ? '/#solution-choice'
      : isRestructuringPage
        ? '/restrukturizaciya-dolgov.html#solution-choice'
        : '/#solution-choice',
    title: '🎆 Выбор решения',
    className: 'text-purple-600 hover:bg-purple-50 font-medium',
  },
  // Show appropriate link based on current page
  isRestructuringPage
    ? {
        href: '/',
        title: '🏠 Банкротство',
        className: 'text-emerald-600 hover:bg-emerald-50 font-medium',
      }
    : {
        href: '/restrukturizaciya-dolgov.html',
        title: '🏠 Реструктуризация',
        className: 'text-emerald-600 hover:bg-emerald-50 font-medium',
      },
  {
    href: isBlogPage
      ? '/#problems'
      : isRestructuringPage
        ? '/restrukturizaciya-dolgov.html#problems'
        : '/#problems',
    title: 'Проблемы',
  },
  {
    href: isBlogPage
      ? '/#process'
      : isRestructuringPage
        ? '/restrukturizaciya-dolgov.html#process'
        : '/#process',
    title: 'Процесс',
  },
  {
    href: isBlogPage
      ? '/#calculator'
      : isRestructuringPage
        ? '/restrukturizaciya-dolgov.html#calculator'
        : '/#calculator',
    title: 'Калькулятор',
  },
  {
    href: isBlogPage
      ? '/#benefits'
      : isRestructuringPage
        ? '/restrukturizaciya-dolgov.html#benefits'
        : '/#benefits',
    title: 'Преимущества',
  },
  {
    href: isBlogPage
      ? '/#reviews'
      : isRestructuringPage
        ? '/restrukturizaciya-dolgov.html#reviews'
        : '/#reviews',
    title: 'Отзывы',
  },
  {
    href: isBlogPage
      ? '/#team'
      : isRestructuringPage
        ? '/restrukturizaciya-dolgov.html#team'
        : '/#team',
    title: 'Команда',
  },
  {
    href: isBlogPage
      ? '/#faq'
      : isRestructuringPage
        ? '/restrukturizaciya-dolgov.html#faq'
        : '/#faq',
    title: 'FAQ',
  },
  { href: '/blog/', title: '📚 Блог', className: 'text-blue-600 hover:bg-blue-50 font-medium' },
  { href: '/#contacts', title: 'Контакты' },
  { href: '/privacy', title: 'Конфиденциальность' },
  { href: '/terms', title: 'Соглашение' },
];
---

<!-- Advanced Interactive Navigation -->
<header class='bg-white shadow-md sticky top-0' style='z-index: 10001;' id='main-header'>
  <nav
    class='w-full max-w-7xl mx-auto px-3 sm:px-4 lg:px-8'
    role='navigation'
    aria-label='Главная навигация'
  >
    <div class='flex items-center justify-between h-16 gap-2 sm:gap-4'>
      <!-- Logo Section -->
      <div class='flex-shrink-0 flex items-center min-w-0'>
        <img
          src='/icons/logo.svg'
          alt='ZeroDolg'
          width='180'
          height='50'
          loading='lazy'
          class='w-24 sm:w-32 md:w-40 lg:w-44 xl:w-[180px] h-auto'
        />
      </div>

      <!-- Main Navigation with Dropdown Menus -->
      <div class='hidden md:block' id='navMenu'>
        <ul class='flex space-x-8 xl:space-x-12'>
          <!-- Services Dropdown -->
          <li class='relative group'>
            <button
              class='btn-ghost !py-2 text-sm flex items-center'
              aria-expanded='false'
              aria-haspopup='true'
              data-dropdown='services'
            >
              <span>Услуги</span>
              <svg class='ml-1 w-4 h-4' width='12' height='12' viewBox='0 0 12 12' fill='none'>
                <path
                  d='M3 4.5L6 7.5L9 4.5'
                  stroke='currentColor'
                  stroke-width='1.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'></path>
              </svg>
            </button>
            <div
              class='absolute left-0 mt-2 w-52 bg-white rounded-xl shadow-xl border border-gray-100 hidden group-hover:block'
              style='z-index: 9999 !important;'
              data-dropdown-menu='services'
            >
              <div class='py-2'>
                {
                  navItems.services.map((item) => (
                    <a
                      href={item.href}
                      class:list={[
                        `block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-all duration-200 rounded-lg mx-2 `,
                        { 'bg-blue-50 text-blue-600 font-semibold': item.highlight },
                      ]}
                    >
                      <div class='flex items-center'>
                        <span class='text-base mr-2'>{item.icon}</span>
                        <span class='font-medium'>{item.title}</span>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </li>

          <!-- About Dropdown -->
          <li class='relative group'>
            <button
              class='btn-ghost !py-2 text-sm flex items-center'
              aria-expanded='false'
              aria-haspopup='true'
              data-dropdown='about'
            >
              <span>О компании</span>
              <svg class='ml-1 w-4 h-4' width='12' height='12' viewBox='0 0 12 12' fill='none'>
                <path
                  d='M3 4.5L6 7.5L9 4.5'
                  stroke='currentColor'
                  stroke-width='1.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'></path>
              </svg>
            </button>
            <div
              class='absolute left-0 mt-2 w-52 bg-white rounded-xl shadow-xl border border-gray-100 hidden group-hover:block'
              style='z-index: 9999 !important;'
              data-dropdown-menu='about'
            >
              <div class='py-2'>
                {
                  navItems.about.map((item) => (
                    <a
                      href={item.href}
                      class='block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-all duration-200 rounded-lg mx-2'
                    >
                      <div class='flex items-center'>
                        <span class='text-base mr-2'>{item.icon}</span>
                        <span class='font-medium'>{item.title}</span>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </li>

          <!-- Info Dropdown -->
          <li class='relative group'>
            <button
              class='btn-ghost !py-2 text-sm flex items-center'
              aria-expanded='false'
              aria-haspopup='true'
              data-dropdown='info'
            >
              <span>Информация</span>
              <svg class='ml-1 w-4 h-4' width='12' height='12' viewBox='0 0 12 12' fill='none'>
                <path
                  d='M3 4.5L6 7.5L9 4.5'
                  stroke='currentColor'
                  stroke-width='1.5'
                  stroke-linecap='round'
                  stroke-linejoin='round'></path>
              </svg>
            </button>
            <div
              class='absolute left-0 mt-2 w-52 bg-white rounded-xl shadow-xl border border-gray-100 hidden group-hover:block'
              style='z-index: 9999 !important;'
              data-dropdown-menu='info'
            >
              <div class='py-2'>
                {
                  navItems.info.map((item) => (
                    <a
                      href={item.href}
                      class='block px-4 py-3 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-all duration-200 rounded-lg mx-2'
                    >
                      <div class='flex items-center'>
                        <span class='text-base mr-2'>{item.icon}</span>
                        <span class='font-medium'>{item.title}</span>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </li>
        </ul>
      </div>

      <!-- Right Side Actions -->
      <div class='flex items-center gap-2 sm:gap-4 lg:gap-6 flex-shrink-0'>
        <!-- Phone Link for Desktop - Enhanced -->
        <a
          href={`tel:${company.phone.replace(/[^\d+]/g, '')}`}
          class='hidden md:flex items-center px-3 lg:px-4 py-2 lg:py-2.5 text-gray-700 hover:text-blue-600 hover:bg-gradient-to-r hover:from-blue-50 hover:to-blue-100 rounded-xl transition-all duration-300 group border border-transparent hover:border-blue-200 hover:shadow-lg flex-shrink-0'
          aria-label='Позвонить'
        >
          <svg
            width='20'
            height='20'
            viewBox='0 0 20 20'
            fill='none'
            class='flex-shrink-0 group-hover:scale-110 group-hover:rotate-12 transition-all duration-300'
          >
            <path
              d='M18.3 15.2C18.3 15.5 18.24 15.81 18.11 16.11C17.98 16.41 17.81 16.69 17.58 16.95C17.19 17.38 16.76 17.68 16.27 17.86C15.79 18.04 15.27 18.13 14.71 18.13C13.86 18.13 12.96 17.92 12.02 17.49C11.08 17.06 10.14 16.49 9.21 15.78C8.27 15.06 7.38 14.27 6.53 13.4C5.69 12.54 4.91 11.64 4.2 10.7C3.5 9.76 2.93 8.82 2.51 7.89C2.09 6.95 1.88 6.05 1.88 5.19C1.88 4.65 1.97 4.13 2.14 3.64C2.31 3.14 2.6 2.69 3.02 2.3C3.53 1.8 4.09 1.55 4.68 1.55C4.91 1.55 5.14 1.6 5.35 1.7C5.57 1.8 5.77 1.95 5.93 2.17L7.72 4.71C7.88 4.92 8 5.11 8.08 5.29C8.16 5.46 8.2 5.63 8.2 5.78C8.2 5.97 8.14 6.16 8.02 6.34C7.91 6.52 7.75 6.71 7.55 6.9L6.96 7.51C6.87 7.6 6.83 7.71 6.83 7.84C6.83 7.9 6.84 7.95 6.86 8.01C6.89 8.07 6.92 8.11 6.94 8.15C7.1 8.43 7.37 8.8 7.75 9.24C8.14 9.68 8.55 10.13 9 10.58C9.46 11.03 9.9 11.44 10.35 11.83C10.79 12.21 11.16 12.47 11.45 12.63C11.48 12.65 11.52 12.68 11.57 12.71C11.63 12.74 11.69 12.75 11.76 12.75C11.9 12.75 12.01 12.7 12.1 12.61L12.69 12.03C12.89 11.83 13.08 11.68 13.26 11.57C13.44 11.45 13.62 11.39 13.82 11.39C13.97 11.39 14.13 11.42 14.31 11.5C14.49 11.58 14.68 11.69 14.89 11.84L17.46 13.66C17.68 13.82 17.83 14.01 17.92 14.23C18 14.45 18.05 14.67 18.05 14.91'
              stroke='currentColor'
              stroke-width='1.8'
              stroke-miterlimit='10'></path>
          </svg>
          <div class='ml-2 lg:ml-3 min-w-0'>
            <span class='block text-xs lg:text-sm font-semibold leading-tight whitespace-nowrap'
              >{company.phone}</span
            >
            <span
              class='hidden lg:block text-xs text-gray-500 group-hover:text-blue-500 transition-colors'
              >Позвонить</span
            >
          </div>
        </a>

        <!-- Mobile Menu Toggle -->
        <button
          class='md:hidden inline-flex btn-ghost !p-2 rounded-xl flex-shrink-0'
          aria-label='Меню'
          aria-expanded='false'
          data-mobile-toggle
        >
          <span class='sr-only'>Открыть главное меню</span>
          <div class='flex flex-col items-center justify-center w-6 h-6'>
            <span
              class='nav-toggle-line block h-0.5 w-6 bg-current rounded transition-all duration-300'
            ></span>
            <span
              class='nav-toggle-line block h-0.5 w-6 bg-current rounded my-1.5 transition-all duration-300'
            ></span>
            <span
              class='nav-toggle-line block h-0.5 w-6 bg-current rounded transition-all duration-300'
            ></span>
          </div>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    class='lg:hidden fixed inset-0 overflow-y-auto hidden'
    style='z-index: 9999 !important;'
    id='mobile-menu'
    data-mobile-menu
    role='dialog'
    aria-modal='true'
    aria-labelledby='mobile-menu-title'
    aria-hidden='true'
  >
    <div
      class='fixed inset-0 bg-black bg-opacity-75'
      data-mobile-menu-overlay
      aria-label='Закрыть мобильное меню'
    >
    </div>

    <div class='relative transform overflow-hidden max-w-xs w-full ml-auto h-full'>
      <!-- Mobile Menu Header -->
      <div class='bg-white shadow-lg h-full flex flex-col'>
        <div class='flex items-center justify-between p-4 border-b h-16'>
          <a
            href='/'
            class='flex-shrink-0 flex items-center'
            title={`${company.name} - Главная`}
            aria-label='Перейти на главную страницу'
          >
            <img src='/icons/logo.svg' alt={company.name} width='180' height='50' loading='lazy' />
          </a>
          <button
            class='btn-ghost !p-2'
            type='button'
            aria-label='Закрыть мобильное меню'
            data-mobile-menu-close
          >
            <span class='sr-only'>Закрыть меню</span>
            <svg class='h-6 w-6' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M6 18L18 6M6 6l12 12'></path>
            </svg>
          </button>
        </div>

        <!-- Mobile Navigation -->
        <nav class='flex-1 overflow-y-auto p-4' role='navigation' aria-label='Мобильная навигация'>
          <h2 id='mobile-menu-title' class='sr-only'>Навигация по сайту</h2>
          <ul class='space-y-2'>
            {
              mobileMenuItems.map((item) => (
                <li role='none'>
                  <a
                    href={item.href}
                    class:list={`block px-4 py-3 rounded-md ${item.className || 'text-gray-700 hover:bg-gray-50'} text-base font-medium`}
                    role='menuitem'
                    title={item.title}
                    data-mobile-link
                  >
                    {item.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <!-- Mobile Contact Information -->
        <div class='border-t p-4 space-y-3'>
          <a
            href={`tel:${company.phone.replace(/[^\d+]/g, '')}`}
            class='flex items-center justify-center space-x-2 py-3 text-base sm:text-lg font-semibold text-blue-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg transition-all duration-200'
            title='Позвонить'
            aria-label={`Телефон: ${company.phone}`}
          >
            <svg width='20' height='20' viewBox='0 0 20 20' fill='none' class='flex-shrink-0'>
              <path
                d='M18.3 15.2C18.3 15.5 18.24 15.81 18.11 16.11C17.98 16.41 17.81 16.69 17.58 16.95C17.19 17.38 16.76 17.68 16.27 17.86C15.79 18.04 15.27 18.13 14.71 18.13C13.86 18.13 12.96 17.92 12.02 17.49C11.08 17.06 10.14 16.49 9.21 15.78C8.27 15.06 7.38 14.27 6.53 13.4C5.69 12.54 4.91 11.64 4.2 10.7C3.5 9.76 2.93 8.82 2.51 7.89C2.09 6.95 1.88 6.05 1.88 5.19C1.88 4.65 1.97 4.13 2.14 3.64C2.31 3.14 2.6 2.69 3.02 2.3C3.53 1.8 4.09 1.55 4.68 1.55C4.91 1.55 5.14 1.6 5.35 1.7C5.57 1.8 5.77 1.95 5.93 2.17L7.72 4.71C7.88 4.92 8 5.11 8.08 5.29C8.16 5.46 8.2 5.63 8.2 5.78C8.2 5.97 8.14 6.16 8.02 6.34C7.91 6.52 7.75 6.71 7.55 6.9L6.96 7.51C6.87 7.6 6.83 7.71 6.83 7.84C6.83 7.9 6.84 7.95 6.86 8.01C6.89 8.07 6.92 8.11 6.94 8.15C7.1 8.43 7.37 8.8 7.75 9.24C8.14 9.68 8.55 10.13 9 10.58C9.46 11.03 9.9 11.44 10.35 11.83C10.79 12.21 11.16 12.47 11.45 12.63C11.48 12.65 11.52 12.68 11.57 12.71C11.63 12.74 11.69 12.75 11.76 12.75C11.9 12.75 12.01 12.7 12.1 12.61L12.69 12.03C12.89 11.83 13.08 11.68 13.26 11.57C13.44 11.45 13.62 11.39 13.82 11.39C13.97 11.39 14.13 11.42 14.31 11.5C14.49 11.58 14.68 11.69 14.89 11.84L17.46 13.66C17.68 13.82 17.83 14.01 17.92 14.23C18 14.45 18.05 14.67 18.05 14.91'
                stroke='currentColor'
                stroke-width='1.5'
                stroke-miterlimit='10'></path>
            </svg>
            <span class='whitespace-nowrap text-sm sm:text-base'>{company.phone}</span>
          </a>
          <div class='flex items-center justify-center space-x-2 text-sm text-gray-500'>
            <svg width='16' height='16' viewBox='0 0 20 20' fill='none' class='flex-shrink-0'>
              <path
                d='M10 18a8 8 0 100-16 8 8 0 000 16zm0-9V5m0 4l3 3'
                stroke='currentColor'
                stroke-width='1.5'
                stroke-linecap='round'
                stroke-linejoin='round'></path>
            </svg>
            <time datetime='Mo-Su 09:00-21:00'>
              {company.workHours}
            </time>
          </div>
        </div>

        <!-- Mobile Social Links -->
        <div
          class='border-t p-4 flex justify-center space-x-6'
          role='navigation'
          aria-label='Социальные сети'
        >
          {
            company.social.whatsapp && (
              <a
                href={company.social.whatsapp}
                class='text-gray-500 hover:text-gray-700 transition-colors'
                target='_blank'
                rel='noopener nofollow'
                aria-label='Написать в WhatsApp'
                title='WhatsApp консультация'
              >
                <span>WhatsApp</span>
              </a>
            )
          }
          {
            company.social.telegram && (
              <a
                href={company.social.telegram}
                class='text-gray-500 hover:text-gray-700 transition-colors'
                target='_blank'
                rel='noopener nofollow'
                aria-label='Написать в Telegram'
                title='Telegram консультация'
              >
                <span>Telegram</span>
              </a>
            )
          }
          {
            company.social.vk && (
              <a
                href={company.social.vk}
                class='text-gray-500 hover:text-gray-700 transition-colors'
                target='_blank'
                rel='noopener nofollow'
                aria-label='Наша группа ВКонтакте'
                title='Группа ВКонтакте'
              >
                <span>ВКонтакте</span>
              </a>
            )
          }
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Header interactivity is handled by Header Preact component -->
<HeaderComponent client:load />
