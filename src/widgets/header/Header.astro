---
import HeaderComponent from '../../components/preact/header.tsx';

export interface Props {
  currentPage?: string;
}

// Props are not currently used in this component
// const { currentPage } = Astro.props;

// Данные компании (можно вынести в отдельный конфиг)
const company = {
  name: 'ZeroDolg',
  phone: '+7 (905) 577-33-87',
  workHours: 'Пн-Пт: 9:00-18:00',
  social: {
    whatsapp: 'https://wa.me/79055773387',
    telegram: 'https://t.me/zerodolg',
    vk: 'https://vk.com/zerodolg',
  },
};

// Навигационные элементы
const navItems = {
  services: [
    {
      href: '#problems',
      icon: '⚡',
      title: 'Решаемые проблемы',
      desc: 'Какие долговые проблемы мы решаем',
    },
    {
      href: '#process',
      icon: '📋',
      title: 'Процесс банкротства',
      desc: 'Пошаговое описание процедуры',
    },
    {
      href: '#calculator',
      icon: '💰',
      title: 'Калькулятор стоимости',
      desc: 'Рассчитайте стоимость услуг',
      highlight: true,
    },
  ],
  about: [
    { href: '#benefits', icon: '🏆', title: 'Наши преимущества', desc: 'Почему выбирают нас' },
    { href: '#team', icon: '👥', title: 'Команда', desc: 'Наши юристы и специалисты' },
    { href: '#reviews', icon: '⭐', title: 'Отзывы клиентов', desc: 'Истории успеха' },
  ],
  info: [
    { href: '#faq', icon: '❓', title: 'Частые вопросы', desc: 'Ответы на популярные вопросы' },
    { href: 'blog/', icon: '📚', title: 'Блог', desc: 'Полезные статьи и новости' },
    { href: '#contact', icon: '📍', title: 'Контакты', desc: 'Как с нами связаться' },
    {
      href: '/privacy',
      icon: '🔒',
      title: 'Конфиденциальность',
      desc: 'Политика обработки данных',
    },
    { href: '/terms', icon: '📋', title: 'Соглашение', desc: 'Условия использования сайта' },
  ],
};

const mobileMenuItems = [
  { href: '#problems', title: 'Проблемы' },
  { href: '#process', title: 'Процесс' },
  { href: '#calculator', title: 'Калькулятор' },
  { href: '#benefits', title: 'Преимущества' },
  { href: '#reviews', title: 'Отзывы' },
  { href: '#team', title: 'Команда' },
  { href: '#faq', title: 'FAQ' },
  { href: 'blog/', title: '📚 Блог', className: 'mobile-menu__link--blog' },
  { href: '#contacts', title: 'Контакты' },
  { href: '/privacy', title: 'Конфиденциальность' },
  { href: '/terms', title: 'Соглашение' },
];
---

<!-- Advanced Interactive Navigation -->
<header class="bg-white shadow-md sticky top-0 z-50" id="main-header">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" role="navigation" aria-label="Главная навигация">
    <div class="flex items-center justify-between h-16">
      <!-- Logo Section -->
      <div class="flex-shrink-0 flex items-center">
        <img src="/icons/logo.svg" alt="ZeroDolg" width="140" height="40" loading="lazy" />
      </div>

      <!-- Main Navigation with Dropdown Menus -->
      <div class="hidden md:block" id="navMenu">
        <ul class="flex space-x-8">
          <!-- Services Dropdown -->
          <li class="relative group">
            <button
              class="text-gray-700 hover:text-primary px-3 py-2 font-medium text-sm flex items-center"
              aria-expanded="false"
              aria-haspopup="true"
              data-dropdown="services"
            >
              <span>Услуги</span>
              <svg class="ml-1 w-4 h-4" width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path
                  d="M3 4.5L6 7.5L9 4.5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
            <div class="absolute z-10 mt-2 w-64 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 hidden group-hover:block" data-dropdown-menu="services">
              <div class="py-1">
                {
                  navItems.services.map((item) => (
                    <a
                      href={item.href}
                      class={`block px-4 py-3 hover:bg-gray-50 ${item.highlight ? 'bg-blue-50' : ''}`}
                    >
                      <div class="flex items-start">
                        <span class="text-lg mr-3">{item.icon}</span>
                        <div>
                          <span class="block text-sm font-medium text-gray-900">{item.title}</span>
                          <span class="block text-sm text-gray-500">{item.desc}</span>
                        </div>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </li>

          <!-- About Dropdown -->
          <li class="relative group">
            <button
              class="text-gray-700 hover:text-primary px-3 py-2 font-medium text-sm flex items-center"
              aria-expanded="false"
              aria-haspopup="true"
              data-dropdown="about"
            >
              <span>О компании</span>
              <svg class="ml-1 w-4 h-4" width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path
                  d="M3 4.5L6 7.5L9 4.5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
            <div class="absolute z-10 mt-2 w-64 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 hidden group-hover:block" data-dropdown-menu="about">
              <div class="py-1">
                {
                  navItems.about.map((item) => (
                    <a href={item.href} class="block px-4 py-3 hover:bg-gray-50">
                      <div class="flex items-start">
                        <span class="text-lg mr-3">{item.icon}</span>
                        <div>
                          <span class="block text-sm font-medium text-gray-900">{item.title}</span>
                          <span class="block text-sm text-gray-500">{item.desc}</span>
                        </div>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </li>

          <!-- Info Dropdown -->
          <li class="relative group">
            <button
              class="text-gray-700 hover:text-primary px-3 py-2 font-medium text-sm flex items-center"
              aria-expanded="false"
              aria-haspopup="true"
              data-dropdown="info"
            >
              <span>Информация</span>
              <svg class="ml-1 w-4 h-4" width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path
                  d="M3 4.5L6 7.5L9 4.5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
            <div class="absolute z-10 mt-2 w-64 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 hidden group-hover:block" data-dropdown-menu="info">
              <div class="py-1">
                {
                  navItems.info.map((item) => (
                    <a href={item.href} class="block px-4 py-3 hover:bg-gray-50">
                      <div class="flex items-start">
                        <span class="text-lg mr-3">{item.icon}</span>
                        <div>
                          <span class="block text-sm font-medium text-gray-900">{item.title}</span>
                          <span class="block text-sm text-gray-500">{item.desc}</span>
                        </div>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </li>
        </ul>
      </div>

      <!-- Action Buttons -->
      <div class="flex items-center">
        <!-- Quick Actions for Desktop -->
        <div class="hidden md:flex items-center space-x-4">
          <button class="p-2 text-gray-700 hover:text-primary rounded-md" aria-label="Поиск" data-action="search">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path
                d="M9 17C13.4183 17 17 13.4183 17 9C17 4.58172 13.4183 1 9 1C4.58172 1 1 4.58172 1 9C1 13.4183 4.58172 17 9 17Z"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M19 19L14.65 14.65"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </button>

          <a
            href={`tel:${company.phone.replace(/[^\d+]/g, '')}`}
            class="flex items-center text-nav-text hover:text-nav-hover transition-colors"
            aria-label="Позвонить"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path
                d="M18.3 15.2C18.3 15.5 18.24 15.81 18.11 16.11C17.98 16.41 17.81 16.69 17.58 16.95C17.19 17.38 16.76 17.68 16.27 17.86C15.79 18.04 15.27 18.13 14.71 18.13C13.86 18.13 12.96 17.92 12.02 17.49C11.08 17.06 10.14 16.49 9.21 15.78C8.27 15.06 7.38 14.27 6.53 13.4C5.69 12.54 4.91 11.64 4.2 10.7C3.5 9.76 2.93 8.82 2.51 7.89C2.09 6.95 1.88 6.05 1.88 5.19C1.88 4.65 1.97 4.13 2.14 3.64C2.31 3.14 2.6 2.69 3.02 2.3C3.53 1.8 4.09 1.55 4.68 1.55C4.91 1.55 5.14 1.6 5.35 1.7C5.57 1.8 5.77 1.95 5.93 2.17L7.72 4.71C7.88 4.92 8 5.11 8.08 5.29C8.16 5.46 8.2 5.63 8.2 5.78C8.2 5.97 8.14 6.16 8.02 6.34C7.91 6.52 7.75 6.71 7.55 6.9L6.96 7.51C6.87 7.6 6.83 7.71 6.83 7.84C6.83 7.9 6.84 7.95 6.86 8.01C6.89 8.07 6.92 8.11 6.94 8.15C7.1 8.43 7.37 8.8 7.75 9.24C8.14 9.68 8.55 10.13 9 10.58C9.46 11.03 9.9 11.44 10.35 11.83C10.79 12.21 11.16 12.47 11.45 12.63C11.48 12.65 11.52 12.68 11.57 12.71C11.63 12.74 11.69 12.75 11.76 12.75C11.9 12.75 12.01 12.7 12.1 12.61L12.69 12.03C12.89 11.83 13.08 11.68 13.26 11.57C13.44 11.45 13.62 11.39 13.82 11.39C13.97 11.39 14.13 11.42 14.31 11.5C14.49 11.58 14.68 11.69 14.89 11.84L17.46 13.66C17.68 13.82 17.83 14.01 17.92 14.23C18 14.45 18.05 14.67 18.05 14.91"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-miterlimit="10"></path>
            </svg>
            <span class="ml-1 text-sm font-medium">{company.phone}</span>
          </a>
        </div>

        <!-- CTA Button -->
        <button class="hidden md:inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary ml-4" data-modal="callback">
          <span>Получить консультацию</span>
          <svg class="ml-2 -mr-1 h-5 w-5" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path
              d="M3 8H13M13 8L8 3M13 8L8 13"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>

        <!-- Mobile Menu Toggle -->
        <button
          class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-gray-700 hover:text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary"
          aria-label="Меню"
          aria-expanded="false"
          data-mobile-toggle
        >
          <span class="sr-only">Открыть главное меню</span>
          <span class="nav-toggle-line block h-0.5 w-6 bg-current rounded transition"></span>
          <span class="nav-toggle-line block h-0.5 w-6 bg-current rounded my-1.5 transition"></span>
          <span class="nav-toggle-line block h-0.5 w-6 bg-current rounded transition"></span>
        </button>
      </div>
    </div>
  </nav>

  <!-- Search Overlay -->
  <div class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden" data-search-overlay>
    <div class="flex items-center justify-center h-full p-4">
      <div class="bg-white rounded-lg shadow-xl w-full max-w-md">
        <form class="search-form flex" action="/search" method="GET">
          <input
            type="search"
            class="search-input flex-1 px-4 py-3 focus:outline-none text-lg border-0"
            placeholder="Поиск по сайту..."
            name="q"
            aria-label="Поиск"
          />
          <button type="submit" class="search-submit px-6 py-3 bg-primary text-white hover:bg-primary-dark" aria-label="Искать">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path
                d="M9 17C13.4183 17 17 13.4183 17 9C17 4.58172 13.4183 1 9 1C4.58172 1 1 4.58172 1 9C1 13.4183 4.58172 17 9 17Z"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M19 19L14.65 14.65"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </button>
        </form>
        <button class="absolute top-4 right-4 text-gray-500 hover:text-gray-700" data-search-close aria-label="Закрыть поиск">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path
              d="M18 6L6 18M6 6L18 18"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    class="lg:hidden fixed inset-0 z-50 overflow-y-auto hidden"
    id="mobile-menu"
    data-mobile-menu
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-menu-title"
    aria-hidden="true"
  >
    <div class="mobile-menu__overlay fixed inset-0 bg-black bg-opacity-75" data-mobile-menu-overlay aria-label="Закрыть мобильное меню">
    </div>

    <div class="relative transform overflow-hidden max-w-xs w-full ml-auto h-full">
      <!-- Mobile Menu Header -->
      <div class="bg-white shadow-lg h-full flex flex-col">
        <div class="flex items-center justify-between p-4 border-b">
          <a
            href="/"
            class="flex-shrink-0 flex items-center"
            title={`${company.name} - Главная`}
            aria-label="Перейти на главную страницу"
          >
            <img src="/images/logo.svg" alt={company.name} width="140" height="40" loading="lazy" />
          </a>
          <button
            class="mobile-menu__close -mr-2 p-2 rounded-md text-gray-700 hover:text-gray-900 hover:bg-gray-100"
            type="button"
            aria-label="Закрыть мобильное меню"
            data-mobile-menu-close
          >
            <span class="sr-only">Закрыть меню</span>
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Mobile Navigation -->
        <nav class="flex-1 overflow-y-auto p-4" role="navigation" aria-label="Мобильная навигация">
          <h2 id="mobile-menu-title" class="sr-only">Навигация по сайту</h2>
          <ul class="space-y-2">
            {
              mobileMenuItems.map((item) => (
                <li class="mobile-menu__item" role="none">
                  <a
                    href={item.href}
                    class={`mobile-menu__link block px-4 py-3 rounded-md ${item.className || 'text-gray-700 hover:bg-gray-50'} text-base font-medium`}
                    role="menuitem"
                    title={item.title}
                  >
                    {item.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <!-- Mobile Contact Information -->
        <div class="border-t p-4 space-y-4">
          <a
            href={`tel:${company.phone.replace(/[^\d+]/g, '')}`}
            class="mobile-menu__phone block text-center text-lg font-semibold text-primary hover:text-primary-dark"
            title="Позвонить для консультации"
            aria-label={`Телефон: ${company.phone}`}
          >
            {company.phone}
          </a>
          <time class="mobile-menu__work-hours block text-center text-base text-gray-500" datetime="Mo-Fr 09:00-18:00">
            {company.workHours}
          </time>
          <button
            class="w-full py-3 px-4 bg-gray-100 text-gray-800 rounded-md hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500"
            data-modal="install-app"
            type="button"
            aria-label="Установить приложение"
          >
            <span>📱 Установить приложение</span>
          </button>
          <button
            class="w-full py-3 px-4 bg-primary text-white rounded-md hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary"
            data-modal="callback"
            type="button"
            aria-label="Заказать обратный звонок для консультации"
          >
            <span>Заказать звонок</span>
          </button>
        </div>

        <!-- Mobile Social Links -->
        <div class="border-t p-4 flex justify-center space-x-6" role="navigation" aria-label="Социальные сети">
          {
            company.social.whatsapp && (
              <a
                href={company.social.whatsapp}
                class="mobile-menu__social-link text-gray-500 hover:text-gray-700"
                target="_blank"
                rel="noopener nofollow"
                aria-label="Написать в WhatsApp"
                title="WhatsApp консультация"
              >
                <span>WhatsApp</span>
              </a>
            )
          }
          {
            company.social.telegram && (
              <a
                href={company.social.telegram}
                class="mobile-menu__social-link text-gray-500 hover:text-gray-700"
                target="_blank"
                rel="noopener nofollow"
                aria-label="Написать в Telegram"
                title="Telegram консультация"
              >
                <span>Telegram</span>
              </a>
            )
          }
          {
            company.social.vk && (
              <a
                href={company.social.vk}
                class="mobile-menu__social-link text-gray-500 hover:text-gray-700"
                target="_blank"
                rel="noopener nofollow"
                aria-label="Наша группа ВКонтакте"
                title="Группа ВКонтакте"
              >
                <span>ВКонтакте</span>
              </a>
            )
          }
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Header interactivity is handled by Header Preact component -->
<HeaderComponent client:load />
