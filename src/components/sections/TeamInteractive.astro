---
import TeamInteractive from '../../islands/interactive/TeamInteractiveEnhanced';
import { teamMembers, calculateTeamStats } from '../../core/team-members.ts';

// Use static data
const activeTeamMembers = teamMembers;

// Calculate team statistics
const teamStats = calculateTeamStats(activeTeamMembers);
---

<!-- Team interactivity is handled by the TeamInteractiveEnhanced component with stats -->
<TeamInteractive client:visible members={activeTeamMembers} stats={teamStats} />
