---
// Component to display problems that the service solves with modern Tailwind design

import ProblemsInteractive from '../../islands/sections/ProblemsInteractive.tsx';
import SectionSemantics from '../../shared/ui/SectionSemantics.astro';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Problems data with corresponding solution icons
const problemsData = [
  {
    icon: '/icons/solution/01-shield-check.svg',
    title: 'Кредиты и займы',
    description: 'Списываем долги по кредитам, займам МФО, кредитным картам',
    gradient: 'from-blue-500 to-purple-600',
    hoverColor: 'hover:text-blue-600',
    bgGradient: 'bg-gradient-to-br from-blue-50 to-purple-50',
  },
  {
    icon: '/icons/solution/02-bell-off.svg',
    title: 'Налоги и штрафы',
    description: 'Избавляем от налоговых долгов, штрафов ГИБДД, пени',
    gradient: 'from-emerald-500 to-teal-600',
    hoverColor: 'hover:text-emerald-600',
    bgGradient: 'bg-gradient-to-br from-emerald-50 to-teal-50',
  },
  {
    icon: '/icons/solution/03-home-shield.svg',
    title: 'Коммунальные долги',
    description: 'Списываем задолженности по ЖКХ и коммунальным платежам',
    gradient: 'from-orange-500 to-red-600',
    hoverColor: 'hover:text-orange-600',
    bgGradient: 'bg-gradient-to-br from-orange-50 to-red-50',
  },
  {
    icon: '/icons/solution/04-handshake.svg',
    title: 'Поручительства',
    description: 'Освобождаем от долгов по поручительству и созаемщикам',
    gradient: 'from-violet-500 to-pink-600',
    hoverColor: 'hover:text-violet-600',
    bgGradient: 'bg-gradient-to-br from-violet-50 to-pink-50',
  },
];
---

<!-- Problems Section with Modern Design and Extended Background Pattern -->
<section
  class:list={`relative py-20 md:py-28 lg:py-36 pb-32 md:pb-40 lg:pb-48 ${className}`}
  id='problems'
  aria-labelledby='problems-title'
  style='isolation: isolate; z-index: 10;'
>
  <!-- Background for Problems section only with mask applied -->
  <div
    class='absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-indigo-50/40'
    style='z-index: -10; mask-image: linear-gradient(to bottom, black 0%, black 85%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 85%, transparent 100%);'
  >
  </div>

  <!-- Watercolor background pattern for Problems section only with mask applied -->
  <div
    class='absolute inset-0 opacity-25'
    style='z-index: -10; background-image: url("/patterns/problems-pattern.png"); background-size: cover; background-position: center; background-repeat: no-repeat; mask-image: linear-gradient(to bottom, black 0%, black 85%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 85%, transparent 100%);'
  >
  </div>

  <!-- Dot pattern overlay for Problems section only with mask applied -->
  <div
    class='absolute inset-0 opacity-10'
    style='z-index: -10; background-image: url("/patterns/hero-dots.svg"); background-size: 100px 100px; mask-image: linear-gradient(to bottom, black 0%, black 85%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 85%, transparent 100%);'
  >
  </div>

  <div class='relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
    <!-- Section Header -->
    <header class='text-center mb-16 md:mb-20 lg:mb-24'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-red-100/80 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-red-700 ring-1 ring-red-200/50 mb-8'
        role='text'
        aria-label='Проблемы с долгами, которые мы решаем'
      >
        <svg
          class='h-4 w-4 text-red-600'
          fill='none'
          viewBox='0 0 24 24'
          stroke='currentColor'
          aria-hidden='true'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z'
          ></path>
        </svg>
        <span itemscope itemtype='https://schema.org/Thing'>
          <meta itemprop='name' content='Экспертная помощь по долгам' />
          <meta
            itemprop='description'
            content='Кредиты, займы, налоги, коммунальные долги, поручительства'
          />
          Экспертная помощь
        </span>
      </div>
      <h2
        id='problems-title'
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 tracking-tight leading-tight'
      >
        Решаем проблемы с долгами
      </h2>
      <p class='text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-medium'>
        Поможем в сложной ситуации
      </p>
    </header>

    <!-- Problems Grid -->
    <div
      class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 lg:gap-10'
      role='list'
      aria-label='Типы долгов, которые можно списать'
    >
      {
        problemsData.map((problem, index) => (
          <article
            class:list={`group relative overflow-hidden rounded-2xl 
                  bg-white/60 backdrop-blur-md border border-white/50 
                  shadow-md shadow-slate-900/10 
                  p-3 md:p-4 lg:p-5 text-center cursor-pointer 
                  transition-all duration-500 ease-out transform hover:scale-[1.02] hover:-translate-y-2 
                  hover:bg-white/85 hover:shadow-xl hover:shadow-slate-900/15 
                  hover:border-slate-200/60 problems-card problems-card-${index + 1} 
                  focus:outline-none focus:ring-4 focus:ring-blue-500/50 focus:ring-offset-2 
                  focus:scale-[1.02] focus:-translate-y-2 min-h-[160px] md:min-h-[170px] lg:min-h-[180px] 
                  flex flex-col justify-between aspect-[4/3]`}
            role='listitem'
            tabindex='0'
            aria-labelledby={`problem-title-${index + 1}`}
            aria-describedby={`problem-desc-${index + 1}`}
            data-index={`0${index + 1}`}
            style={`animation-delay: ${(index + 1) * 150}ms`}
            onkeydown={`if(event.key==='Enter'||event.key===' '){event.preventDefault();this.click();}`}
          >
            {/* Card number indicator */}
            <div
              class='absolute top-4 right-4 w-8 h-8 rounded-full bg-gradient-to-br from-slate-100/90 to-slate-200/90
                      opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center backdrop-blur-sm'
            >
              <span class='text-xs font-bold text-slate-700'>{`0${index + 1}`}</span>
            </div>

            {/* Gradient accent top border */}
            <div
              class:list={`absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r ${problem.gradient}
                       scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left rounded-t-2xl`}
            />

            {/* Icon Container */}
            <div class='flex-shrink-0 mb-2'>
              <div
                class:list={`relative w-8 h-8 md:w-10 md:h-10 lg:w-12 lg:h-12 mx-auto rounded-lg md:rounded-xl 
                         bg-gradient-to-br ${problem.gradient} p-2 md:p-2.5 shadow-lg 
                         group-hover:shadow-xl group-hover:scale-110 transition-all duration-500`}
              >
                {/* Inner glow effect */}
                <div class='absolute inset-0 rounded-lg md:rounded-xl bg-gradient-to-br from-white/30 to-transparent pointer-events-none' />

                {/* SVG Icon */}
                <img
                  src={problem.icon}
                  alt={`Иконка для ${problem.title.toLowerCase()}`}
                  class='w-full h-full object-contain filter brightness-0 invert'
                  role='img'
                  loading='lazy'
                />
              </div>
            </div>

            {/* Content */}
            <div class='relative z-10 flex-grow flex flex-col justify-center'>
              <h3
                id={`problem-title-${index + 1}`}
                class:list={`text-lg md:text-xl lg:text-lg font-bold text-slate-900 mb-2 
                      transition-colors duration-300 ${problem.hoverColor} leading-tight tracking-tight`}
              >
                {problem.title}
              </h3>
              <p
                id={`problem-desc-${index + 1}`}
                class='text-sm md:text-base lg:text-sm text-slate-700 leading-relaxed font-medium opacity-90'
              >
                {problem.description}
              </p>
            </div>

            {/* Hover background gradient */}
            <div
              class:list={`absolute inset-0 ${problem.bgGradient} opacity-0
                       group-hover:opacity-100 transition-opacity duration-500 -z-10`}
            />
          </article>
        ))
      }
    </div>
  </div>
</section>
<!-- Семантические данные для SEO -->
<SectionSemantics sectionId='problems' />

<!-- Interactive Enhancement Component -->
<ProblemsInteractive client:idle />

<!-- Enhanced Animation Styles -->
<style>
  /* Entrance animations with staggered delay */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .problems-card {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }

  .problems-card-1 {
    animation-delay: 150ms;
  }
  .problems-card-2 {
    animation-delay: 300ms;
  }
  .problems-card-3 {
    animation-delay: 450ms;
  }
  .problems-card-4 {
    animation-delay: 600ms;
  }

  /* Enhanced glassmorphism effect */
  .problems-card {
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .problems-card {
      animation: none;
      opacity: 1;
    }

    .problems-card:hover {
      transform: none;
    }
  }

  /* Print styles */
  @media print {
    .problems-card {
      break-inside: avoid;
      box-shadow: none;
      border: 1px solid #e2e8f0;
      background: white !important;
    }
  }

  /* Ripple effect for click feedback */
  .problems-ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(59, 130, 246, 0.3);
    transform: scale(0);
    animation: ripple 0.6s linear;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes ripple {
    to {
      transform: scale(2);
      opacity: 0;
    }
  }

  /* Enhanced visibility state */
  .problems-card.animate-visible {
    opacity: 1 !important;
  }
</style>
