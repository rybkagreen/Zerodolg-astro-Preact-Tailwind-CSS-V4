---
import StickyPanelLogic from '../islands/StickyPanelLogic.tsx';

export interface Props {
  title?: string;
  subtitle?: string;
  timerDate?: string;
  ctaText?: string;
  ctaModal?: string;
  delay?: number;
  scrollThreshold?: number;
  cookieDays?: number;
}

const {
  title = "🎁 Специальное предложение!",
  subtitle = "Только сегодня! Скидка 50% на консультацию",
  timerDate = null,
  ctaText = "Получить скидку",
  ctaModal = "callback",
  delay = 5000,
  scrollThreshold = 300,
  cookieDays = 1
} = Astro.props;

// Calculate default timer date (24 hours from now)
const defaultTimerDate = timerDate || new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString();
---

<div class="sticky-panel" hidden data-sticky-panel>
  <div class="sticky-panel__container">
    <button 
      class="sticky-panel__close" 
      data-sticky-close
      aria-label="Закрыть панель"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    
    <div class="sticky-panel__content">
      <div class="sticky-panel__text">
        <h3 class="sticky-panel__title">{title}</h3>
        <p class="sticky-panel__subtitle">{subtitle}</p>
      </div>
      
      {timerDate && (
        <div class="sticky-panel__timer" data-timer={defaultTimerDate}>
          <div class="timer__item">
            <span class="timer__value" data-days>00</span>
            <span class="timer__label">дней</span>
          </div>
          <div class="timer__separator">:</div>
          <div class="timer__item">
            <span class="timer__value" data-hours>00</span>
            <span class="timer__label">часов</span>
          </div>
          <div class="timer__separator">:</div>
          <div class="timer__item">
            <span class="timer__value" data-minutes>00</span>
            <span class="timer__label">минут</span>
          </div>
        </div>
      )}
      
      <button 
        class="sticky-panel__cta btn btn--primary"
        data-modal={ctaModal}
        data-track="sticky_panel_cta"
      >
        {ctaText}
      </button>
    </div>
  </div>
</div>

<StickyPanelLogic 
  client:idle
  delay={delay}
  scrollThreshold={scrollThreshold}
  cookieDays={cookieDays}
/>

