---
const { className = '' } = Astro.props;
---

<div class={`container-component ${className}`}>
  <style>
    .container-component {
      container-type: inline-size;
    }
    
    @container (min-width: 400px) {
      .responsive-content {
        flex-direction: row;
      }
    }
    
    @container (min-width: 600px) {
      .responsive-content {
        flex-direction: row;
        justify-content: space-between;
      }
      
      .responsive-content .card {
        flex: 1;
        margin-right: 1rem;
      }
      
      .responsive-content .card:last-child {
        margin-right: 0;
      }
    }
  </style>
  
  <div class=\"responsive-content flex flex-col p-4 gap-4\">
    <div class=\"card bg-bg-secondary p-4 rounded-lg shadow-sm\">
      <h3 class=\"text-text-primary font-medium\">Карточка 1</h3>
      <p class=\"text-text-muted mt-1\">Этот контент адаптируется к ширине контейнера</p>
    </div>
    <div class=\"card bg-bg-secondary p-4 rounded-lg shadow-sm\">
      <h3 class=\"text-text-primary font-medium\">Карточка 2</h3>
      <p class=\"text-text-muted mt-1\">Используются контейнерные запросы вместо медиа-запросов</p>
    </div>
  </div>
</div>