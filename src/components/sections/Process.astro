---
import ProcessInteractive from '../../islands/sections/ProcessInteractive.tsx';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Данные о процессе банкротства (адаптированы из Timeline.astro)
const processData = {
  title: 'Как проходит банкротство',
  subtitle: 'Пошаговый процесс освобождения от долгов через суд',
  steps: [
    {
      number: 1,
      title: 'Консультация',
      shortTitle: 'Анализ ситуации',
      description: 'Анализируем вашу ситуацию и определяем возможность банкротства',
      duration: '1 день',
      difficulty: 'easy',
      icon: 'analysis',
      gradient: 'from-blue-500 to-indigo-600',
      hoverColor: 'hover:text-blue-600',
      bgGradient: 'bg-gradient-to-br from-blue-50 to-indigo-50',
      details: [
        'Бесплатная оценка перспектив',
        'Анализ всех долгов и кредиторов',
        'Определение оптимальной стратегии',
        'Расчет стоимости процедуры',
      ],
    },
    {
      number: 2,
      title: 'Подготовка документов',
      shortTitle: 'Сбор документов',
      description: 'Собираем и готовим все необходимые документы',
      duration: '5-7 дней',
      difficulty: 'medium',
      icon: 'documents',
      gradient: 'from-emerald-500 to-teal-600',
      hoverColor: 'hover:text-emerald-600',
      bgGradient: 'bg-gradient-to-br from-emerald-50 to-teal-50',
      details: [
        'Помощь в сборе документов',
        'Подготовка списка кредиторов',
        'Оформление заявления в суд',
        'Проверка всех данных',
      ],
      documents: [
        'Паспорт и СНИЛС',
        'ИНН и свидетельство о рождении',
        'Справки о доходах за 3 года',
        'Кредитные договоры и решения судов',
      ],
    },
    {
      number: 3,
      title: 'Подача заявления',
      shortTitle: 'Подача в суд',
      description: 'Подаем заявление в Арбитражный суд',
      duration: '1 день',
      difficulty: 'easy',
      icon: 'court',
      gradient: 'from-orange-500 to-red-600',
      hoverColor: 'hover:text-orange-600',
      bgGradient: 'bg-gradient-to-br from-orange-50 to-red-50',
      details: [
        'Подача через электронную систему суда',
        'Оплата госпошлины 300 рублей',
        'Получение входящего номера дела',
        'Уведомление всех кредиторов',
      ],
      warning: 'С момента подачи заявления коллекторы не могут вам звонить',
    },
    {
      number: 4,
      title: 'Судебная процедура',
      shortTitle: 'Представительство в суде',
      description: 'Представляем ваши интересы на всех заседаниях',
      duration: '4-6 месяцев',
      difficulty: 'hard',
      icon: 'gavel',
      gradient: 'from-violet-500 to-pink-600',
      hoverColor: 'hover:text-violet-600',
      bgGradient: 'bg-gradient-to-br from-violet-50 to-pink-50',
      details: [
        'Первое судебное заседание',
        'Назначение финансового управляющего',
        'Реализация имущества (если есть)',
        'Собрание кредиторов',
      ],
      warning: 'Единственное жилье и предметы обычного обихода остаются у вас',
    },
    {
      number: 5,
      title: 'Списание долгов',
      shortTitle: 'Новая жизнь',
      description: 'Получаем решение суда о списании всех долгов',
      duration: '1 день',
      difficulty: 'easy',
      icon: 'discharge',
      gradient: 'from-green-500 to-emerald-600',
      hoverColor: 'hover:text-green-600',
      bgGradient: 'bg-gradient-to-br from-green-50 to-emerald-50',
      details: [
        'Окончательное судебное заседание',
        'Получение решения суда',
        'Списание всех долгов',
        'Начало новой жизни без долгов',
      ],
    },
  ],
};
---

<!-- Process Section with Interactive Card -->
<section
  class:list={`relative py-20 md:py-28 lg:py-36 overflow-hidden ${className}`}
  id='process'
  aria-labelledby='process-title'
>
  <!-- Background layers -->
  <div class='absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-purple-50/40'></div>

  <!-- Background pattern -->
  <div
    class='absolute inset-0 opacity-25 mix-blend-multiply'
    style='background-image: url("/patterns/Pastel Paint Strokes Abstract Digital Art Social Media Post (1).png"); background-size: cover; background-position: center; background-repeat: no-repeat;'
  >
  </div>

  <!-- Dot pattern overlay -->
  <div
    class='absolute inset-0 opacity-10'
    style='background-image: url("/patterns/hero-dots.svg"); background-size: 100px 100px;'
  >
  </div>

  <div class='relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
    <!-- Section Header -->
    <header class='text-center mb-16 md:mb-20 lg:mb-24'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-purple-100/80 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-purple-700 ring-1 ring-purple-200/50 mb-8'
      >
        <svg class='h-4 w-4 text-purple-600' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2'
          ></path>
        </svg>
        Процесс банкротства
      </div>
      <h2
        id='process-title'
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 tracking-tight leading-tight'
      >
        {processData.title}
      </h2>
      <p class='text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-medium'>
        {processData.subtitle}
      </p>
    </header>

    <!-- Interactive Process Card -->
    <div class='process-interactive-container'>
      <article
        class='group relative overflow-hidden rounded-3xl
               bg-white/60 backdrop-blur-md border border-white/50
               shadow-md shadow-slate-900/10
               p-6 md:p-8 lg:p-10
               transition-all duration-500 ease-out
               hover:bg-white/85 hover:shadow-xl hover:shadow-slate-900/15
               hover:border-slate-200/60 process-card'
      >
        <!-- Card number indicator (shows current step) -->
        <div
          id='process-step-indicator'
          class='absolute top-6 right-6 w-10 h-10 rounded-full bg-gradient-to-br from-slate-100/90 to-slate-200/90
                 transition-all duration-300 flex items-center justify-center backdrop-blur-sm'
        >
          <span id='process-step-number' class='text-sm font-bold text-slate-700'>1</span>
        </div>

        <!-- Gradient accent border (changes with step) -->
        <div
          id='process-accent-border'
          class='absolute top-0 left-0 right-0 h-2 bg-gradient-to-r from-blue-500 to-indigo-600
                 transition-all duration-500 rounded-t-3xl'
        >
        </div>

        <!-- Navigation Tabs -->
        <div class='mb-8'>
          <div class='flex flex-wrap gap-2 md:gap-3 lg:gap-4'>
            {
              processData.steps.map((step, index) => (
                <button
                  class:list={[
                    `process-nav-btn px-3 py-2 md:px-4 md:py-3 rounded-xl text-sm md:text-base font-medium
                        transition-all duration-300 border-2 
                        `,
                    {
                      'bg-blue-500 text-white border-blue-500 shadow-md': index === 0,
                      'bg-white/50 text-slate-600 border-white/30 hover:bg-white/70 hover:text-slate-800':
                        index !== 0,
                    },
                  ]}
                  data-step={index}
                  data-gradient={step.gradient}
                  data-bg-gradient={step.bgGradient}
                >
                  <span class='hidden md:inline'>{step.title}</span>
                  <span class='md:hidden'>{step.shortTitle}</span>
                </button>
              ))
            }
          </div>
        </div>

        <!-- Content Area -->
        <div id='process-content' class='space-y-6'>
          <!-- Dynamic content will be inserted here by ProcessInteractive -->
          <div class='process-step-content' data-step='0'>
            <!-- Step 1 content (initial) -->
            <div class='flex items-start gap-4 mb-6'>
              <div
                class='w-12 h-12 md:w-16 md:h-16 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-600
                          flex items-center justify-center shadow-lg flex-shrink-0'
              >
                <svg
                  class='w-6 h-6 md:w-8 md:h-8 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2z'
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class='text-2xl md:text-3xl font-bold text-slate-900 mb-2'>
                  {processData.steps[0].title}
                </h3>
                <div class='flex items-center gap-3 mb-4'>
                  <span
                    class='px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-medium'
                  >
                    {processData.steps[0].duration}
                  </span>
                  <span class='text-slate-500'>•</span>
                  <span class='text-slate-600'>Этап 1 из 5</span>
                </div>
                <p class='text-lg text-slate-700 leading-relaxed'>
                  {processData.steps[0].description}
                </p>
              </div>
            </div>

            <!-- Details -->
            <div class='space-y-4'>
              <h4 class='text-lg font-semibold text-slate-900'>Что включает:</h4>
              <ul class='space-y-3'>
                {
                  processData.steps[0].details.map((detail, idx) => (
                    <li key={idx} class='flex items-start gap-3'>
                      <div class='mt-1 w-5 h-5 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0'>
                        <svg
                          class='w-3 h-3 text-green-600'
                          fill='none'
                          viewBox='0 0 24 24'
                          stroke='currentColor'
                        >
                          <path
                            stroke-linecap='round'
                            stroke-linejoin='round'
                            stroke-width='3'
                            d='M5 13l4 4L19 7'
                          />
                        </svg>
                      </div>
                      <span class='text-slate-700'>{detail}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <!-- Navigation Controls -->
        <div class='flex items-center justify-between mt-8 pt-6 border-t border-slate-200/50'>
          <button
            id='process-prev-btn'
            class='flex items-center gap-2 px-4 py-2 rounded-xl text-slate-500 hover:text-slate-700
                   hover:bg-white/50 transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed'
            disabled
          >
            <svg class='w-5 h-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M15 19l-7-7 7-7'></path>
            </svg>
            <span>Назад</span>
          </button>

          <!-- Progress indicator -->
          <div class='flex items-center gap-2'>
            {
              processData.steps.map((_, index) => (
                <div
                  class:list={[
                    `w-2 h-2 rounded-full transition-all duration-300 process-progress-dot
                        `,
                    { 'bg-blue-500': index === 0, 'bg-slate-300': index !== 0 },
                  ]}
                  data-step={index}
                />
              ))
            }
          </div>

          <button
            id='process-next-btn'
            class='flex items-center gap-2 px-4 py-2 rounded-xl bg-blue-500 text-white
                   hover:bg-blue-600 transition-all duration-300'
          >
            <span>Далее</span>
            <svg class='w-5 h-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
              <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7'
              ></path>
            </svg>
          </button>
        </div>

        <!-- Hover background gradient -->
        <div
          id='process-hover-bg'
          class='absolute inset-0 bg-gradient-to-br from-blue-50 to-indigo-50 opacity-0
                 transition-opacity duration-500 -z-10 pointer-events-none'
        >
        </div>
      </article>
    </div>

    <!-- CTA Section -->
    <div class='mt-16 md:mt-20'>
      <div
        class='relative overflow-hidden rounded-3xl bg-gradient-to-br from-blue-600 via-purple-600 to-indigo-700 p-8 md:p-12 shadow-2xl'
      >
        {/* Background decoration */}
        <div class='absolute -top-10 -right-10 h-40 w-40 rounded-full bg-white/10 blur-3xl'></div>
        <div class='absolute -bottom-10 -left-10 h-32 w-32 rounded-full bg-purple-300/20 blur-2xl'>
        </div>

        <div class='relative text-center'>
          <div
            class='mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-white/10 backdrop-blur-sm'
          >
            <svg class='h-8 w-8 text-white' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M13 10V3L4 14h7v7l9-11h-7z'></path>
            </svg>
          </div>

          <h3 class='mb-4 text-3xl font-bold text-white lg:text-4xl'>
            Готовы начать новую жизнь без долгов?
          </h3>
          <p class='mb-8 text-lg text-blue-100 lg:text-xl'>
            Оставьте заявку и мы поможем на каждом этапе
          </p>

          <div class='flex flex-col gap-4 sm:flex-row sm:justify-center'>
            <button
              class='group inline-flex items-center justify-center gap-2 rounded-2xl bg-white px-8 py-4 text-lg font-bold text-blue-600 shadow-xl transition-all duration-300 hover:scale-105 hover:bg-blue-50 hover:shadow-2xl'
              data-modal='consultation'
              data-modal-type='consultation'
            >
              Начать процедуру
              <svg
                class='h-5 w-5 transition-transform duration-300 group-hover:translate-x-1'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M13 7l5 5m0 0l-5 5m5-5H6'></path>
              </svg>
            </button>

            <button
              class='group inline-flex items-center justify-center gap-2 rounded-2xl border-2 border-white/30 bg-white/10 px-8 py-4 text-lg font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:bg-white/20'
              data-modal='callback'
            >
              <svg class='h-5 w-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'
                ></path>
              </svg>
              Заказать звонок
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Process Interactive Component -->
<ProcessInteractive client:load processData={processData} />

<!-- Enhanced Animation Styles for Process -->
<style>
  /* Process card animations */
  .process-card {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }

  .process-card {
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  /* Step transition animations */
  .process-step-content {
    transition: all 0.5s ease-in-out;
  }

  .process-step-content.fade-out {
    opacity: 0;
    transform: translateY(20px);
  }

  .process-step-content.fade-in {
    opacity: 1;
    transform: translateY(0);
  }

  /* Navigation button hover effects */
  .process-nav-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px -8px rgba(0, 0, 0, 0.3);
  }

  /* Progress dots animation */
  .process-progress-dot {
    transform: scale(1);
    transition: all 0.3s ease;
  }

  .process-progress-dot.active {
    transform: scale(1.2);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .process-card {
      animation: none;
      opacity: 1;
    }

    .process-step-content,
    .process-nav-btn,
    .process-progress-dot {
      transition: none;
    }
  }
</style>
