---
// Hero.astro - Hero section with two-column layout
import HeroForm from '../../components/forms/HeroForm.astro';

export interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Коллекторы больше не позвонят.',
  subtitle = 'Арбитражный управляющий Масхулиа Л.З. с командой юристов проведут вашу процедуру банкротства.',
} = Astro.props;
---

<section class='hero-section section-padding'>
  <!-- Background decoration -->
  <div class='absolute inset-0'>
    <div
      class='absolute -top-40 -right-32 w-80 h-80 bg-gradient-to-br from-blue-400/30 to-indigo-600/30 rounded-full blur-3xl'
    >
    </div>
    <div
      class='absolute -bottom-40 -left-32 w-96 h-96 bg-gradient-to-tr from-purple-400/20 to-pink-600/20 rounded-full blur-3xl'
    >
    </div>
    <div
      class='absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-r from-blue-500/10 to-purple-500/10 rounded-full blur-3xl'
    >
    </div>
  </div>

  <div class='relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    <div class='grid items-center grid-cols-1 gap-16 lg:grid-cols-2'>
      <!-- Left Column - Main Content -->
      <div class='space-y-10 text-center lg:text-left'>
        <!-- Badge -->
        <div
          class='inline-flex items-center gap-2 rounded-full bg-white/10 px-6 py-3 text-sm font-medium text-white/90 backdrop-blur-sm ring-1 ring-white/20'
        >
          <svg class='h-4 w-4 text-green-400' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              stroke-width='2'
              d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'></path>
          </svg>
          Федеральный закон №127-ФЗ «О несостоятельности»
        </div>

        <!-- Main Heading -->
        <div class='space-y-6'>
          <h1
            class='text-4xl font-black leading-tight text-white sm:text-5xl lg:text-6xl xl:text-7xl'
          >
            <span class='bg-gradient-to-r from-white to-blue-100 bg-clip-text text-transparent'>
              {title}
            </span>
          </h1>
          <div
            class='text-2xl font-bold text-transparent bg-gradient-to-r from-yellow-400 via-orange-400 to-red-400 bg-clip-text sm:text-3xl lg:text-4xl'
          >
            Спишем долги от 300 тыс. до 10 млн ₽ через суд
          </div>
        </div>

        <!-- Subtitle -->
        <p class='text-xl leading-relaxed text-blue-100 lg:text-2xl'>
          {subtitle}
        </p>

        <!-- Key Stats -->
        <div class='inline-flex items-center gap-6 text-white'>
          <div class='text-center'>
            <div class='text-3xl font-bold text-green-400'>89%</div>
            <div class='text-sm text-blue-200'>успех</div>
          </div>
          <div class='w-px h-12 bg-white/20'></div>
          <div class='text-center'>
            <div class='text-3xl font-bold text-yellow-400'>6-8</div>
            <div class='text-sm text-blue-200'>месяцев</div>
          </div>
          <div class='w-px h-12 bg-white/20'></div>
          <div class='text-center'>
            <div class='text-3xl font-bold text-blue-400'>5 мин</div>
            <div class='text-sm text-blue-200'>от метро</div>
          </div>
        </div>

        <!-- Benefits List -->
        <div class='space-y-4'>
          <ul class='space-y-3 text-left'>
            <li class='flex items-center gap-3 text-lg text-white'>
              <div
                class='flex h-6 w-6 items-center justify-center rounded-full bg-green-500/20 ring-1 ring-green-400/30'
              >
                <svg
                  class='h-3 w-3 text-green-400'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='3'
                    d='M5 13l4 4L19 7'></path>
                </svg>
              </div>
              Единственное жилье защищено законом
            </li>
            <li class='flex items-center gap-3 text-lg text-white'>
              <div
                class='flex h-6 w-6 items-center justify-center rounded-full bg-green-500/20 ring-1 ring-green-400/30'
              >
                <svg
                  class='h-3 w-3 text-green-400'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='3'
                    d='M5 13l4 4L19 7'></path>
                </svg>
              </div>
              Полное списание долгов через суд
            </li>
            <li class='flex items-center gap-3 text-lg text-white'>
              <div
                class='flex h-6 w-6 items-center justify-center rounded-full bg-green-500/20 ring-1 ring-green-400/30'
              >
                <svg
                  class='h-3 w-3 text-green-400'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='3'
                    d='M5 13l4 4L19 7'></path>
                </svg>
              </div>
              Защита от взысканий с первого дня
            </li>
          </ul>

          <!-- Special Offer Badge -->
          <div class='relative mt-6'>
            <div
              class='absolute inset-0 rounded-2xl bg-gradient-to-r from-red-500 to-orange-500 blur opacity-75'
            >
            </div>
            <div
              class='relative rounded-2xl bg-gradient-to-r from-red-500 to-orange-500 p-4 text-center text-white'
            >
              <div class='flex items-center justify-center gap-2 text-lg font-bold'>
                <span class='text-2xl'>🔥</span>
                <span>Консультация БЕСПЛАТНО</span>
              </div>
              <p class='text-sm opacity-90'>акция до 31 августа 2025 для первых 10 человек!</p>
            </div>
          </div>
        </div>

        <!-- CTA Button -->
        <div class='pt-4'>
          <button
            class='group relative inline-flex w-full items-center justify-center gap-3 overflow-hidden rounded-2xl bg-gradient-to-r from-blue-600 to-indigo-600 px-8 py-6 text-lg font-bold text-white shadow-xl transition-all duration-300 hover:scale-105 hover:from-blue-700 hover:to-indigo-700 focus:outline-none focus:ring-4 focus:ring-blue-500/25 sm:w-auto'
            data-action='scroll-to-form'
          >
            <span class='relative z-10'>Получить бесплатную консультацию</span>
            <div
              class='relative z-10 flex items-center gap-1 rounded-full bg-yellow-400/20 px-3 py-1 text-sm font-semibold text-yellow-300 ring-1 ring-yellow-400/30'
            >
              <div class='h-2 w-2 rounded-full bg-yellow-400 animate-pulse'></div>
              Осталось 7 мест
            </div>
            <div
              class='absolute inset-0 bg-gradient-to-r from-white/0 via-white/20 to-white/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000'
            >
            </div>
          </button>
        </div>

        <!-- Contact Info -->
        <div class='grid grid-cols-1 gap-6 pt-8 text-blue-100 sm:grid-cols-3'>
          <div class='flex items-center gap-3'>
            <div
              class='flex h-10 w-10 items-center justify-center rounded-full bg-white/10 ring-1 ring-white/20'
            >
              <span class='text-xl'>🏢</span>
            </div>
            <span>Офис: Минская ул., 2Ж</span>
          </div>
          <div class='flex items-center gap-3'>
            <div
              class='flex h-10 w-10 items-center justify-center rounded-full bg-white/10 ring-1 ring-white/20'
            >
              <span class='text-xl'>🔒</span>
            </div>
            <span>Защита данных по 152-ФЗ</span>
          </div>
          <div class='flex items-center gap-3'>
            <div
              class='flex h-10 w-10 items-center justify-center rounded-full bg-white/10 ring-1 ring-white/20'
            >
              <span class='text-xl'>📞</span>
            </div>
            <span>Ежедневно 9:00-21:00</span>
          </div>
        </div>
      </div>

      <!-- Right Column - Expert Card, Form and Stats -->
      <div class='space-y-8'>
        <!-- Expert Card with Modern Design -->
        <div
          class='relative overflow-hidden rounded-3xl bg-white/95 backdrop-blur-lg p-8 shadow-2xl ring-1 ring-white/20'
        >
          <div
            class='absolute -top-10 -right-10 h-20 w-20 rounded-full bg-gradient-to-br from-blue-400/20 to-purple-400/20 blur-xl'
          >
          </div>
          <div class='relative flex items-start gap-6'>
            <div class='relative'>
              <div
                class='absolute -inset-1 rounded-full bg-gradient-to-r from-blue-600 to-purple-600 opacity-75 blur'
              >
              </div>
              <img
                class='relative h-24 w-24 rounded-full object-cover ring-2 ring-white'
                src='/images/team/mashulia.webp'
                alt='Масхулиа Леван Зурабович - Арбитражный управляющий'
                width='96'
                height='96'
                fetchpriority='high'
                decoding='async'
              />
              <div
                class='absolute -bottom-1 -right-1 rounded-full bg-green-500 p-1 ring-2 ring-white'
              >
                <svg class='h-3 w-3 text-white' fill='currentColor' viewBox='0 0 20 20'>
                  <path
                    fill-rule='evenodd'
                    d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z'
                    clip-rule='evenodd'></path>
                </svg>
              </div>
            </div>
            <div class='flex-1'>
              <div class='mb-2'>
                <h3 class='text-2xl font-bold text-gray-900'>Масхулиа Л.З.</h3>
                <p class='text-blue-600 font-semibold'>Арбитражный управляющий №14320</p>
              </div>
              <div class='space-y-2 text-sm text-gray-600'>
                <div class='flex items-center gap-2'>
                  <div class='h-2 w-2 rounded-full bg-green-400'></div>
                  <span>11+ лет опыта</span>
                </div>
                <div class='flex items-center gap-2'>
                  <div class='h-2 w-2 rounded-full bg-blue-400'></div>
                  <span>1200+ успешных дел</span>
                </div>
                <div class='flex items-center gap-2'>
                  <div class='h-2 w-2 rounded-full bg-purple-400'></div>
                  <span>Член СРО арбитражных управляющих</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Form with Enhanced Design -->
        <div class='relative'>
          <div
            class='absolute -inset-1 rounded-3xl bg-gradient-to-r from-blue-600 to-purple-600 opacity-75 blur'
          >
          </div>
          <div class='relative rounded-3xl bg-white p-8'>
            <HeroForm id='consultation-form' />
          </div>
        </div>

        <!-- Stats with Modern Cards -->
        <div class='grid grid-cols-3 gap-4'>
          <div
            class='group relative overflow-hidden rounded-2xl bg-gradient-to-br from-blue-500 to-blue-600 p-6 text-center text-white shadow-xl transition-transform hover:scale-105'
          >
            <div
              class='absolute inset-0 bg-gradient-to-br from-white/20 to-transparent opacity-0 transition-opacity group-hover:opacity-100'
            >
            </div>
            <div class='relative'>
              <div class='text-3xl font-bold'>1000+</div>
              <div class='text-sm opacity-90'>Клиентов</div>
            </div>
          </div>
          <div
            class='group relative overflow-hidden rounded-2xl bg-gradient-to-br from-green-500 to-emerald-600 p-6 text-center text-white shadow-xl transition-transform hover:scale-105'
          >
            <div
              class='absolute inset-0 bg-gradient-to-br from-white/20 to-transparent opacity-0 transition-opacity group-hover:opacity-100'
            >
            </div>
            <div class='relative'>
              <div class='text-3xl font-bold'>98%</div>
              <div class='text-sm opacity-90'>Успех</div>
            </div>
          </div>
          <div
            class='group relative overflow-hidden rounded-2xl bg-gradient-to-br from-amber-500 to-orange-600 p-6 text-center text-white shadow-xl transition-transform hover:scale-105'
          >
            <div
              class='absolute inset-0 bg-gradient-to-br from-white/20 to-transparent opacity-0 transition-opacity group-hover:opacity-100'
            >
            </div>
            <div class='relative'>
              <div class='text-3xl font-bold'>2.1M+</div>
              <div class='text-sm opacity-90'>Списано</div>
            </div>
          </div>
        </div>
      </div>
      <!-- End of right column -->
    </div>
  </div>
</section>

<!-- Hero interactivity is handled by Preact components -->
