---
// Hero.astro - Hero section with Tailwind CSS v3 styling
import HeroForm from '../../components/forms/HeroForm.astro';
import { SITE_CONSTANTS, getPromoInfo } from '../../shared/config/constants';
import OptimizedImage from '@/shared/ui/OptimizedImage';
import { generateTeamMemberImageSchema } from '@shared/lib/extended-structured-data';

export interface Props {
  title?: string;
  subtitle?: string;
}

const { title = 'От долгов — к свободе всего один шаг!' } = Astro.props;

// Получаем актуальные данные из констант
const stats = SITE_CONSTANTS.stats;
const manager = SITE_CONSTANTS.manager;
const contacts = SITE_CONSTANTS.contacts;
const promo = getPromoInfo();
---

<!-- Hero Section with Animated Dark Blue Gradient Background -->
<section class='relative min-h-[75vh] md:min-h-[80vh] lg:min-h-[85vh] overflow-hidden'>
  <!-- Dark Blue to Blue Cyclic Rotating Animated Gradient Background -->
  <div
    class='absolute inset-0 animate-gradient-rotate'
    style='background: linear-gradient(to right, #0f172a, #1e3a8a, #312e81) !important; background-size: 400% 400% !important;'
  >
  </div>

  <!-- Dark overlay for contrast -->
  <div
    class='absolute inset-0 bg-gradient-to-br from-transparent via-black/20 to-black/40 pointer-events-none'
  >
  </div>

  <!-- Animated mesh pattern overlay -->
  <div
    class='absolute inset-0 opacity-30'
    style='background-image: radial-gradient(circle at 30% 70%, rgba(245, 158, 11, 0.15) 0%, transparent 50%), radial-gradient(circle at 70% 30%, rgba(37, 99, 235, 0.15) 0%, transparent 50%), radial-gradient(circle at 50% 50%, rgba(255, 215, 0, 0.1) 0%, transparent 50%); animation: mesh-float 30s ease-in-out infinite;'
  >
  </div>

  <!-- Content Container -->
  <div class='relative z-10 container-custom mx-auto px-4 py-12 lg:py-20'>
    <!-- Trust Badge - Centered across Hero section -->
    <div class='flex justify-center mb-8'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-blue-100/80 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-blue-700 ring-1 ring-blue-200/50'
      >
        <svg class='h-4 w-4 text-blue-600' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z'
          ></path>
        </svg>
        <span class='text-blue-700'>
          Работаем по ФЗ-№127<br />"О несостоятельности"
        </span>
      </div>
    </div>

    <div class='grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-10 lg:gap-12 items-start'>
      <!-- Left Column - Main Content -->
      <div class='space-y-8'>
        <!-- Title Section -->
        <div class='space-y-4'>
          <h1
            class='text-4xl lg:text-5xl xl:text-6xl font-bold text-white leading-[1.1] tracking-tight'
          >
            {title}
          </h1>
          <div class='text-2xl lg:text-3xl font-semibold text-amber-400 leading-tight'>
            Гарантированно спишем 300 тыс. – 10 млн ₽ — коллекторы замолчат навсегда.
          </div>
        </div>

        <!-- Description -->
        <div class='space-y-4 text-lg text-gray-300 leading-relaxed max-w-2xl'>
          <p>
            Арбитражный управляющий Леван Масхулиа с командой опытных юристов проведёт ваше
            банкротство.
            <a
              href='https://old.bankrot.fedresurs.ru/ArbitrManagerCard.aspx?ID=0fe01101-9000-45a5-9a14-31d86002b6ba'
              target='_blank'
              rel='noopener nofollow'
              class='text-amber-400 font-semibold hover:text-amber-300 underline decoration-amber-400/50 hover:decoration-amber-300 transition-colors'
            >
              100% успешных дел (по данным ЕФРСБ)
            </a>
            — списание долгов в среднем за <span class='text-amber-400 font-semibold'
              >4–6 месяцев</span
            >.
          </p>
          <p class='text-emerald-400 font-medium'>
            Офис в 3 минутах от метро ВДНХ — ваше спокойствие начинается
            <a
              href='https://yandex.ru/profile/7922237253?lang=ru&no-distribution=1&view-state=mini&source=wizbiz_new_map_single'
              target='_blank'
              rel='noopener nofollow'
              class='text-emerald-300 hover:text-emerald-200 underline decoration-emerald-300/50 hover:decoration-emerald-200 transition-colors font-semibold'
              title='Посмотреть на Яндекс.Картах — отзывы и маршрут'
            >
              здесь
            </a>!
          </p>
        </div>

        <!-- Benefits Grid -->
        <div class='grid grid-cols-1 md:grid-cols-3 gap-4'>
          <div
            class='rounded-xl bg-gradient-to-br from-emerald-500/10 to-emerald-600/10 backdrop-blur-sm border border-emerald-500/30 p-5 text-center'
          >
            <div class='flex justify-center mb-3'>
              <div
                class='w-12 h-12 rounded-full bg-emerald-500/20 flex items-center justify-center'
              >
                <svg
                  class='w-6 h-6 text-emerald-400'
                  fill='none'
                  stroke='currentColor'
                  viewBox='0 0 24 24'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
                  ></path>
                </svg>
              </div>
            </div>
            <h3 class='text-lg font-bold text-white mb-1'>Единственное жилье</h3>
            <p class='text-gray-300 text-sm'>защищено законом</p>
          </div>
          <div
            class='rounded-xl bg-gradient-to-br from-emerald-500/10 to-emerald-600/10 backdrop-blur-sm border border-emerald-500/30 p-5 text-center'
          >
            <div class='flex justify-center mb-3'>
              <div
                class='w-12 h-12 rounded-full bg-emerald-500/20 flex items-center justify-center'
              >
                <svg
                  class='w-6 h-6 text-emerald-400'
                  fill='none'
                  stroke='currentColor'
                  viewBox='0 0 24 24'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2'
                  ></path>
                </svg>
              </div>
            </div>
            <h3 class='text-lg font-bold text-white mb-1'>Полное списание</h3>
            <p class='text-gray-300 text-sm'>долгов через суд</p>
          </div>
          <div
            class='rounded-xl bg-gradient-to-br from-emerald-500/10 to-emerald-600/10 backdrop-blur-sm border border-emerald-500/30 p-5 text-center'
          >
            <div class='flex justify-center mb-3'>
              <div
                class='w-12 h-12 rounded-full bg-emerald-500/20 flex items-center justify-center'
              >
                <svg
                  class='w-6 h-6 text-emerald-400'
                  fill='none'
                  stroke='currentColor'
                  viewBox='0 0 24 24'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z'
                  ></path>
                </svg>
              </div>
            </div>
            <h3 class='text-lg font-bold text-white mb-1'>Защита от взысканий</h3>
            <p class='text-gray-300 text-sm'>с первого дня</p>
          </div>
        </div>

        <!-- CTA Card -->
        <div
          class='rounded-2xl bg-gradient-to-r from-orange-600/20 to-red-600/20 backdrop-blur-md border border-orange-500/30 p-6'
        >
          <div class='text-center'>
            <div
              class='inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-red-500/20 to-orange-500/20 border border-orange-500/30 px-4 py-2 mb-4'
            >
              <svg class='w-5 h-5 text-orange-400' fill='currentColor' viewBox='0 0 20 20'>
                <path
                  fill-rule='evenodd'
                  d='M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z'
                  clip-rule='evenodd'></path>
              </svg>
              <span class='text-orange-400 font-semibold text-sm'>
                {SITE_CONSTANTS.promo.consultation.title} — {promo.availability}
              </span>
            </div>

            <h3 class='text-xl font-bold text-white mb-2'>
              {SITE_CONSTANTS.promo.consultation.description}
            </h3>
            <p class='text-gray-300 mb-4'>Оставьте заявку и мы свяжемся с вами в течение 2 минут</p>

            <p class='text-orange-300/70 text-sm'>{promo.availability}</p>
          </div>
        </div>

        <!-- Trust Indicators -->
        <div class='flex flex-wrap items-center gap-6 pt-4'>
          <div class='flex items-center gap-2'>
            <svg
              class='w-5 h-5 text-gray-400'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
              ></path>
            </svg>
            <span class='text-gray-400 text-sm'>Офис в центре Москвы</span>
          </div>
          <div class='flex items-center gap-2'>
            <svg
              class='w-5 h-5 text-gray-400'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z'
              ></path>
            </svg>
            <span class='text-gray-400 text-sm'>Конфиденциально</span>
          </div>
          <div class='flex items-center gap-2'>
            <svg
              class='w-5 h-5 text-gray-400'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'></path>
            </svg>
            <span class='text-gray-400 text-sm'>Работаем {contacts.workTimeShort}</span>
          </div>
        </div>
      </div>

      <!-- Right Column - Expert Card, Form and Stats -->
      <div class='space-y-6'>
        <!-- Expert Card -->
        <div class='rounded-2xl bg-white/10 backdrop-blur-md border border-white/20 p-6 shadow-2xl'>
          <div class='flex items-center gap-4'>
            <div class='relative flex-shrink-0'>
              <div
                class='w-32 h-32 rounded-full overflow-hidden border-4 border-blue-300 shadow-2xl shadow-blue-400/30'
              >
                <OptimizedImage
                  src='/images/team/mashulia.webp'
                  alt='Масхулиа Леван Зурабович - Арбитражный управляющий'
                  width={128}
                  height={128}
                  class='w-full h-full object-cover'
                  style='object-position: center 25%'
                  sizes='(max-width: 768px) 100vw, 50vw'
                  decoding='async'
                  loading='lazy'
                />
              </div>
            </div>
            <div class='flex-1'>
              <div class='text-white font-bold text-lg'>Леван Масхулиа</div>
              <div class='text-amber-400 text-sm font-medium'>
                Арбитражный финансовый управляющий (ИНН 505014806562)
              </div>
              <div class='mt-2 text-gray-200 text-sm space-y-1'>
                <div class='block mb-2'>
                  ✓ Член СРО "
                  <a
                    href='https://old.bankrot.fedresurs.ru/SroCard.aspx?ID=08422e0b-4cc3-4c28-9e89-9ca52edb16d0'
                    target='_blank'
                    rel='noopener nofollow'
                    class='text-amber-300 hover:text-amber-200 underline decoration-amber-300/50 hover:decoration-amber-200 transition-colors text-xs leading-relaxed'
                    title='Проверить в реестре Федресурс'
                  >
                    Ассоциация арбитражных управляющих саморегулируемая организация "Центральное
                    агентство арбитражных управляющих"
                  </a>
                  "
                </div>
                <span class='block'>✓ {manager.experience.display}</span>
                <span class='block'>✓ {manager.cases.display}</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Form Container -->
        <div
          class='rounded-2xl bg-white/10 backdrop-blur-md border border-white/20 p-6 shadow-2xl'
          id='consultation-form'
        >
          <div
            class='[&_input]:bg-white/10 [&_input]:backdrop-blur-sm [&_input]:border-white/20 [&_input]:text-white [&_input]:placeholder-gray-300 [&_textarea]:bg-white/10 [&_textarea]:backdrop-blur-sm [&_textarea]:border-white/20 [&_textarea]:text-white [&_textarea]:placeholder-gray-300 [&_select]:bg-white/10 [&_select]:backdrop-blur-sm [&_select]:border-white/20 [&_select]:text-white [&_label]:text-gray-200 [&_input:focus]:bg-white/20 [&_input:focus]:border-yellow-400 [&_textarea:focus]:bg-white/20 [&_textarea:focus]:border-yellow-400 [&_select:focus]:bg-white/20 [&_select:focus]:border-yellow-400'
          >
            <HeroForm />
          </div>
        </div>

        <!-- Stats Grid -->
        <div class='grid grid-cols-3 gap-4'>
          <div
            class='rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 p-4 text-center'
          >
            <span class='block text-2xl font-bold text-amber-400'>{stats.clients.display}</span>
            <span class='block text-sm text-gray-300 mt-1'>Клиентов</span>
          </div>
          <div
            class='rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 p-4 text-center'
          >
            <span class='block text-2xl font-bold text-amber-400'>{stats.successRate.display}</span>
            <span class='block text-sm text-gray-300 mt-1'>Успех</span>
          </div>
          <div
            class='rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 p-4 text-center'
          >
            <span class='block text-2xl font-bold text-amber-400'
              >{stats.debtCleared.shortDisplay}</span
            >
            <span class='block text-sm text-gray-300 mt-1'>Списано</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Structured data for team member image -->
  <!-- eslint-disable-next-line astro/no-set-html-directive -->
  <script
    type='application/ld+json'
    set:html={JSON.stringify(
      generateTeamMemberImageSchema({
        name: manager.name,
        position: manager.fullPosition,
        photo: manager.photo,
        role: 'Руководитель компании',
        description: 'Эксперт в области банкротства физических лиц с 15-летним опытом работы',
        website: 'https://zerodolg.ru',
      }),
      null,
      2
    )}
  />
</section>
