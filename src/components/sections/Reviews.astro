import { getReviews } from '../../lib/content-service.js';

// Fetch reviews from CMS
const cmsReviews = await getReviews();

// Calculate review statistics
const calculateReviewStats = (reviews) => {
  const totalReviews = reviews.length;
  
  // Calculate average rating
  const totalRating = reviews.reduce((sum, review) => sum + review.rating, 0);
  const averageRating = totalReviews > 0 ? (totalRating / totalReviews).toFixed(1) : 0;
  
  // Calculate percentage of 5-star reviews
  const fiveStarCount = reviews.filter(review => review.rating === 5).length;
  const fiveStarsPercent = totalReviews > 0 ? Math.round((fiveStarCount / totalReviews) * 100) : 0;
  
  // Assume all reviews are verified for this example
  const verifiedPercent = 96; // Same as original
  
  return {
    total_reviews: totalReviews,
    average_rating: parseFloat(averageRating),
    five_stars_percent: fiveStarsPercent,
    verified_percent: verifiedPercent
  };
};

