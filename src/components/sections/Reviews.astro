---

<section class="reviews" id="reviews">
  <!-- Skip link for carousel navigation -->
  <a href="#reviews-content" class="skip-link skip-link--carousel" aria-label="Пропустить карусель отзывов">
    Пропустить карусель
  </a>
  
  <div class="container">
    <div class="section__header" id="reviews-content" tabindex="-1">
      <h2 class="section__title">Отзывы наших клиентов</h2>
      <p class="section__subtitle">
        Более 1400 человек уже решили свои долговые проблемы с нашей помощью
      </p>
      
      <div class="reviews__rating">
        <div class="reviews__stars">
          <span class="reviews__star reviews__star--filled">★</span>
          <span class="reviews__star reviews__star--filled">★</span>
          <span class="reviews__star reviews__star--filled">★</span>
          <span class="reviews__star reviews__star--filled">★</span>
          <span class="reviews__star reviews__star--filled">★</span>
        </div>
        <div class="reviews__rating-text">
          <span class="reviews__rating-number">{reviewsData.stats.average_rating}</span> из 5 • 
          <span class="reviews__rating-count">{reviewsData.stats.total_reviews} отзывов</span>
        </div>
      </div>
    </div>

    <!-- Stats Section -->
    <div class="reviews__stats">
      <div class="reviews__stats-grid">
        <div class="reviews__stat">
          <span class="reviews__stat-number" data-count-to={reviewsData.stats.total_reviews}>0</span>
          <span class="reviews__stat-label">Отзывов</span>
        </div>
        <div class="reviews__stat">
          <span class="reviews__stat-number" data-count-to={reviewsData.stats.average_rating} data-decimals="1">0</span>
          <span class="reviews__stat-label">Средняя оценка</span>
        </div>
        <div class="reviews__stat">
          <span class="reviews__stat-number" data-count-to={reviewsData.stats.five_stars_percent}>0</span>%
          <span class="reviews__stat-label">Пятизвёздочных</span>
        </div>
        <div class="reviews__stat">
          <span class="reviews__stat-number" data-count-to={reviewsData.stats.verified_percent}>0</span>%
          <span class="reviews__stat-label">Проверенных</span>
        </div>
      </div>
    </div>

    <!-- Trust Signals -->
    <div class="trust-signals">
      {Object.entries(reviewsData.trust_signals).map(([platform, data]) => (
        <a href={data.link} class="trust-signal" target="_blank" rel="noopener">
          <div class="trust-signal__logo">
            {platform === 'yandex' && '🟡'}
            {platform === 'google' && '🔴'}
            {platform === '2gis' && '🟢'}
          </div>
          <div class="trust-signal__rating">
            <div class="trust-signal__stars">
              {'★'.repeat(Math.floor(data.rating))}
              {data.rating % 1 !== 0 && '☆'}
            </div>
            <span class="trust-signal__count">{data.count} отзывов</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Reviews Carousel -->
    <div class="reviews__carousel" data-autoplay="true" role="region" aria-label="Отзывы клиентов" aria-roledescription="carousel">
      <!-- Progress bar for autoplay -->
      <div class="reviews__progress" aria-hidden="true">
        <div class="reviews__progress-bar"></div>
      </div>
      
      <div class="reviews__carousel-wrapper">
        <div class="reviews__carousel-track" role="list">
          {reviewsData.reviews.map((review, index) => (
            <article 
              class="reviews__carousel-slide review-card" 
              role="listitem"
              aria-label={`Отзыв ${index + 1} из ${reviewsData.reviews.length}`}
              data-review-id={review.id}
            >
              <div class="review-card__header">
                <div class="review-card__user">
                  <div class="review-card__avatar" aria-label={`Аватар клиента ${review.name}`} aria-hidden="true">
                    <span>{review.name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2)}</span>
                  </div>
                  <div class="review-card__info">
                    <h3 class="review-card__name">{review.name}</h3>
                    <div class="review-card__meta">
                      <span class="review-card__profession">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M20 7h-9m3 10H7m10-5H7"/>
                        </svg>
                        {review.profession}
                      </span>
                      <span class="review-card__location">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                          <circle cx="12" cy="10" r="3"/>
                        </svg>
                        {review.city}
                      </span>
                    </div>
                  </div>
                </div>
                <div class="review-card__rating" role="img" aria-label={`Рейтинг: ${review.rating} из 5 звёзд`}>
                  {'★'.repeat(review.rating)}{'☆'.repeat(5 - review.rating)}
                </div>
              </div>
              
              <div class="review-card__body">
                <!-- Новые структурированные блоки -->
                <div class="review-card__sections">
                  {review.problem && (
                    <div class="review-card__section review-card__section--problem">
                      <div class="review-card__section-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <circle cx="12" cy="12" r="10"/>
                          <line x1="12" y1="8" x2="12" y2="12"/>
                          <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                      </div>
                      <div class="review-card__section-content">
                        <h4 class="review-card__section-title">Проблема</h4>
                        <p class="review-card__section-text">{review.problem}</p>
                      </div>
                    </div>
                  )}
                  
                  {review.solution && (
                    <div class="review-card__section review-card__section--solution">
                      <div class="review-card__section-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                          <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                      </div>
                      <div class="review-card__section-content">
                        <h4 class="review-card__section-title">Решение</h4>
                        <p class="review-card__section-text">{review.solution}</p>
                      </div>
                    </div>
                  )}
                  
                  {review.result && (
                    <div class="review-card__section review-card__section--result">
                      <div class="review-card__section-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      </div>
                      <div class="review-card__section-content">
                        <h4 class="review-card__section-title">Результат</h4>
                        <p class="review-card__section-text">{review.result}</p>
                      </div>
                    </div>
                  )}
                </div>
                
                <!-- Ключевые метрики -->
                {(review.debt || review.duration) && (
                  <div class="review-card__metrics">
                    {review.debt && (
                      <div class="review-card__metric">
                        <div class="review-card__metric-value">{review.debt}</div>
                        <div class="review-card__metric-label">Сумма долга</div>
                      </div>
                    )}
                    {review.duration && (
                      <div class="review-card__metric">
                        <div class="review-card__metric-value">{review.duration}</div>
                        <div class="review-card__metric-label">Срок решения</div>
                      </div>
                    )}
                    {review.procedure && (
                      <div class="review-card__metric">
                        <div class="review-card__metric-value">{review.procedure}</div>
                        <div class="review-card__metric-label">Процедура</div>
                      </div>
                    )}
                  </div>
                )}
              </div>
              
              <div class="review-card__footer">
                {review.verified && (
                  <span class="review-card__verified" aria-label="Подтверждённый отзыв">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                      <path d="M8 0L9.5 2.5L12.5 1.5L12 4.5L15 5.5L13.5 8L15 10.5L12 11.5L12.5 14.5L9.5 13.5L8 16L6.5 13.5L3.5 14.5L4 11.5L1 10.5L2.5 8L1 5.5L4 4.5L3.5 1.5L6.5 2.5L8 0Z"/>
                      <path d="M6 8L7 9L10 6" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Проверено
                  </span>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
      
      <!-- Carousel Navigation -->
      <button 
        class="reviews__nav reviews__nav--prev" 
        aria-label="Показать предыдущие отзывы"
        type="button"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button 
        class="reviews__nav reviews__nav--next" 
        aria-label="Показать следующие отзывы"
        type="button"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      
      <!-- Carousel Indicators -->
      <div class="reviews__indicators" role="tablist" aria-label="Навигация по отзывам">
        {reviewsData.reviews.map((_, index) => (
          <button 
            class={`reviews__indicator ${index === 0 ? 'reviews__indicator--active' : ''}`}
            data-slide={index}
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            aria-label={`Отзыв ${index + 1}`}
            type="button"
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Load carousel script -->
<script src="/js/reviews-carousel.js" defer></script>

