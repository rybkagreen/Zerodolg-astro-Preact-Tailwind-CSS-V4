---
// Type definitions
interface Review {
  id: string;
  author: string;
  rating: number;
  date: string;
  text: string;
  verified: boolean;
  helpful: number;
  avatar?: string;
  tags?: string[];
}

interface ReviewStats {
  total: number;
  average: number;
  distribution: Record<number, number>;
}

// Static reviews data
const reviews: Review[] = [
  {
    id: "1",
    author: "Александр В.",
    rating: 5,
    date: "2024-03-15",
    text: "Отличная компания! Помогли решить проблему с долгами быстро и профессионально. Особенно порадовало внимательное отношение и поддержка на всех этапах.",
    verified: true,
    helpful: 24,
    tags: ["Профессионализм", "Быстро", "Поддержка"]
  },
  {
    id: "2",
    author: "Марина Б.",
    rating: 5,
    date: "2024-03-10",
    text: "Обратилась в безвыходной ситуации. Специалисты все объяснили, помогли собрать документы и провели через всю процедуру. Теперь могу спокойно жить!",
    verified: true,
    helpful: 18,
    tags: ["Помощь", "Консультация", "Результат"]
  },
  {
    id: "3",
    author: "Дмитрий К.",
    rating: 4,
    date: "2024-03-05",
    text: "Хорошая работа. Процесс занял чуть больше времени, чем ожидал, но результатом доволен. Долги списаны, можно начинать жизнь с чистого листа.",
    verified: true,
    helpful: 15,
    tags: ["Результат", "Новый старт"]
  },
  {
    id: "4",
    author: "Елена М.",
    rating: 5,
    date: "2024-02-28",
    text: "Спасибо огромное за помощь! Думала, что выхода нет, но вы доказали обратное. Все прошло гладко, юристы настоящие профессионалы.",
    verified: true,
    helpful: 21,
    tags: ["Профессионализм", "Благодарность"]
  },
  {
    id: "5",
    author: "Сергей Т.",
    rating: 5,
    date: "2024-02-20",
    text: "Рекомендую! Четкая работа, прозрачные условия, никаких скрытых платежей. Все как обещали, так и сделали.",
    verified: true,
    helpful: 19,
    tags: ["Честность", "Прозрачность", "Рекомендую"]
  },
  {
    id: "6",
    author: "Анна К.",
    rating: 5,
    date: "2024-02-15",
    text: "Благодаря вашей помощи смогла избавиться от долгов и сохранить квартиру. Вы дали мне второй шанс!",
    verified: true,
    helpful: 28,
    tags: ["Второй шанс", "Сохранили жилье"]
  }
];

// Calculate statistics
const calculateStats = (reviews: Review[]): ReviewStats => {
  const distribution: Record<number, number> = { 5: 0, 4: 0, 3: 0, 2: 0, 1: 0 };
  let totalRating = 0;
  
  reviews.forEach(review => {
    distribution[review.rating]++;
    totalRating += review.rating;
  });
  
  return {
    total: reviews.length,
    average: reviews.length > 0 ? totalRating / reviews.length : 0,
    distribution
  };
};

const stats = calculateStats(reviews);

// Format date for display
const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return new Intl.DateTimeFormat('ru-RU', { 
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  }).format(date);
};

// Get initials from name
const getInitials = (name: string) => {
  return name.split(' ')
    .map(word => word[0])
    .join('')
    .toUpperCase();
};
---

<section class="reviews" id="reviews">
  <div class="reviews__background">
    <div class="reviews__gradient"></div>
  </div>
  
  <div class="container">
    <!-- Header -->
    <div class="reviews__header">
      <h2 class="reviews__title">Отзывы наших клиентов</h2>
      <p class="reviews__subtitle">
        Более {stats.total * 230} человек уже решили свои долговые проблемы с нашей помощью
      </p>
    </div>

    <!-- Statistics -->
    <div class="reviews__stats">
      <div class="reviews__stats-summary">
        <div class="reviews__rating-score">
          <span class="reviews__rating-number">{stats.average.toFixed(1)}</span>
          <div class="reviews__rating-stars">
            {[...Array(5)].map((_, i) => (
              <svg 
                class={`reviews__star ${i < Math.floor(stats.average) ? 'reviews__star--filled' : ''}`}
                width="24" 
                height="24" 
                viewBox="0 0 24 24"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>
          <span class="reviews__rating-count">На основе {stats.total * 230} отзывов</span>
        </div>
        
        <div class="reviews__rating-bars">
          {[5, 4, 3, 2, 1].map(rating => {
            const percentage = stats.total > 0 ? (stats.distribution[rating] / stats.total) * 100 : 0;
            return (
              <div class="reviews__rating-bar">
                <span class="reviews__rating-label">{rating}★</span>
                <div class="reviews__rating-track">
                  <div 
                    class="reviews__rating-fill" 
                    style={`width: ${percentage}%`}
                  ></div>
                </div>
                <span class="reviews__rating-percent">{Math.round(percentage)}%</span>
              </div>
            );
          })}
        </div>
      </div>
    </div>

    <!-- Reviews Grid -->
    <div class="reviews__grid">
      {reviews.map((review, index) => (
        <article 
          class="review-card"
          data-index={index}
        >
          <div class="review-card__header">
            <div class="review-card__author">
              <div class="review-card__avatar">
                {review.avatar ? (
                  <img src={review.avatar} alt={review.author} loading="lazy" />
                ) : (
                  <span>{getInitials(review.author)}</span>
                )}
              </div>
              <div class="review-card__meta">
                <h3 class="review-card__name">{review.author}</h3>
                <time class="review-card__date">{formatDate(review.date)}</time>
              </div>
            </div>
            
            {review.verified && (
              <div class="review-card__verified">
                <svg width="16" height="16" viewBox="0 0 16 16">
                  <path d="M8 0L9.5 2.5L12.5 1.5L12 4.5L15 5.5L13.5 8L15 10.5L12 11.5L12.5 14.5L9.5 13.5L8 16L6.5 13.5L3.5 14.5L4 11.5L1 10.5L2.5 8L1 5.5L4 4.5L3.5 1.5L6.5 2.5L8 0Z" fill="currentColor"/>
                  <path d="M6 8L7 9L10 6" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Проверено
              </div>
            )}
          </div>
          
          <div class="review-card__rating">
            {[...Array(5)].map((_, i) => (
              <svg 
                class={`review-card__star ${i < review.rating ? 'review-card__star--filled' : ''}`}
                width="20" 
                height="20" 
                viewBox="0 0 24 24"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>
          
          <p class="review-card__text">{review.text}</p>
          
          {review.tags && review.tags.length > 0 && (
            <div class="review-card__tags">
              {review.tags.map(tag => (
                <span class="review-card__tag">{tag}</span>
              ))}
            </div>
          )}
          
          <div class="review-card__footer">
            <button class="review-card__helpful" data-review-id={review.id}>
              <svg width="16" height="16" viewBox="0 0 16 16">
                <path d="M14 9.5v5a1.5 1.5 0 01-1.5 1.5h-10A1.5 1.5 0 011 14.5v-5a1 1 0 011-1h2.5l1.8-5.4A1.5 1.5 0 017.7 2h.1a2.2 2.2 0 012.2 2.2v2.3h3a1 1 0 01.98 1.2l-.98 4.3z" stroke="currentColor" fill="none" stroke-width="1.5"/>
              </svg>
              Полезно ({review.helpful})
            </button>
          </div>
        </article>
      ))}
    </div>

    <!-- Load More Button -->
    <div class="reviews__actions">
      <button class="reviews__load-more">
        Показать еще отзывы
        <svg width="20" height="20" viewBox="0 0 20 20">
          <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  /* Container and Layout */
  .reviews {
    position: relative;
    padding: 80px 0;
    overflow: hidden;
  }

  .container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Animated Gradient Background */
  .reviews__background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
  }

  .reviews__gradient {
    position: absolute;
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    background: linear-gradient(
      135deg,
      rgba(99, 102, 241, 0.03) 0%,
      rgba(139, 92, 246, 0.05) 25%,
      rgba(217, 70, 239, 0.03) 50%,
      rgba(99, 102, 241, 0.05) 75%,
      rgba(139, 92, 246, 0.03) 100%
    );
    animation: gradientShift 20s ease infinite;
  }

  @keyframes gradientShift {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg);
    }
    25% {
      transform: translate(-10%, -10%) rotate(90deg);
    }
    50% {
      transform: translate(0, -20%) rotate(180deg);
    }
    75% {
      transform: translate(10%, -10%) rotate(270deg);
    }
  }

  /* Header */
  .reviews__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .reviews__title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    margin: 0 0 16px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .reviews__subtitle {
    font-size: 18px;
    color: #64748b;
    margin: 0;
  }

  /* Statistics */
  .reviews__stats {
    background: rgba(99, 102, 241, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(99, 102, 241, 0.15);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 48px;
    box-shadow: 0 10px 40px rgba(99, 102, 241, 0.1);
  }

  .reviews__stats-summary {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 48px;
    align-items: center;
  }

  .reviews__rating-score {
    text-align: center;
  }

  .reviews__rating-number {
    font-size: 48px;
    font-weight: 700;
    color: #ffffff;
    display: block;
  }

  .reviews__rating-stars {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin: 8px 0;
  }

  .reviews__star {
    fill: rgba(255, 255, 255, 0.3);
    transition: fill 0.3s ease;
  }

  .reviews__star--filled {
    fill: #fde047;
  }

  .reviews__rating-count {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
  }

  .reviews__rating-bars {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .reviews__rating-bar {
    display: grid;
    grid-template-columns: 20px 1fr 40px;
    gap: 12px;
    align-items: center;
  }

  .reviews__rating-label {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.9);
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .reviews__rating-track {
    height: 8px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    overflow: hidden;
  }

  .reviews__rating-fill {
    height: 100%;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0.6) 100%);
    border-radius: 4px;
    transition: width 1s ease;
    animation: fillAnimation 1s ease-out;
  }

  @keyframes fillAnimation {
    from {
      width: 0 !important;
    }
  }

  .reviews__rating-percent {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.9);
    text-align: right;
  }

  /* Reviews Grid */
  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 24px;
    margin-bottom: 48px;
  }

  /* Review Card */
  .review-card {
    background: rgba(99, 102, 241, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(99, 102, 241, 0.15);
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 4px 20px rgba(99, 102, 241, 0.1);
    transition: all 0.3s ease;
    animation: slideUp 0.6s ease-out backwards;
  }

  .review-card:hover {
    transform: translateY(-4px);
    background: rgba(99, 102, 241, 0.12);
    border-color: rgba(99, 102, 241, 0.25);
    box-shadow: 0 8px 30px rgba(99, 102, 241, 0.2);
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .review-card:nth-child(1) { animation-delay: 0.1s; }
  .review-card:nth-child(2) { animation-delay: 0.2s; }
  .review-card:nth-child(3) { animation-delay: 0.3s; }
  .review-card:nth-child(4) { animation-delay: 0.4s; }
  .review-card:nth-child(5) { animation-delay: 0.5s; }
  .review-card:nth-child(6) { animation-delay: 0.6s; }

  .review-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .review-card__author {
    display: flex;
    gap: 12px;
  }

  .review-card__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.7) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #667eea;
    font-weight: 600;
    font-size: 18px;
    flex-shrink: 0;
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .review-card__avatar img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  .review-card__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .review-card__name {
    font-size: 16px;
    font-weight: 600;
    color: #ffffff;
    margin: 0;
  }

  .review-card__date {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
  }

  .review-card__verified {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    color: #86efac;
    font-weight: 500;
  }

  .review-card__verified svg {
    flex-shrink: 0;
  }

  .review-card__rating {
    display: flex;
    gap: 2px;
    margin-bottom: 16px;
  }

  .review-card__star {
    fill: rgba(255, 255, 255, 0.3);
  }

  .review-card__star--filled {
    fill: #fde047;
  }

  .review-card__text {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.95);
    margin: 0 0 16px;
  }

  .review-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .review-card__tag {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(5px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.9);
  }

  .review-card__footer {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: 16px;
  }

  .review-card__helpful {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.9);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .review-card__helpful:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.3);
    color: #ffffff;
  }

  .review-card__helpful svg {
    stroke: rgba(255, 255, 255, 0.9);
  }

  /* Actions */
  .reviews__actions {
    text-align: center;
  }

  .reviews__load-more {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: rgba(99, 102, 241, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 2px solid rgba(99, 102, 241, 0.2);
    border-radius: 12px;
    font-size: 16px;
    font-weight: 500;
    color: #667eea;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .reviews__load-more:hover {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .reviews {
      padding: 60px 0;
    }

    .reviews__stats-summary {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .reviews__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .review-card {
      padding: 20px;
    }
  }
</style>

<script>
  // Initialize animations on scroll
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        
        // Animate rating bars
        const ratingFills = entry.target.querySelectorAll('.reviews__rating-fill');
        ratingFills.forEach(fill => {
          const width = fill.style.width;
          fill.style.width = '0';
          setTimeout(() => {
            fill.style.width = width;
          }, 100);
        });
      }
    });
  }, observerOptions);

  // Observe review cards
  document.querySelectorAll('.review-card').forEach(card => {
    observer.observe(card);
  });

  // Observe stats section
  const statsSection = document.querySelector('.reviews__stats');
  if (statsSection) {
    observer.observe(statsSection);
  }

  // Handle helpful button clicks
  document.querySelectorAll('.review-card__helpful').forEach(button => {
    button.addEventListener('click', function() {
      const reviewId = this.dataset.reviewId;
      const countMatch = this.textContent?.match(/\d+/);
      if (countMatch) {
        const currentCount = parseInt(countMatch[0]);
        this.innerHTML = `
          <svg width="16" height="16" viewBox="0 0 16 16">
            <path d="M14 9.5v5a1.5 1.5 0 01-1.5 1.5h-10A1.5 1.5 0 011 14.5v-5a1 1 0 011-1h2.5l1.8-5.4A1.5 1.5 0 017.7 2h.1a2.2 2.2 0 012.2 2.2v2.3h3a1 1 0 01.98 1.2l-.98 4.3z" stroke="currentColor" fill="currentColor" stroke-width="1.5"/>
          </svg>
          Полезно (${currentCount + 1})
        `;
        this.style.background = '#f0f9ff';
        this.style.borderColor = '#3b82f6';
        this.style.color = '#3b82f6';
        this.disabled = true;
      }
    });
  });

  // Handle load more button
  const loadMoreBtn = document.querySelector('.reviews__load-more');
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function() {
      // Here you would typically load more reviews
      // For demo, we'll just show a message
      this.textContent = 'Загрузка...';
      setTimeout(() => {
        this.textContent = 'Все отзывы загружены';
        this.disabled = true;
        this.style.opacity = '0.5';
      }, 1000);
    });
  }
</script>