---
import LeadMagnetsComponent from '../../islands/shared/interactive/lead-magnets.tsx';
import Icon from '@shared/ui/Icon.astro';
import SectionSemantics from '../../shared/ui/SectionSemantics.astro';

const leadMagnets = [
  {
    type: 'consultation',
    badge: 'Рекомендуем',
    badgeType: 'primary',
    icon: 'consultation',
    title: 'Персональная консультация',
    description:
      '30-минутный разбор вашей ситуации с юристом по банкротству. Получите экспертную оценку и план действий.',
    features: ['Анализ документов', 'Оценка перспектив', 'Стратегия решения'],
    buttonText: 'Записаться на консультацию',
    note: 'Бесплатно • Без обязательств',
    modalType: 'consultation',
    trackEvent: 'lead_consultation',
  },
  {
    type: 'calculator',
    icon: 'calculator',
    title: 'Калькулятор банкротства',
    description:
      'Узнайте точную стоимость процедуры банкротства. Получите персональный расчет без регистрации.',
    features: ['Расчет всех расходов', 'Сроки процедуры', 'Нюансы вашего дела'],
    buttonText: 'Рассчитать стоимость',
    note: 'Быстро • Точно • Бесплатно',
    modalType: 'calculator',
    trackEvent: 'lead_calculator',
  },
  {
    type: 'guide',
    badge: 'Популярно',
    badgeType: 'secondary',
    icon: 'guide',
    title: 'Гид по банкротству 2025',
    description:
      'Скачайте бесплатный гид с 47 страницами полезной информации. Актуальные изменения в законах.',
    features: ['Алгоритм действий', 'Шаблоны документов', 'Чек-листы'],
    buttonText: 'Скачать гид',
    note: 'PDF • 47 страниц • Актуально',
    modalType: 'guide-download',
    trackEvent: 'lead_guide',
  },
  {
    type: 'checklist',
    badge: 'Новое',
    badgeType: 'success',
    icon: 'checklist',
    title: 'Чек-лист подготовки',
    description:
      'Полный список документов и действий для успешного банкротства. Ничего не забудьте!',
    features: ['Список документов', 'Порядок действий', 'Частые ошибки'],
    buttonText: 'Получить чек-лист',
    note: 'Готовый список • Проверено на практике',
    modalType: 'checklist-download',
    trackEvent: 'lead_checklist',
  },
  {
    type: 'webinar',
    icon: 'webinar',
    title: 'Бесплатный вебинар',
    description:
      'Еженедельный вебинар "Банкротство без ошибок". Разбор реальных кейсов и ответы на вопросы.',
    features: ['Живое общение', 'Реальные кейсы', 'Q&A сессия'],
    buttonText: 'Записаться на вебинар',
    note: 'Каждый четверг • 19:00 МСК',
    modalType: 'webinar-registration',
    trackEvent: 'lead_webinar',
  },
  {
    type: 'assessment',
    badge: 'Эксклюзив',
    badgeType: 'premium',
    icon: 'assessment',
    title: 'Экспресс-оценка дела',
    description:
      'Получите предварительную оценку перспектив вашего дела за 24 часа. Бесплатно и конфиденциально.',
    features: ['Анализ за 24 часа', 'Персональные рекомендации', 'Оценка рисков'],
    buttonText: 'Получить оценку',
    note: 'Результат через 24 часа • Бесплатно',
    modalType: 'assessment',
    trackEvent: 'lead_assessment',
  },
];

const ctaData = {
  title: 'Начните путь к финансовой свободе',
  subtitle: 'Выберите удобный способ получения помощи',
  buttonText: 'Начать банкротство',
  buttonIcon: 'arrow',
  modalType: 'consultation',
};
---

<!-- Lead Magnets Section -->
<section
  class='lead-magnets-section section-padding relative overflow-hidden -mt-24 md:-mt-32 lg:-mt-40'
  aria-labelledby='lead-magnets-title'
  style='isolation: isolate; z-index: -1; mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 100%);'
>
  <!-- Reset background to white to override any previous section's background -->
  <div class='absolute inset-0 bg-white z-0'></div>

  <!-- Background with financial relief pattern -->
  <div
    class='absolute inset-0 bg-gradient-to-br from-blue-50/40 via-white/60 to-indigo-50/30 z-10'
    style='mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);'
  >
  </div>

  <!-- Pastel paint strokes background pattern -->
  <div
    class='absolute inset-0 opacity-25 z-20'
    style='background-image: url("/patterns/watercolor_learning_materials.png"); background-size: cover; background-position: center; background-repeat: no-repeat; mask-image: linear-gradient(to bottom, black 0%, black 70%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 70%, transparent 100%);'
  >
  </div>

  <!-- Subtle dot pattern overlay -->
  <div
    class='absolute inset-0 opacity-5 z-30'
    style='background-image: url("/patterns/hero-dots.svg"); background-size: 80px 80px; mask-image: linear-gradient(to bottom, black 0%, black 70%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 70%, transparent 100%);'
  >
  </div>

  <div class='container-custom relative z-40'>
    <!-- Section Header -->
    <header class='text-center mb-16 md:mb-20 lg:mb-24'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-blue-100/80 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-blue-700 ring-1 ring-blue-200/50 mb-8'
      >
        <svg class='h-4 w-4 text-blue-600' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'
          ></path>
        </svg>
        Полезные материалы
      </div>
      <h2
        id='lead-magnets-title'
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 tracking-tight leading-tight'
      >
        Полезные ресурсы
      </h2>
      <p class='text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-medium'>
        Получите экспертную помощь и базу знаний для успешного банкротства
      </p>
    </header>

    <!-- Lead Magnets Grid -->
    <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 lg:gap-10 mb-16'>
      {
        leadMagnets.map((magnet, index) => {
          const gradientClasses = [
            'from-blue-500 to-purple-600',
            'from-emerald-500 to-teal-600',
            'from-orange-500 to-red-600',
            'from-violet-500 to-pink-600',
            'from-cyan-500 to-blue-600',
            'from-indigo-500 to-purple-600',
          ];
          const bgGradients = [
            'bg-gradient-to-br from-blue-50 to-purple-50',
            'bg-gradient-to-br from-emerald-50 to-teal-50',
            'bg-gradient-to-br from-orange-50 to-red-50',
            'bg-gradient-to-br from-violet-50 to-pink-50',
            'bg-gradient-to-br from-cyan-50 to-blue-50',
            'bg-gradient-to-br from-indigo-50 to-purple-50',
          ];

          const gradient = gradientClasses[index % gradientClasses.length];
          const bgGradient = bgGradients[index % bgGradients.length];

          return (
            <div class='group relative overflow-hidden rounded-2xl bg-white/60 backdrop-blur-md border border-white/50 shadow-md shadow-slate-900/10 p-6 transition-all duration-500 ease-out transform hover:scale-[1.02] hover:-translate-y-2 hover:bg-white/85 hover:shadow-xl hover:shadow-slate-900/15 hover:border-slate-200/60 min-h-[420px] flex flex-col justify-between'>
              {/* Gradient accent top border */}
              <div
                class:list={[
                  `absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r ${gradient} scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left rounded-t-2xl`,
                ]}
              />

              {/* Badge */}
              {magnet.badge && (
                <div
                  class:list={[
                    `absolute top-4 right-4 px-3 py-1 rounded-full text-xs font-semibold backdrop-blur-sm`,
                    {
                      'bg-blue-500/90 text-white': magnet.badgeType === 'primary',
                      'bg-slate-200/90 text-slate-800': magnet.badgeType === 'secondary',
                      'bg-green-500/90 text-white': magnet.badgeType === 'success',
                      'bg-purple-500/90 text-white': magnet.badgeType === 'premium',
                    },
                  ]}
                >
                  {magnet.badge}
                </div>
              )}

              {/* Content */}
              <div class='mt-8 flex-grow flex flex-col'>
                {/* Icon */}
                <div class='flex-shrink-0 mb-4'>
                  <div
                    class:list={[
                      `relative w-12 h-12 mx-auto rounded-xl bg-gradient-to-br ${gradient} p-2.5 shadow-lg group-hover:shadow-xl group-hover:scale-110 transition-all duration-500`,
                    ]}
                  >
                    {/* Inner glow effect */}
                    <div class='absolute inset-0 rounded-xl bg-gradient-to-br from-white/30 to-transparent pointer-events-none' />
                    <div class='w-full h-full flex items-center justify-center text-white'>
                      <Icon name={magnet.icon} />
                    </div>
                  </div>
                </div>

                {/* Title */}
                <h3 class='text-xl font-bold text-slate-900 mb-3 group-hover:text-blue-700 transition-colors duration-300 text-center'>
                  {magnet.title}
                </h3>

                {/* Description */}
                <p class='text-slate-600 mb-6 text-center leading-relaxed flex-grow'>
                  {magnet.description}
                </p>

                {/* Features List */}
                <ul class='mb-6 space-y-2'>
                  {magnet.features.map((feature) => (
                    <li class='flex items-start text-sm'>
                      <svg
                        class='w-4 h-4 text-emerald-500 flex-shrink-0 mt-0.5 mr-2'
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        stroke-width='2.5'
                      >
                        <path d='M20 6L9 17l-5-5' />
                      </svg>
                      <span class='text-slate-700 leading-relaxed'>{feature}</span>
                    </li>
                  ))}
                </ul>

                {/* Button */}
                <button
                  class:list={[
                    `w-full py-3 px-6 bg-gradient-to-r ${gradient} text-white rounded-xl hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all duration-300 font-semibold text-sm flex items-center justify-center group-hover:scale-105`,
                  ]}
                  data-modal={magnet.modalType}
                  data-track={magnet.trackEvent}
                >
                  <span>{magnet.buttonText}</span>
                  <span class='ml-2 loader hidden'>
                    <svg
                      class='animate-spin h-4 w-4 text-white'
                      viewBox='0 0 24 24'
                      aria-label='Загрузка'
                      role='status'
                    >
                      <circle
                        cx='12'
                        cy='12'
                        r='10'
                        fill='none'
                        stroke='currentColor'
                        stroke-width='2'
                      />
                    </svg>
                  </span>
                </button>

                {/* Note */}
                <p class='text-xs text-slate-500 mt-3 text-center leading-tight'>{magnet.note}</p>
              </div>

              {/* Hover background gradient */}
              <div
                class:list={[
                  `absolute inset-0 ${bgGradient} opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10`,
                ]}
              />
            </div>
          );
        })
      }
    </div>

    {/* CTA Section */}
    <div
      class='relative bg-white/60 backdrop-blur-md rounded-2xl border border-white/50 shadow-lg p-8 md:p-12 text-center'
    >
      {/* Gradient background overlay */}
      <div class='absolute inset-0 bg-gradient-to-r from-blue-600/90 to-indigo-600/90 rounded-2xl'>
      </div>

      <div class='relative z-10'>
        <h3 class='text-2xl md:text-3xl font-bold text-white mb-3'>{ctaData.title}</h3>
        <p class='text-lg text-blue-100 mb-6'>{ctaData.subtitle}</p>
        <button
          class='inline-flex items-center px-6 py-3 bg-white text-blue-600 font-semibold rounded-xl hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-blue-600 transition-all duration-300 hover:scale-105 shadow-lg backdrop-blur-sm'
          data-modal={ctaData.modalType}
        >
          <span>{ctaData.buttonText}</span>
          <span class='ml-2' aria-hidden='true'>
            <Icon name={ctaData.buttonIcon} />
          </span>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- Семантические данные для SEO -->
<SectionSemantics sectionId='leadmagnets' />

<!-- Load interactive logic -->
<LeadMagnetsComponent client:load />
