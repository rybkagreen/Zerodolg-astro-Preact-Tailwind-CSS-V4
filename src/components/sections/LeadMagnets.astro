---

<section class="lead-magnets section section--light" id="lead-magnets" aria-labelledby="lead-magnets-title">
  <div class="container">
    <header class="section__header section__header--center">
      <h2 id="lead-magnets-title" class="section__title">
        Получите бесплатные материалы для самостоятельного изучения
      </h2>
      <p class="section__subtitle">
        Профессиональные инструменты и знания для решения вопросов с долгами
      </p>
    </header>
    
    <!-- Lead Magnets Grid -->
    <div class="lead-magnets__grid" role="list" aria-label="Профессиональные инструменты">
      {leadMagnets.map((magnet) => (
        <article class={`lead-card ${magnet.isUrgent ? 'lead-card--urgent' : ''}`} data-type={magnet.type}>
          <div class="lead-card__header">
            {magnet.badge && (
              <span class={`lead-card__badge lead-card__badge--${magnet.badgeType}`}>
                {magnet.badge}
              </span>
            )}
            {/* eslint-disable-next-line astro/no-set-html-directive -- Safe: SVG content from static array */}
            <div class="lead-card__icon" set:html={magnet.icon} />
          </div>
          
          <div class="lead-card__content">
            <h3 class="lead-card__title">{magnet.title}</h3>
            <p class="lead-card__description">
              {magnet.description}
            </p>
            
            <ul class="lead-card__features">
              {magnet.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
          </div>
          
          <div class="lead-card__footer">
            <button 
              class={`lead-card__button ${magnet.buttonClass === 'urgent' ? 'lead-card__button--urgent' : magnet.badge === 'Рекомендуем' ? 'lead-card__button--primary' : ''}`}
              data-modal={magnet.modalType}
              data-track={magnet.trackEvent}
            >
              {magnet.buttonText}
            </button>
            <span class="lead-card__note">{magnet.note}</span>
          </div>
        </article>
      ))}
    </div>
    
    <!-- Bottom CTA -->
    <div class="lead-magnets__cta">
      <div class="lead-magnets__cta-content">
        <h3 class="lead-magnets__cta-title">
          Нужна помощь в выборе?
        </h3>
        <p class="lead-magnets__cta-text">
          Наши специалисты помогут подобрать оптимальное решение для вашей ситуации
        </p>
        <button 
          class="lead-magnets__cta-button"
          data-modal="consultation"
          data-track="lead_bottom_consultation"
        >
          <span>Получить консультацию</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

