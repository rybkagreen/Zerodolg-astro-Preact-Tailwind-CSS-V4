---
import LeadMagnetsComponent from '../../islands/shared/interactive/lead-magnets.tsx';
import Icon from '@shared/ui/Icon.astro';

const leadMagnets = [
  {
    type: 'consultation',
    badge: 'Рекомендуем',
    badgeType: 'primary',
    icon: 'consultation',
    title: 'Персональная консультация',
    description:
      '30-минутный разбор вашей ситуации с юристом по банкротству. Получите экспертную оценку и план действий.',
    features: ['Анализ документов', 'Оценка перспектив', 'Стратегия решения'],
    buttonText: 'Записаться на консультацию',
    note: 'Бесплатно • Без обязательств',
    modalType: 'consultation',
    trackEvent: 'lead_consultation',
  },
  {
    type: 'calculator',
    icon: 'calculator',
    title: 'Калькулятор банкротства',
    description:
      'Узнайте точную стоимость процедуры банкротства. Получите персональный расчет без регистрации.',
    features: ['Расчет всех расходов', 'Сроки процедуры', 'Нюансы вашего дела'],
    buttonText: 'Рассчитать стоимость',
    note: 'Быстро • Точно • Бесплатно',
    modalType: 'calculator',
    trackEvent: 'lead_calculator',
  },
  {
    type: 'guide',
    badge: 'Популярно',
    badgeType: 'secondary',
    icon: 'guide',
    title: 'Гид по банкротству 2025',
    description:
      'Скачайте бесплатный гид с 47 страницами полезной информации. Актуальные изменения в законах.',
    features: ['Алгоритм действий', 'Шаблоны документов', 'Чек-листы'],
    buttonText: 'Скачать гид',
    note: 'PDF • 47 страниц • Актуально',
    modalType: 'guide-download',
    trackEvent: 'lead_guide',
  },
  {
    type: 'checklist',
    badge: 'Новое',
    badgeType: 'success',
    icon: 'checklist',
    title: 'Чек-лист подготовки',
    description:
      'Полный список документов и действий для успешного банкротства. Ничего не забудьте!',
    features: ['Список документов', 'Порядок действий', 'Частые ошибки'],
    buttonText: 'Получить чек-лист',
    note: 'Готовый список • Проверено на практике',
    modalType: 'checklist-download',
    trackEvent: 'lead_checklist',
  },
  {
    type: 'webinar',
    icon: 'webinar',
    title: 'Бесплатный вебинар',
    description:
      'Еженедельный вебинар "Банкротство без ошибок". Разбор реальных кейсов и ответы на вопросы.',
    features: ['Живое общение', 'Реальные кейсы', 'Q&A сессия'],
    buttonText: 'Записаться на вебинар',
    note: 'Каждый четверг • 19:00 МСК',
    modalType: 'webinar-registration',
    trackEvent: 'lead_webinar',
  },
  {
    type: 'assessment',
    badge: 'Эксклюзив',
    badgeType: 'premium',
    icon: 'assessment',
    title: 'Экспресс-оценка дела',
    description:
      'Получите предварительную оценку перспектив вашего дела за 24 часа. Бесплатно и конфиденциально.',
    features: ['Анализ за 24 часа', 'Персональные рекомендации', 'Оценка рисков'],
    buttonText: 'Получить оценку',
    note: 'Результат через 24 часа • Бесплатно',
    modalType: 'assessment',
    trackEvent: 'lead_assessment',
  },
];

const ctaData = {
  title: 'Начните путь к финансовой свободе',
  subtitle: 'Выберите удобный способ получения помощи',
  buttonText: 'Начать банкротство',
  buttonIcon: 'arrow',
  modalType: 'consultation',
};
---

<!-- Lead Magnets Section -->
<section
  class='py-16 lg:py-24 relative bg-gradient-to-b from-gray-50 to-white'
  aria-labelledby='lead-magnets-title'
>
  <!-- Decorative Elements -->
  <div
    class='absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none'
    aria-hidden='true'
  >
    <div
      class='absolute top-1/4 left-1/4 w-32 h-32 rounded-full bg-accent opacity-10 animate-pulse'
    >
    </div>
    <div
      class='absolute top-3/4 right-1/4 w-48 h-48 rounded-full bg-primary opacity-10 animate-pulse delay-300'
    >
    </div>
    <div
      class='absolute bottom-1/4 left-1/2 w-40 h-40 rounded-full bg-success opacity-10 animate-pulse delay-700'
    >
    </div>
  </div>

  <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
    <!-- Section Header -->
    <header class='text-center mb-12'>
      <h2 id='lead-magnets-title' class='text-3xl md:text-4xl font-bold text-gray-900 mb-4'>
        Полезные материалы
      </h2>
      <p class='text-xl text-gray-600 max-w-3xl mx-auto'>
        Получите бесплатные ресурсы для начала процедуры банкротства
      </p>
    </header>

    <!-- Lead Magnets Grid -->
    <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16'>
      {
        leadMagnets.map((magnet) => (
          <div
            class:list={[
              `bg-white rounded-xl shadow-lg p-6 border relative overflow-hidden `,
              {
                'border-blue-500': magnet.type === 'consultation',
                'border-green-500': magnet.type === 'calculator',
                'border-purple-500': magnet.type === 'guide',
                'border-orange-500': magnet.type === 'checklist',
                'border-indigo-500': magnet.type === 'webinar',
                'border-pink-500': magnet.type === 'assessment',
                'border-gray-200': ![
                  'consultation',
                  'calculator',
                  'guide',
                  'checklist',
                  'webinar',
                  'assessment',
                ].includes(magnet.type),
              },
            ]}
          >
            {/* Badge */}
            {magnet.badge && (
              <div
                class:list={[
                  `absolute top-4 right-4 px-3 py-1 rounded-full text-xs font-semibold`,
                  {
                    'bg-blue-500 text-white': magnet.badgeType === 'primary',
                    'bg-gray-200 text-gray-800': magnet.badgeType === 'secondary',
                    'bg-green-500 text-white': magnet.badgeType === 'success',
                    'bg-purple-500 text-white': magnet.badgeType === 'premium',
                  },
                ]}
              >
                {magnet.badge}
              </div>
            )}

            {/* Content */}
            <div class='mt-8'>
              {/* Icon */}
              <div
                class='w-12 h-12 flex items-center justify-center rounded-lg bg-gray-100 text-gray-700 mb-6'
                aria-hidden='true'
              >
                <Icon name={magnet.icon} />
              </div>

              {/* Title */}
              <h3 class='text-xl font-bold text-gray-900 mb-3'>{magnet.title}</h3>

              {/* Description */}
              <p class='text-gray-600 mb-6'>{magnet.description}</p>

              {/* Features List */}
              <ul class='mb-6'>
                {magnet.features.map((feature) => (
                  <li class='flex items-start mb-2'>
                    <svg
                      class='w-5 h-5 text-green-500 flex-shrink-0 mt-0.5 mr-2'
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke='currentColor'
                      stroke-width='2'
                    >
                      <path d='M20 6L9 17l-5-5' />
                    </svg>
                    <span class='text-gray-700'>{feature}</span>
                  </li>
                ))}
              </ul>

              {/* Button */}
              <button
                class='w-full py-3 px-6 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors duration-200 font-medium flex items-center justify-center'
                data-modal={magnet.modalType}
                data-track={magnet.trackEvent}
              >
                <span>{magnet.buttonText}</span>
                <span class='ml-2 loader hidden'>
                  <svg
                    class='animate-spin h-5 w-5 text-white'
                    viewBox='0 0 50 50'
                    aria-label='Загрузка'
                    role='status'
                  >
                    <circle cx='25' cy='25' r='20' fill='none' stroke-width='5' />
                  </svg>
                </span>
              </button>

              {/* Note */}
              <p class='text-xs text-gray-500 mt-3 text-center'>{magnet.note}</p>
            </div>
          </div>
        ))
      }
    </div>

    {/* CTA Section */}
    <div class='bg-gradient-to-r from-blue-500 to-indigo-600 rounded-2xl p-8 md:p-12 text-center'>
      <div>
        <h3 class='text-2xl md:text-3xl font-bold text-white mb-3'>{ctaData.title}</h3>
        <p class='text-lg text-blue-100 mb-6'>{ctaData.subtitle}</p>
        <button
          class='inline-flex items-center px-6 py-3 bg-white text-blue-600 font-semibold rounded-lg hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-blue-600 transition-colors duration-200'
          data-modal={ctaData.modalType}
        >
          <span>{ctaData.buttonText}</span>
          <span class='ml-2' aria-hidden='true'>
            <Icon name={ctaData.buttonIcon} />
          </span>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- Load interactive logic -->
<LeadMagnetsComponent client:load />
