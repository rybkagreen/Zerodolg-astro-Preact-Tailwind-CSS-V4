---
import SectionSemantics from '../../shared/ui/SectionSemantics.astro';
import SectionDivider from '../../shared/ui/SectionDivider.astro';

// Benefits data - advantages of working with the company
const benefits = [
  {
    id: 'experience',
    icon: 'experience',
    title: '15 лет опыта',
    description: 'Специализируемся на банкротстве с 2008 года',
  },
  {
    id: 'success',
    icon: 'success',
    title: '98% выигранных дел',
    description: 'Из 500+ клиентов только 10 не получили списание',
  },
  {
    id: 'guarantee',
    icon: 'guarantee',
    title: 'Гарантия результата',
    description: 'Прописываем обязательства в договоре',
  },
  {
    id: 'payment',
    icon: 'payment',
    title: 'Рассрочка оплаты',
    description: 'Платите частями без переплат и процентов',
  },
  {
    id: 'support',
    icon: 'support',
    title: 'Полное сопровождение',
    description: 'Берем на себя все этапы процедуры',
  },
  {
    id: 'confidential',
    icon: 'confidential',
    title: 'Конфиденциальность',
    description:
      'Уважаем конфиденциальность наших клиентов и понимаем деликатность процесса банкротства',
  },
];
---

<section
  class='benefits-section section-padding relative overflow-hidden'
  id='benefits'
  aria-labelledby='benefits-title'
>
  <!-- Reset background to white to override any previous section's background -->
  <div class='absolute inset-0 bg-white z-0'></div>

  <!-- Background with financial relief pattern -->
  <div class='absolute inset-0 bg-gradient-to-br from-blue-50/40 via-white/60 to-indigo-50/30 z-10'>
  </div>

  <!-- Pastel paint strokes background pattern -->
  <div
    class='absolute inset-0 opacity-25 z-20'
    style='background-image: url("/patterns/benefits-pattern.png"); background-size: cover; background-position: center; background-repeat: no-repeat;'
  >
  </div>

  <!-- Subtle dot pattern overlay -->
  <div
    class='absolute inset-0 opacity-5 z-30'
    style='background-image: url("/patterns/hero-dots.svg"); background-size: 80px 80px;'
  >
  </div>

  <div class='container-custom relative z-40'>
    <header class='text-center mb-16 md:mb-20 lg:mb-24'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-blue-100/80 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-blue-700 ring-1 ring-blue-200/50 mb-8'
      >
        <svg class='h-4 w-4 text-blue-600' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M13 10V3L4 14h7v7l9-11h-7z'></path>
        </svg>
        Наши преимущества
      </div>
      <h2
        id='benefits-title'
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 tracking-tight leading-tight'
      >
        Почему выбирают именно нас
      </h2>
      <p class='text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-medium'>
        Мы создали идеальную систему для решения ваших финансовых проблем
      </p>
    </header>

    <!-- Benefits Grid -->
    <div
      class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 lg:gap-10'
      role='list'
      aria-label='Преимущества работы с нами'
    >
      {
        benefits.map((benefit, index) => {
          const gradientClasses = [
            'from-blue-500 to-purple-600',
            'from-emerald-500 to-teal-600',
            'from-orange-500 to-red-600',
            'from-violet-500 to-pink-600',
            'from-cyan-500 to-blue-600',
            'from-indigo-500 to-purple-600',
          ];
          const hoverColors = [
            'hover:text-blue-600',
            'hover:text-emerald-600',
            'hover:text-orange-600',
            'hover:text-violet-600',
            'hover:text-cyan-600',
            'hover:text-indigo-600',
          ];
          const bgGradients = [
            'bg-gradient-to-br from-blue-50 to-purple-50',
            'bg-gradient-to-br from-emerald-50 to-teal-50',
            'bg-gradient-to-br from-orange-50 to-red-50',
            'bg-gradient-to-br from-violet-50 to-pink-50',
            'bg-gradient-to-br from-cyan-50 to-blue-50',
            'bg-gradient-to-br from-indigo-50 to-purple-50',
          ];

          const gradient = gradientClasses[index % gradientClasses.length];
          const hoverColor = hoverColors[index % hoverColors.length];
          const bgGradient = bgGradients[index % bgGradients.length];

          return (
            <article
              class:list={`group relative overflow-hidden rounded-2xl 
                    bg-white/60 backdrop-blur-md border border-white/50 
                    shadow-md shadow-slate-900/10 
                    p-3 md:p-4 lg:p-5 text-center cursor-pointer 
                    transition-all duration-500 ease-out transform hover:scale-[1.02] hover:-translate-y-2 
                    hover:bg-white/85 hover:shadow-xl hover:shadow-slate-900/15 
                    hover:border-slate-200/60 benefits-card benefits-card-${index + 1} 
                    focus:outline-none focus:ring-4 focus:ring-blue-500/50 focus:ring-offset-2 
                    focus:scale-[1.02] focus:-translate-y-2 min-h-[160px] md:min-h-[170px] lg:min-h-[180px] 
                    flex flex-col justify-between aspect-[4/3]`}
              role='listitem'
              tabindex='0'
              aria-labelledby={`benefit-title-${index + 1}`}
              aria-describedby={`benefit-desc-${index + 1}`}
              data-index={`0${index + 1}`}
              style={`animation-delay: ${(index + 1) * 150}ms`}
              onkeydown={`if(event.key==='Enter'||event.key===' '){event.preventDefault();this.click();}`}
            >
              {/* Card number indicator */}
              <div
                class='absolute top-4 right-4 w-8 h-8 rounded-full bg-gradient-to-br from-slate-100/90 to-slate-200/90 
                        opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center backdrop-blur-sm'
              >
                <span class='text-xs font-bold text-slate-700'>{`0${index + 1}`}</span>
              </div>

              {/* Gradient accent top border */}
              <div
                class:list={`absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r ${gradient} 
                         scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left rounded-t-2xl`}
              />

              {/* Icon Container */}
              <div class='flex-shrink-0 mb-2'>
                <div
                  class:list={`relative w-8 h-8 md:w-10 md:h-10 lg:w-12 lg:h-12 mx-auto rounded-lg md:rounded-xl 
                           bg-gradient-to-br ${gradient} p-2 md:p-2.5 shadow-lg 
                           group-hover:shadow-xl group-hover:scale-110 transition-all duration-500`}
                >
                  {/* Inner glow effect */}
                  <div class='absolute inset-0 rounded-lg md:rounded-xl bg-gradient-to-br from-white/30 to-transparent pointer-events-none' />

                  {/* SVG Icons */}
                  {benefit.icon === 'experience' && (
                    <svg
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke='currentColor'
                      class='w-full h-full object-contain filter brightness-0 invert'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z'
                      />
                    </svg>
                  )}
                  {benefit.icon === 'success' && (
                    <svg
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke='currentColor'
                      class='w-full h-full object-contain filter brightness-0 invert'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M13 7h8m0 0v8m0-8l-8 8-4-4-6 6'
                      />
                    </svg>
                  )}
                  {benefit.icon === 'guarantee' && (
                    <svg
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke='currentColor'
                      class='w-full h-full object-contain filter brightness-0 invert'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
                      />
                    </svg>
                  )}
                  {benefit.icon === 'payment' && (
                    <svg
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke='currentColor'
                      class='w-full h-full object-contain filter brightness-0 invert'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z'
                      />
                    </svg>
                  )}
                  {benefit.icon === 'support' && (
                    <svg
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke='currentColor'
                      class='w-full h-full object-contain filter brightness-0 invert'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z'
                      />
                    </svg>
                  )}
                  {benefit.icon === 'confidential' && (
                    <svg
                      viewBox='0 0 24 24'
                      fill='none'
                      stroke='currentColor'
                      class='w-full h-full object-contain filter brightness-0 invert'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z'
                      />
                    </svg>
                  )}
                </div>
              </div>

              {/* Content */}
              <div class='relative z-10 flex-grow flex flex-col justify-center'>
                <h3
                  id={`benefit-title-${index + 1}`}
                  class:list={`text-xl md:text-2xl lg:text-xl font-bold text-slate-900 mb-3 
                        transition-colors duration-300 ${hoverColor} leading-tight tracking-tight`}
                >
                  {benefit.title}
                </h3>
                <p
                  id={`benefit-desc-${index + 1}`}
                  class='text-base md:text-lg lg:text-base text-slate-700 leading-relaxed font-medium opacity-90'
                >
                  {benefit.description}
                </p>
              </div>

              {/* Hover background gradient */}
              <div
                class:list={`absolute inset-0 ${bgGradient} opacity-0 
                         group-hover:opacity-100 transition-opacity duration-500 -z-10`}
              />
            </article>
          );
        })
      }
    </div>
  </div>

  <!-- Разделитель для плавного перехода к следующей секции -->
  <SectionDivider type='curve' position='bottom' height='50px' color='white' opacity={0.8} />
</section>

<!-- Семантические данные для SEO -->
<SectionSemantics sectionId='benefits' />

<!-- Enhanced Animation Styles for Benefits -->
<style>
  /* Entrance animations with staggered delay */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .benefits-card {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }

  .benefits-card-1 {
    animation-delay: 150ms;
  }
  .benefits-card-2 {
    animation-delay: 300ms;
  }
  .benefits-card-3 {
    animation-delay: 450ms;
  }
  .benefits-card-4 {
    animation-delay: 600ms;
  }
  .benefits-card-5 {
    animation-delay: 750ms;
  }
  .benefits-card-6 {
    animation-delay: 900ms;
  }

  /* Enhanced glassmorphism effect */
  .benefits-card {
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .benefits-card {
      animation: none;
      opacity: 1;
    }

    .benefits-card:hover {
      transform: none;
    }
  }

  /* Print styles */
  @media print {
    .benefits-card {
      break-inside: avoid;
      box-shadow: none;
      border: 1px solid #e2e8f0;
      background: white !important;
    }
  }

  /* Ripple effect for click feedback */
  .benefits-ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(59, 130, 246, 0.3);
    transform: scale(0);
    animation: ripple 0.6s linear;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes ripple {
    to {
      transform: scale(2);
      opacity: 0;
    }
  }

  /* Enhanced visibility state */
  .benefits-card.animate-visible {
    opacity: 1 !important;
  }
</style>
