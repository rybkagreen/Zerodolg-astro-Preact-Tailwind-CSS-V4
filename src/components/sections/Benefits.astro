---
// Benefits data - advantages of working with the company
const benefits = [
  {
    id: 'experience',
    icon: 'experience',
    title: '15 лет опыта',
    description: 'Специализируемся на банкротстве с 2008 года',
  },
  {
    id: 'success',
    icon: 'success',
    title: '98% выигранных дел',
    description: 'Из 500+ клиентов только 10 не получили списание',
  },
  {
    id: 'guarantee',
    icon: 'guarantee',
    title: 'Гарантия результата',
    description: 'Прописываем обязательства в договоре',
  },
  {
    id: 'payment',
    icon: 'payment',
    title: 'Рассрочка оплаты',
    description: 'Платите частями без переплат и процентов',
  },
  {
    id: 'support',
    icon: 'support',
    title: 'Полное сопровождение',
    description: 'Берем на себя все этапы процедуры',
  },
  {
    id: 'confidential',
    icon: 'confidential',
    title: 'Конфиденциальность',
    description: 'Соблюдаем адвокатскую тайну',
  },
];
---

<section class="py-16 md:py-24 bg-gradient-to-b from-gray-50 to-white" id="benefits" aria-labelledby="benefits-title">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <header class="text-center mb-12 md:mb-16">
      <h2 id="benefits-title" class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Преимущества работы с нами</h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10" role="list" aria-label="Преимущества работы с нами">
      {
        benefits.map((benefit) => (
          <article class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow duration-300" role="listitem">
            <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-blue-50 text-blue-600 mb-4" aria-hidden="true">
              {/* Using inline SVG for icons - you can replace with actual icon component */}
              {benefit.icon === 'experience' && (
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                </svg>
              )}
              {benefit.icon === 'success' && (
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                  <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z" />
                </svg>
              )}
              {benefit.icon === 'guarantee' && (
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                  <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z" />
                </svg>
              )}
              {benefit.icon === 'payment' && (
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                  <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z" />
                </svg>
              )}
              {benefit.icon === 'support' && (
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                  <path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-7 12h-2v-2h2v2zm0-4h-2V6h2v4z" />
                </svg>
              )}
              {benefit.icon === 'confidential' && (
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                  <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
