---
// Benefits data - advantages of working with the company
const benefits = [
  {
    id: 'experience',
    icon: 'experience',
    title: '15 лет опыта',
    description: 'Специализируемся на банкротстве с 2008 года',
  },
  {
    id: 'success',
    icon: 'success',
    title: '98% выигранных дел',
    description: 'Из 500+ клиентов только 10 не получили списание',
  },
  {
    id: 'guarantee',
    icon: 'guarantee',
    title: 'Гарантия результата',
    description: 'Прописываем обязательства в договоре',
  },
  {
    id: 'payment',
    icon: 'payment',
    title: 'Рассрочка оплаты',
    description: 'Платите частями без переплат и процентов',
  },
  {
    id: 'support',
    icon: 'support',
    title: 'Полное сопровождение',
    description: 'Берем на себя все этапы процедуры',
  },
  {
    id: 'confidential',
    icon: 'confidential',
    title: 'Конфиденциальность',
    description: 'Соблюдаем адвокатскую тайну',
  },
];
---

<section
  class='py-20 md:py-28 bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50 relative overflow-hidden'
  id='benefits'
  aria-labelledby='benefits-title'
>
  <!-- Background decoration -->
  <div class='absolute inset-0 opacity-30'>
    <div
      class='absolute top-20 left-10 w-72 h-72 bg-blue-300/20 rounded-full blur-3xl animate-pulse'
    >
    </div>
    <div
      class='absolute bottom-20 right-10 w-96 h-96 bg-purple-300/20 rounded-full blur-3xl animate-pulse delay-1000'
    >
    </div>
  </div>

  <div class='relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    <header class='text-center mb-16 md:mb-20'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-blue-100/80 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-blue-700 ring-1 ring-blue-200/50 mb-8'
      >
        <svg class='h-4 w-4 text-blue-600' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M13 10V3L4 14h7v7l9-11h-7z'></path>
        </svg>
        Наши преимущества
      </div>
      <h2
        id='benefits-title'
        class='text-4xl md:text-5xl lg:text-6xl font-black text-slate-900 mb-6 leading-tight'
      >
        <span
          class='bg-gradient-to-r from-slate-900 via-blue-900 to-indigo-900 bg-clip-text text-transparent'
        >
          Почему выбирают именно нас
        </span>
      </h2>
      <p class='text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed'>
        Мы создали идеальную систему для решения ваших финансовых проблем
      </p>
    </header>

    <div
      class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10'
      role='list'
      aria-label='Преимущества работы с нами'
    >
      {
        benefits.map((benefit, index) => {
          const gradientClasses = [
            'from-blue-500 to-indigo-600',
            'from-green-500 to-emerald-600',
            'from-purple-500 to-pink-600',
            'from-orange-500 to-red-600',
            'from-cyan-500 to-teal-600',
            'from-violet-500 to-purple-600',
          ];
          const gradient = gradientClasses[index % gradientClasses.length];

          return (
            <article
              class='group relative overflow-hidden rounded-3xl bg-white/80 backdrop-blur-sm p-8 shadow-xl ring-1 ring-slate-200/50 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:ring-slate-300/50'
              role='listitem'
            >
              {/* Background gradient overlay on hover */}
              <div
                class:list={`absolute inset-0 bg-gradient-to-br ${gradient} opacity-0 transition-opacity duration-500 group-hover:opacity-5`}
              />

              {/* Floating decoration */}
              <div class='absolute -top-6 -right-6 h-24 w-24 rounded-full bg-gradient-to-br from-white/50 to-transparent opacity-0 blur-xl transition-opacity duration-500 group-hover:opacity-100' />

              <div class='relative'>
                {/* Enhanced icon container */}
                <div class='mb-6'>
                  <div
                    class:list={`inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br ${gradient} shadow-lg transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3`}
                  >
                    {benefit.icon === 'experience' && (
                      <svg
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        class='w-8 h-8 text-white'
                      >
                        <path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2'
                          d='M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z'
                        />
                      </svg>
                    )}
                    {benefit.icon === 'success' && (
                      <svg
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        class='w-8 h-8 text-white'
                      >
                        <path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2'
                          d='M13 7h8m0 0v8m0-8l-8 8-4-4-6 6'
                        />
                      </svg>
                    )}
                    {benefit.icon === 'guarantee' && (
                      <svg
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        class='w-8 h-8 text-white'
                      >
                        <path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2'
                          d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
                        />
                      </svg>
                    )}
                    {benefit.icon === 'payment' && (
                      <svg
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        class='w-8 h-8 text-white'
                      >
                        <path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2'
                          d='M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z'
                        />
                      </svg>
                    )}
                    {benefit.icon === 'support' && (
                      <svg
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        class='w-8 h-8 text-white'
                      >
                        <path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2'
                          d='M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z'
                        />
                      </svg>
                    )}
                    {benefit.icon === 'confidential' && (
                      <svg
                        viewBox='0 0 24 24'
                        fill='none'
                        stroke='currentColor'
                        class='w-8 h-8 text-white'
                      >
                        <path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2'
                          d='M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z'
                        />
                      </svg>
                    )}
                  </div>
                </div>

                {/* Content */}
                <div class='space-y-4'>
                  <h3 class='text-2xl font-bold text-slate-900 group-hover:text-slate-800 transition-colors duration-300'>
                    {benefit.title}
                  </h3>
                  <p class='text-slate-600 leading-relaxed group-hover:text-slate-700 transition-colors duration-300'>
                    {benefit.description}
                  </p>
                </div>

                {/* Decorative arrow */}
                <div class='mt-6 flex items-center text-slate-400 group-hover:text-slate-600 transition-colors duration-300'>
                  <span class='text-sm font-medium'>Подробнее</span>
                  <svg
                    class='ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1'
                    fill='none'
                    viewBox='0 0 24 24'
                    stroke='currentColor'
                  >
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      stroke-width='2'
                      d='M9 5l7 7-7 7'
                    />
                  </svg>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
