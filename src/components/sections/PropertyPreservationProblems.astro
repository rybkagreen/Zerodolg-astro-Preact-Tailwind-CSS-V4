---
// PropertyPreservationProblems.astro - Секция проблем для страницы банкротства с сохранением имущества
// Синяя/фиолетовая цветовая схема для единообразия с лендингом

import SectionSemantics from '../../shared/ui/SectionSemantics.astro';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Проблемы, которые решает банкротство с сохранением имущества
const propertyProblems = [
  {
    icon: '/icons/solution/01-shield-check.svg',
    title: 'Боитесь потерять квартиру',
    description: 'Единственное жилье защищено законом — квартира останется у вас навсегда',
    gradient: 'from-blue-500 to-indigo-600',
    hoverColor: 'hover:text-blue-600',
    bgGradient: 'bg-gradient-to-br from-blue-50 to-indigo-50',
    highlight: 'Жилье под защитой закона',
  },
  {
    icon: '/icons/solution/03-home-shield.svg',
    title: 'Риск изъятия автомобиля',
    description: 'Защитим автомобиль, необходимый для работы или семейных нужд',
    gradient: 'from-purple-500 to-pink-600',
    hoverColor: 'hover:text-purple-600',
    bgGradient: 'bg-gradient-to-br from-purple-50 to-pink-50',
    highlight: 'Авто для работы защищен',
  },
  {
    icon: '/icons/solution/02-bell-off.svg',
    title: 'Растущие долги и штрафы',
    description: 'Спишем все долги и остановим бесконечное начисление процентов и пеней',
    gradient: 'from-indigo-500 to-blue-600',
    hoverColor: 'hover:text-indigo-600',
    bgGradient: 'bg-gradient-to-br from-indigo-50 to-blue-50',
    highlight: 'Полное списание долгов',
  },
  {
    icon: '/icons/solution/04-handshake.svg',
    title: 'Давление коллекторов',
    description: 'Остановим звонки, угрозы и визиты коллекторов — юридическая защита с первого дня',
    gradient: 'from-cyan-500 to-teal-600',
    hoverColor: 'hover:text-cyan-600',
    bgGradient: 'bg-gradient-to-br from-cyan-50 to-teal-50',
    highlight: 'Коллекторы замолчат навсегда',
  },
];
---

<section
  class:list={`property-problems-section relative py-20 md:py-28 lg:py-36 overflow-hidden ${className}`}
  id='property-problems'
  aria-labelledby='property-problems-title'
>
  <!-- Background -->
  <div class='absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-indigo-50/40'></div>

  <!-- Geometric pattern overlay -->
  <div
    class='absolute inset-0 opacity-5'
    style="background-image: url('/patterns/hero-dots.svg'); background-size: 120px 120px;"
  >
  </div>

  <div class='relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
    <!-- Section Header -->
    <header class='text-center mb-16 md:mb-20 lg:mb-24'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-blue-100/80 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-blue-700 ring-1 ring-blue-200/50 mb-8'
      >
        <svg class='h-4 w-4 text-blue-600' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
          ></path>
        </svg>
        Защита имущества при банкротстве
      </div>
      <h2
        id='property-problems-title'
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 tracking-tight leading-tight'
      >
        Какие проблемы мы решаем
      </h2>
      <p class='text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-medium'>
        Банкротство с сохранением имущества — спишите долги и защитите ценности
      </p>
    </header>

    <!-- Problems Grid -->
    <div
      class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 lg:gap-10'
      role='list'
      aria-label='Проблемы, которые решает банкротство с сохранением имущества'
    >
      {
        propertyProblems.map((problem, index) => (
          <article
            class:list={`group relative overflow-hidden rounded-2xl 
                bg-white/70 backdrop-blur-md border border-white/60 
                shadow-lg shadow-slate-900/10 
                p-6 md:p-7 lg:p-8 text-center cursor-pointer 
                transition-all duration-700 ease-out transform hover:scale-[1.03] hover:-translate-y-3
                hover:bg-white/90 hover:shadow-2xl hover:shadow-blue-900/20 
                hover:border-blue-200/70 property-problems-card property-problems-card-${index + 1} 
                focus:outline-none focus:ring-4 focus:ring-blue-500/50 focus:ring-offset-2 
                focus:scale-[1.03] focus:-translate-y-3 min-h-[200px] md:min-h-[220px] lg:min-h-[240px] 
                flex flex-col justify-between`}
            role='listitem'
            tabindex='0'
            aria-labelledby={`property-problem-title-${index + 1}`}
            aria-describedby={`property-problem-desc-${index + 1}`}
            data-index={`0${index + 1}`}
            style={`animation-delay: ${(index + 1) * 200}ms`}
            onkeydown={`if(event.key==='Enter'||event.key===' '){event.preventDefault();this.click();}`}
          >
            {/* Card number indicator */}
            <div class='absolute top-4 right-4 w-10 h-10 rounded-full bg-gradient-to-br from-blue-100/90 to-indigo-200/90 opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center backdrop-blur-sm'>
              <span class='text-sm font-bold text-blue-700'>{`0${index + 1}`}</span>
            </div>

            {/* Gradient accent border */}
            <div
              class:list={`absolute top-0 left-0 right-0 h-2 bg-gradient-to-r ${problem.gradient}
                     scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left rounded-t-2xl`}
            />

            {/* Content Container */}
            <div class='flex-1 flex flex-col'>
              {/* Icon Container */}
              <div class='flex-shrink-0 mb-4'>
                <div
                  class:list={`relative w-16 h-16 md:w-18 md:h-18 lg:w-20 lg:h-20 mx-auto rounded-xl 
                         bg-gradient-to-br ${problem.gradient} p-4 shadow-lg 
                         group-hover:shadow-2xl group-hover:scale-110 transition-all duration-700 
                         group-hover:rotate-3`}
                >
                  {/* Inner glow effect */}
                  <div class='absolute inset-0 rounded-xl bg-gradient-to-br from-white/30 to-transparent pointer-events-none' />

                  {/* Icon */}
                  <img
                    src={problem.icon}
                    alt={`Иконка для ${problem.title.toLowerCase()}`}
                    class='w-full h-full object-contain filter brightness-0 invert'
                    role='img'
                    loading='lazy'
                  />
                </div>
              </div>

              {/* Text Content */}
              <div class='flex-1 flex flex-col justify-center'>
                <h3
                  id={`property-problem-title-${index + 1}`}
                  class:list={`text-xl md:text-2xl lg:text-xl font-bold text-slate-900 mb-3 
                      transition-colors duration-300 ${problem.hoverColor} leading-tight tracking-tight`}
                >
                  {problem.title}
                </h3>
                <p
                  id={`property-problem-desc-${index + 1}`}
                  class='text-base md:text-lg lg:text-base text-slate-700 leading-relaxed font-medium opacity-90 mb-3'
                >
                  {problem.description}
                </p>

                {/* Highlight badge */}
                <div class='mt-auto'>
                  <div
                    class:list={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold
                              bg-gradient-to-r ${problem.gradient} text-white shadow-md
                              opacity-0 group-hover:opacity-100 transition-all duration-500 transform 
                              translate-y-2 group-hover:translate-y-0`}
                  >
                    <svg class='w-3 h-3 mr-1' fill='currentColor' viewBox='0 0 20 20'>
                      <path
                        fill-rule='evenodd'
                        d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z'
                        clip-rule='evenodd'
                      />
                    </svg>
                    {problem.highlight}
                  </div>
                </div>
              </div>
            </div>

            {/* Hover background gradient */}
            <div
              class:list={`absolute inset-0 ${problem.bgGradient} opacity-0 
                     group-hover:opacity-100 transition-opacity duration-700 -z-10 rounded-2xl`}
            />
          </article>
        ))
      }
    </div>

    <!-- Bottom CTA Section -->
    <div class='mt-16 md:mt-20 lg:mt-24 text-center'>
      <div
        class='bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl p-8 md:p-10 border border-blue-200/50 shadow-lg'
      >
        <h3 class='text-2xl md:text-3xl font-bold text-slate-900 mb-4'>
          Защитите свое имущество прямо сейчас!
        </h3>
        <p class='text-lg text-slate-600 mb-6 leading-relaxed'>
          Каждый день промедления увеличивает риск потери имущества. Начните процедуру сегодня —
          сохраните квартиру и ценности завтра.
        </p>
        <a
          href='#consultation-form'
          class='btn-primary inline-flex items-center gap-2 px-8 py-4 text-lg bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700'
        >
          <svg class='w-5 h-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              stroke-width='2'
              d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
            ></path>
          </svg>
          Получить бесплатную консультацию
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Semantic data for SEO -->
<SectionSemantics sectionId='property-problems' />

<style>
  /* Enhanced Animation Styles */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(60px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .property-problems-card {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }

  .property-problems-card-1 {
    animation-delay: 200ms;
  }
  .property-problems-card-2 {
    animation-delay: 400ms;
  }
  .property-problems-card-3 {
    animation-delay: 600ms;
  }
  .property-problems-card-4 {
    animation-delay: 800ms;
  }

  /* Enhanced glassmorphism effect */
  .property-problems-card {
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .property-problems-card {
      animation: none;
      opacity: 1;
    }

    .property-problems-card:hover {
      transform: none;
    }
  }

  /* Focus styles for accessibility */
  .property-problems-card:focus {
    outline: 3px solid rgba(59, 130, 246, 0.5);
    outline-offset: 2px;
  }

  /* Print styles */
  @media print {
    .property-problems-card {
      break-inside: avoid;
      box-shadow: none;
      border: 1px solid #3b82f6;
      background: white !important;
    }
  }
</style>
