---
// RestructuringProblems.astro - Секция проблем для страницы реструктуризации
// Изумрудная цветовая схема и семантика для сохранения имущества

import SectionSemantics from '../../shared/ui/SectionSemantics.astro';
import SectionDivider from '../../shared/ui/SectionDivider.astro';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Проблемы, которые решает реструктуризация (с акцентом на сохранение имущества)
const restructuringProblems = [
  {
    icon: '/icons/solution/01-shield-check.svg',
    title: 'Риск потери квартиры',
    description: 'Сохраним ваше единственное или дополнительное жилье при любых долгах',
    gradient: 'from-emerald-500 to-teal-600',
    hoverColor: 'hover:text-emerald-600',
    bgGradient: 'bg-gradient-to-br from-emerald-50 to-teal-50',
    highlight: 'Квартира останется у вас',
  },
  {
    icon: '/icons/solution/02-bell-off.svg',
    title: 'Огромные проценты по долгам',
    description: 'Снизим процентную ставку до ключевой ставки ЦБ и заморозим штрафы',
    gradient: 'from-teal-500 to-cyan-600',
    hoverColor: 'hover:text-teal-600',
    bgGradient: 'bg-gradient-to-br from-teal-50 to-cyan-50',
    highlight: 'До 21% вместо 40-60%',
  },
  {
    icon: '/icons/solution/03-home-shield.svg',
    title: 'Угроза изъятия автомобиля',
    description: 'Защитим ваш транспорт и другие ценности от принудительной продажи',
    gradient: 'from-cyan-500 to-blue-600',
    hoverColor: 'hover:text-cyan-600',
    bgGradient: 'bg-gradient-to-br from-cyan-50 to-blue-50',
    highlight: 'Авто и ценности в безопасности',
  },
  {
    icon: '/icons/solution/04-handshake.svg',
    title: 'Давление коллекторов',
    description: 'Остановим звонки коллекторов и исполнительные производства',
    gradient: 'from-blue-500 to-indigo-600',
    hoverColor: 'hover:text-blue-600',
    bgGradient: 'bg-gradient-to-br from-blue-50 to-indigo-50',
    highlight: 'Юридическая защита с первого дня',
  },
];
---

<section
  class:list={`restructuring-problems-section relative py-20 md:py-28 lg:py-36 overflow-hidden ${className}`}
  id='restructuring-problems'
  aria-labelledby='restructuring-problems-title'
>
  <!-- Background -->
  <div class='absolute inset-0 bg-gradient-to-br from-emerald-50 via-white to-teal-50/40'></div>

  <!-- Watercolor background pattern -->
  <div
    class='absolute inset-0 opacity-20 mix-blend-multiply'
    style="background-image: url('/patterns/restructuring-problems-pattern.png'); background-size: cover; background-position: center; background-repeat: no-repeat;"
  >
  </div>

  <!-- Geometric pattern overlay -->
  <div
    class='absolute inset-0 opacity-5'
    style="background-image: url('/patterns/hero-dots.svg'); background-size: 120px 120px;"
  >
  </div>

  <div class='relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
    <!-- Section Header -->
    <header class='text-center mb-16 md:mb-20 lg:mb-24'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-emerald-100/80 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-emerald-700 ring-1 ring-emerald-200/50 mb-8'
      >
        <svg class='h-4 w-4 text-emerald-600' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
          ></path>
        </svg>
        Защищаем ваше имущество
      </div>
      <h2
        id='restructuring-problems-title'
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 tracking-tight leading-tight'
      >
        От каких угроз защищаем
      </h2>
      <p class='text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-medium'>
        Реструктуризация долгов — ваш щит от потери имущества и финансовых угроз
      </p>
    </header>

    <!-- Problems Grid -->
    <div
      class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 lg:gap-10'
      role='list'
      aria-label='Проблемы, от которых защищает реструктуризация долгов'
    >
      {
        restructuringProblems.map((problem, index) => (
          <article
            class:list={`group relative overflow-hidden rounded-2xl 
                bg-white/70 backdrop-blur-md border border-white/60 
                shadow-lg shadow-slate-900/10 
                p-6 md:p-7 lg:p-8 text-center cursor-pointer 
                transition-all duration-700 ease-out transform hover:scale-[1.03] hover:-translate-y-3
                hover:bg-white/90 hover:shadow-2xl hover:shadow-emerald-900/20 
                hover:border-emerald-200/70 restructuring-problems-card restructuring-problems-card-${index + 1} 
                focus:outline-none focus:ring-4 focus:ring-emerald-500/50 focus:ring-offset-2 
                focus:scale-[1.03] focus:-translate-y-3 min-h-[200px] md:min-h-[220px] lg:min-h-[240px] 
                flex flex-col justify-between`}
            role='listitem'
            tabindex='0'
            aria-labelledby={`restructuring-problem-title-${index + 1}`}
            aria-describedby={`restructuring-problem-desc-${index + 1}`}
            data-index={`0${index + 1}`}
            style={`animation-delay: ${(index + 1) * 200}ms`}
            onkeydown={`if(event.key==='Enter'||event.key===' '){event.preventDefault();this.click();}`}
          >
            {/* Card number indicator */}
            <div class='absolute top-4 right-4 w-10 h-10 rounded-full bg-gradient-to-br from-emerald-100/90 to-teal-200/90 opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center backdrop-blur-sm'>
              <span class='text-sm font-bold text-emerald-700'>{`0${index + 1}`}</span>
            </div>

            {/* Gradient accent border */}
            <div
              class:list={`absolute top-0 left-0 right-0 h-2 bg-gradient-to-r ${problem.gradient}
                     scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left rounded-t-2xl`}
            />

            {/* Content Container */}
            <div class='flex-1 flex flex-col'>
              {/* Icon Container */}
              <div class='flex-shrink-0 mb-4'>
                <div
                  class:list={`relative w-16 h-16 md:w-18 md:h-18 lg:w-20 lg:h-20 mx-auto rounded-xl 
                         bg-gradient-to-br ${problem.gradient} p-4 shadow-lg 
                         group-hover:shadow-2xl group-hover:scale-110 transition-all duration-700 
                         group-hover:rotate-3`}
                >
                  {/* Inner glow effect */}
                  <div class='absolute inset-0 rounded-xl bg-gradient-to-br from-white/30 to-transparent pointer-events-none' />

                  {/* Icon */}
                  <img
                    src={problem.icon}
                    alt={`Иконка для ${problem.title.toLowerCase()}`}
                    class='w-full h-full object-contain filter brightness-0 invert'
                    role='img'
                    loading='lazy'
                  />
                </div>
              </div>

              {/* Text Content */}
              <div class='flex-1 flex flex-col justify-center'>
                <h3
                  id={`restructuring-problem-title-${index + 1}`}
                  class:list={`text-xl md:text-2xl lg:text-xl font-bold text-slate-900 mb-3 
                      transition-colors duration-300 ${problem.hoverColor} leading-tight tracking-tight`}
                >
                  {problem.title}
                </h3>
                <p
                  id={`restructuring-problem-desc-${index + 1}`}
                  class='text-base md:text-lg lg:text-base text-slate-700 leading-relaxed font-medium opacity-90 mb-3'
                >
                  {problem.description}
                </p>

                {/* Highlight badge */}
                <div class='mt-auto'>
                  <div
                    class:list={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold
                              bg-gradient-to-r ${problem.gradient} text-white shadow-md
                              opacity-0 group-hover:opacity-100 transition-all duration-500 transform 
                              translate-y-2 group-hover:translate-y-0`}
                  >
                    <svg class='w-3 h-3 mr-1' fill='currentColor' viewBox='0 0 20 20'>
                      <path
                        fill-rule='evenodd'
                        d='M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z'
                        clip-rule='evenodd'
                      />
                    </svg>
                    {problem.highlight}
                  </div>
                </div>
              </div>
            </div>

            {/* Hover background gradient */}
            <div
              class:list={`absolute inset-0 ${problem.bgGradient} opacity-0 
                     group-hover:opacity-100 transition-opacity duration-700 -z-10 rounded-2xl`}
            />
          </article>
        ))
      }
    </div>

    <!-- Bottom CTA Section -->
    <div class='mt-16 md:mt-20 lg:mt-24 text-center'>
      <div
        class='bg-gradient-to-r from-emerald-50 to-teal-50 rounded-2xl p-8 md:p-10 border border-emerald-200/50 shadow-lg'
      >
        <h3 class='text-2xl md:text-3xl font-bold text-slate-900 mb-4'>
          Не рискуйте своим имуществом!
        </h3>
        <p class='text-lg text-slate-600 mb-6 leading-relaxed'>
          Каждый месяц промедления увеличивает долги на 2-5%. Начните реструктуризацию сегодня —
          сохраните завтра.
        </p>
        <button
          class='btn-primary inline-flex items-center gap-2 px-8 py-4 text-lg bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700'
          data-modal='consultation'
        >
          <svg class='w-5 h-5' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              stroke-width='2'
              d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
            ></path>
          </svg>
          Защитить имущество сейчас
        </button>
      </div>
    </div>
  </div>

  <!-- Section divider -->
  <SectionDivider type='wave' position='bottom' height='60px' color='white' opacity={0.9} />
</section>

<!-- Semantic data for SEO -->
<SectionSemantics sectionId='restructuring-problems' />

<style>
  /* Enhanced Animation Styles */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(60px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .restructuring-problems-card {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }

  .restructuring-problems-card-1 {
    animation-delay: 200ms;
  }
  .restructuring-problems-card-2 {
    animation-delay: 400ms;
  }
  .restructuring-problems-card-3 {
    animation-delay: 600ms;
  }
  .restructuring-problems-card-4 {
    animation-delay: 800ms;
  }

  /* Enhanced glassmorphism effect */
  .restructuring-problems-card {
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  /* Reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .restructuring-problems-card {
      animation: none;
      opacity: 1;
    }

    .restructuring-problems-card:hover {
      transform: none;
    }
  }

  /* Focus styles for accessibility */
  .restructuring-problems-card:focus {
    outline: 3px solid rgba(16, 185, 129, 0.5);
    outline-offset: 2px;
  }

  /* Print styles */
  @media print {
    .restructuring-problems-card {
      break-inside: avoid;
      box-shadow: none;
      border: 1px solid #10b981;
      background: white !important;
    }
  }
</style>
