---
// SolutionChoice.astro - Секция выбора между банкротством и реструктуризацией
// Актуализированная версия на октябрь 2024
import SectionSemantics from '../../shared/ui/SectionSemantics.astro';
import BankruptcyTabSwitcher from '../../islands/sections/BankruptcyTabSwitcher.tsx';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Актуальные данные на октябрь 2024
const solutionData = {
  bankruptcy: {
    title: 'Банкротство',
    subtitle: 'Полное списание долгов за 4-6 месяцев',
    price: '150 000 ₽',
    monthlyPayment: 'от 25 000 ₽/мес',
    duration: '4-6 месяцев',
    successRate: '98%',
    advantages: [
      '100% списание всех долгов',
      'Быстрое решение (4-6 месяцев)',
      'Защита от коллекторов с первого дня',
      'Остановка начисления процентов',
    ],
    considerations: [
      'Продажа имущества (кроме единственного жилья)',
      'Ограничения на 5 лет при получении кредитов',
    ],
    suitable: 'При долгах от 300 тыс ₽ и отсутствии стабильного дохода',
    gradient: 'from-blue-500 to-purple-600',
    bgGradient: 'from-blue-50 to-purple-50',
    hoverColor: 'hover:text-blue-600',
  },
  propertyPreservation: {
    title: 'Банкротство с сохранением',
    subtitle: 'Защитите имущество законными способами',
    price: 'от 150 000 ₽',
    monthlyPayment: 'от 25 000 ₽/мес',
    duration: '6-9 месяцев',
    successRate: '98%',
    advantages: [
      'Единственное жилье защищено законом',
      'Сохранение бытовой техники и личных вещей',
      'Прожиточный минимум остается у вас',
      'Инструменты для работы защищены',
    ],
    considerations: [
      'Требуется обоснование необходимости имущества',
      'Процедура на 2-3 месяца дольше обычного банкротства',
    ],
    suitable: 'При наличии единственного жилья и желании сохранить ценности',
    gradient: 'from-indigo-500 to-blue-600',
    bgGradient: 'from-indigo-50 to-blue-50',
    hoverColor: 'hover:text-indigo-600',
  },
  restructuring: {
    title: 'Реструктуризация',
    subtitle: 'Льготные условия выплаты с сохранением имущества',
    price: 'от 89 000 ₽',
    monthlyPayment: 'от 3 700 ₽/мес',
    duration: 'до 4 лет',
    successRate: '61%',
    advantages: [
      'Сохранение всего имущества',
      'Льготные условия платежей',
      'Заморозка штрафов и пеней',
      'Возможность досрочного погашения',
    ],
    considerations: ['Необходимость выплатить весь долг', 'Требуется стабильный доход от 45 000 ₽'],
    suitable: 'При стабильном доходе и желании сохранить имущество',
    gradient: 'from-emerald-500 to-teal-600',
    bgGradient: 'from-emerald-50 to-teal-50',
    hoverColor: 'hover:text-emerald-600',
  },
};
---

<!-- Solution Choice Section -->
<section
  class:list={`solution-choice-section section-padding relative overflow-hidden ${className}`}
  id='solution-choice'
  aria-labelledby='solution-choice-title'
>
  <!-- Background gradient - NO MASK (always visible) -->
  <div
    class='absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-blue-50/40'
    style='z-index: -12; pointer-events: none;'
  >
  </div>

  <!-- Watercolor pattern - double mask (fade-in at top, fade-out at bottom) -->
  <div
    class='absolute inset-0 opacity-25'
    style="background-image: url('/patterns/comparison-pattern-v1.png'); background-size: cover; background-position: center; background-repeat: no-repeat; z-index: -11; pointer-events: none; mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);"
  >
  </div>

  <!-- Dot pattern -->
  <div
    class='absolute inset-0 opacity-5'
    style="background-image: url('/patterns/hero-dots.svg'); background-size: 120px 120px; z-index: -10; pointer-events: none;"
  >
  </div>

  <div class='container-custom relative z-10'>
    <!-- Section Header -->
    <header class='text-center mb-16 md:mb-20'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-blue-100/80 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-blue-700 ring-1 ring-blue-200/50 mb-8'
      >
        <svg class='h-4 w-4' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'></path>
        </svg>
        Выбор оптимального решения
      </div>
      <h2
        id='solution-choice-title'
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 tracking-tight leading-tight'
      >
        Банкротство или реструктуризация?
      </h2>
      <p class='text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto leading-relaxed font-medium'>
        Определяем наиболее выгодный путь решения ваших долговых проблем
      </p>
    </header>

    <!-- Comparison Cards -->
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 mb-16'>
      <!-- Банкротство Card with Tabs -->
      <article
        class='group relative overflow-hidden rounded-2xl bg-white/60 backdrop-blur-md border border-white/50 shadow-lg hover:shadow-xl transition-all duration-500 p-8 hover:scale-[1.02] hover:-translate-y-2 flex flex-col h-full'
        role='region'
        aria-labelledby='bankruptcy-title'
      >
        <div
          class='absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-blue-500/10 to-purple-500/10 rounded-bl-full'
        >
        </div>

        <!-- Популярный выбор badge -->
        <span
          class='absolute top-3 left-1/2 transform -translate-x-1/2 bg-blue-500 text-white text-xs font-bold px-4 py-2 rounded-full shadow-lg z-20'
        >
          Популярный выбор
        </span>

        <div class='relative z-10 pt-4 flex flex-col flex-grow'>
          <!-- Tabs Switcher -->
          <div class='flex justify-center mb-2'>
            <BankruptcyTabSwitcher client:visible={{rootMargin: '100px'}} />
          </div>
          <!-- Icon -->
          <div
            class:list={`w-16 h-16 rounded-xl bg-gradient-to-br ${solutionData.bankruptcy.gradient} p-4 mb-6 group-hover:scale-110 transition-all duration-500`}
          >
            <svg
              class='w-full h-full text-white'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1'
              ></path>
            </svg>
          </div>

          <!-- Standard Bankruptcy Content -->
          <div class='bankruptcy-content' data-content='standard'>
            <!-- Header -->
            <div class='mb-6'>
              <h3 id='bankruptcy-title' class='text-2xl lg:text-3xl font-bold text-slate-900 mb-2'>
                {solutionData.bankruptcy.title}
              </h3>
              <p class='text-slate-600 text-lg leading-relaxed min-h-[3.5rem] flex items-center'>
                {solutionData.bankruptcy.subtitle}
              </p>
            </div>

            <!-- Pricing -->
            <div class='bg-blue-50 rounded-lg p-4 mb-6 h-20 flex flex-col justify-center'>
              <div class='text-3xl font-bold text-blue-600 mb-1'>
                {solutionData.bankruptcy.price}
              </div>
              <div class='text-sm text-blue-700'>
                Рассрочка {solutionData.bankruptcy.monthlyPayment} • {
                  solutionData.bankruptcy.duration
                }
              </div>
            </div>

            <!-- Stats -->
            <div class='flex justify-between text-center mb-6 h-16 items-center'>
              <div>
                <div class='text-2xl font-bold text-green-600'>
                  {solutionData.bankruptcy.successRate}
                </div>
                <div class='text-xs text-slate-600'>Успешность</div>
              </div>
              <div>
                <div class='text-2xl font-bold text-blue-600'>4-6</div>
                <div class='text-xs text-slate-600'>Месяцев</div>
              </div>
              <div>
                <div class='text-2xl font-bold text-purple-600'>100%</div>
                <div class='text-xs text-slate-600'>Списание</div>
              </div>
            </div>

            <!-- Advantages -->
            <div class='space-y-3 mb-6'>
              {
                solutionData.bankruptcy.advantages.map((advantage) => (
                  <div class='flex items-start'>
                    <span class='text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                    <span class='text-slate-700 text-sm'>{advantage}</span>
                  </div>
                ))
              }
            </div>

            <!-- Considerations -->
            <div class='space-y-3 mb-6'>
              {
                solutionData.bankruptcy.considerations.map((consideration) => (
                  <div class='flex items-start'>
                    <span class='text-amber-500 mr-3 mt-0.5 text-lg'>⚠</span>
                    <span class='text-slate-700 text-sm'>{consideration}</span>
                  </div>
                ))
              }
            </div>

            <!-- Content Area (flexible) -->
            <div class='flex-grow'>
              <!-- Suitable for -->
              <div class='bg-blue-50 rounded-lg p-4 mb-6'>
                <p class='text-sm text-blue-800'>
                  <span class='font-bold'>Подходит:</span>
                  {solutionData.bankruptcy.suitable}
                </p>
              </div>
            </div>

            <!-- CTA Button Area (fixed at bottom) -->
            <div class='mt-auto space-y-3'>
              <button
                class='w-full btn-primary group-hover:bg-blue-700 transition-colors duration-300'
                data-modal='consultation'
              >
                Консультация по банкротству
              </button>
              <div class='h-8'></div>
            </div>
          </div>

          <!-- Preservation Bankruptcy Content -->
          <div class='bankruptcy-content hidden' data-content='preservation'>
            <!-- Header -->
            <div class='mb-6'>
              <h3 class='text-2xl lg:text-3xl font-bold text-slate-900 mb-2'>
                {solutionData.propertyPreservation.title}
              </h3>
              <p class='text-slate-600 text-lg leading-relaxed min-h-[3.5rem] flex items-center'>
                {solutionData.propertyPreservation.subtitle}
              </p>
            </div>

            <!-- Pricing -->
            <div class='bg-indigo-50 rounded-lg p-4 mb-6 h-20 flex flex-col justify-center'>
              <div class='text-3xl font-bold text-indigo-600 mb-1'>
                {solutionData.propertyPreservation.price}
              </div>
              <div class='text-sm text-indigo-700'>
                Рассрочка {solutionData.propertyPreservation.monthlyPayment} • {
                  solutionData.propertyPreservation.duration
                }
              </div>
            </div>

            <!-- Stats -->
            <div class='flex justify-between text-center mb-6 h-16 items-center'>
              <div>
                <div class='text-2xl font-bold text-green-600'>
                  {solutionData.propertyPreservation.successRate}
                </div>
                <div class='text-xs text-slate-600'>Успешность</div>
              </div>
              <div>
                <div class='text-2xl font-bold text-indigo-600'>6-9</div>
                <div class='text-xs text-slate-600'>Месяцев</div>
              </div>
              <div>
                <div class='text-2xl font-bold text-blue-600'>🏠</div>
                <div class='text-xs text-slate-600'>Сохранение</div>
              </div>
            </div>

            <!-- Advantages -->
            <div class='space-y-3 mb-6'>
              {
                solutionData.propertyPreservation.advantages.map((advantage) => (
                  <div class='flex items-start'>
                    <span class='text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                    <span class='text-slate-700 text-sm'>{advantage}</span>
                  </div>
                ))
              }
            </div>

            <!-- Considerations -->
            <div class='space-y-3 mb-6'>
              {
                solutionData.propertyPreservation.considerations.map((consideration) => (
                  <div class='flex items-start'>
                    <span class='text-amber-500 mr-3 mt-0.5 text-lg'>⚠</span>
                    <span class='text-slate-700 text-sm'>{consideration}</span>
                  </div>
                ))
              }
            </div>

            <!-- Content Area (flexible) -->
            <div class='flex-grow'>
              <!-- Suitable for -->
              <div class='bg-indigo-50 rounded-lg p-4 mb-6'>
                <p class='text-sm text-indigo-800'>
                  <span class='font-bold'>Подходит:</span>
                  {solutionData.propertyPreservation.suitable}
                </p>
              </div>
            </div>

            <!-- CTA Button Area (fixed at bottom) -->
            <div class='mt-auto space-y-3'>
              <button
                class='w-full btn-primary group-hover:bg-indigo-700 transition-colors duration-300'
                data-modal='consultation'
              >
                Консультация по сохранению
              </button>
              <a
                href='/bankrotstvo-s-sokhraneniyem-imushchestva/'
                class='w-full block text-center py-2 px-4 text-indigo-600 hover:text-indigo-700 text-sm font-medium transition-colors'
              >
                Подробнее о сохранении →
              </a>
            </div>
          </div>
        </div>

        <!-- Hover background -->
        <div
          class:list={`absolute inset-0 bg-gradient-to-br ${solutionData.bankruptcy.bgGradient} opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10`}
        >
        </div>
      </article>

      <!-- Реструктуризация Card -->
      <article
        class='group relative overflow-hidden rounded-2xl bg-white/60 backdrop-blur-md border border-white/50 shadow-lg hover:shadow-xl transition-all duration-500 p-8 hover:scale-[1.02] hover:-translate-y-2 flex flex-col h-full'
        role='region'
        aria-labelledby='restructuring-title'
      >
        <div
          class='absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-emerald-500/10 to-teal-500/10 rounded-bl-full'
        >
        </div>

        <!-- Invisible placeholder badge for alignment -->
        <div
          class='invisible absolute top-3 left-1/2 transform -translate-x-1/2 bg-emerald-500 text-white text-xs font-bold px-4 py-2 rounded-full shadow-lg'
        >
          Placeholder
        </div>

        <div class='relative z-10 pt-4 flex flex-col flex-grow'>
          <!-- Icon -->
          <div
            class:list={`w-16 h-16 rounded-xl bg-gradient-to-br ${solutionData.restructuring.gradient} p-4 mb-6 group-hover:scale-110 transition-all duration-500`}
          >
            <svg
              class='w-full h-full text-white'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
              ></path>
            </svg>
          </div>

          <!-- Header -->
          <div class='mb-6'>
            <h3 id='restructuring-title' class='text-2xl lg:text-3xl font-bold text-slate-900 mb-2'>
              {solutionData.restructuring.title}
            </h3>
            <p class='text-slate-600 text-lg leading-relaxed min-h-[3.5rem] flex items-center'>
              {solutionData.restructuring.subtitle}
            </p>
          </div>

          <!-- Pricing -->
          <div class='bg-emerald-50 rounded-lg p-4 mb-6 h-20 flex flex-col justify-center'>
            <div class='text-3xl font-bold text-emerald-600 mb-1'>
              {solutionData.restructuring.price}
            </div>
            <div class='text-sm text-emerald-700'>
              Рассрочка {solutionData.restructuring.monthlyPayment} • {
                solutionData.restructuring.duration
              }
            </div>
          </div>

          <!-- Stats -->
          <div class='flex justify-between text-center mb-6 h-16 items-center'>
            <div>
              <div class='text-2xl font-bold text-green-600'>
                {solutionData.restructuring.successRate}
              </div>
              <div class='text-xs text-slate-600'>Успешность</div>
            </div>
            <div>
              <div class='text-2xl font-bold text-emerald-600'>100%</div>
              <div class='text-xs text-slate-600'>Имущество</div>
            </div>
            <div>
              <div class='text-2xl font-bold text-teal-600'>0%</div>
              <div class='text-xs text-slate-600'>Штрафы</div>
            </div>
          </div>

          <!-- Advantages -->
          <div class='space-y-3 mb-6'>
            {
              solutionData.restructuring.advantages.map((advantage) => (
                <div class='flex items-start'>
                  <span class='text-green-500 mr-3 mt-0.5 text-lg'>✓</span>
                  <span class='text-slate-700 text-sm'>{advantage}</span>
                </div>
              ))
            }
          </div>

          <!-- Considerations -->
          <div class='space-y-3 mb-6'>
            {
              solutionData.restructuring.considerations.map((consideration) => (
                <div class='flex items-start'>
                  <span class='text-amber-500 mr-3 mt-0.5 text-lg'>⚠</span>
                  <span class='text-slate-700 text-sm'>{consideration}</span>
                </div>
              ))
            }
          </div>

          <!-- Content Area (flexible) -->
          <div class='flex-grow'>
            <!-- Suitable for -->
            <div class='bg-emerald-50 rounded-lg p-4 mb-6'>
              <p class='text-sm text-emerald-800'>
                <span class='font-bold'>Подходит:</span>
                {solutionData.restructuring.suitable}
              </p>
            </div>
          </div>

          <!-- CTA Button Area (fixed at bottom) -->
          <div class='mt-auto space-y-3'>
            <button
              class='w-full btn-secondary group-hover:bg-emerald-700 transition-colors duration-300'
              data-modal='consultation'
            >
              Консультация по реструктуризации
            </button>
            <a
              href='/restrukturizaciya-dolgov/'
              class='w-full block text-center py-2 px-4 text-emerald-600 hover:text-emerald-700 text-sm font-medium transition-colors'
            >
              Подробнее о реструктуризации →
            </a>
          </div>
        </div>

        <!-- Hover background -->
        <div
          class:list={`absolute inset-0 bg-gradient-to-br ${solutionData.restructuring.bgGradient} opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10`}
        >
        </div>
      </article>
    </div>

    <!-- Decision Helper Section -->
    <div
      class='relative overflow-hidden rounded-2xl bg-gradient-to-r from-gray-50 to-blue-50 border border-gray-200 shadow-lg p-8 lg:p-12'
    >
      <div
        class='absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-blue-400/10 to-purple-400/10 rounded-bl-full'
      >
      </div>

      <div class='relative z-10 text-center'>
        <div
          class='w-20 h-20 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 p-5 mx-auto mb-6'
        >
          <svg
            class='w-full h-full text-white'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
          >
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              stroke-width='2'
              d='M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z'
            ></path>
          </svg>
        </div>

        <h3 class='text-3xl lg:text-4xl font-bold text-slate-900 mb-4'>Не знаете, что выбрать?</h3>
        <p class='text-slate-600 mb-8 text-lg lg:text-xl leading-relaxed max-w-2xl mx-auto'>
          Получите бесплатную консультацию и персональные рекомендации по вашей ситуации за 15 минут
        </p>

        <!-- Features Grid -->
        <div class='grid grid-cols-1 md:grid-cols-3 gap-6 mb-8'>
          <div class='text-center'>
            <div
              class='w-12 h-12 rounded-full bg-blue-100 mx-auto mb-3 flex items-center justify-center'
            >
              <svg
                class='w-6 h-6 text-blue-600'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'></path>
              </svg>
            </div>
            <p class='text-sm text-slate-700 font-medium'>Консультация за 15 минут</p>
          </div>
          <div class='text-center'>
            <div
              class='w-12 h-12 rounded-full bg-emerald-100 mx-auto mb-3 flex items-center justify-center'
            >
              <svg
                class='w-6 h-6 text-emerald-600'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'></path>
              </svg>
            </div>
            <p class='text-sm text-slate-700 font-medium'>Персональные рекомендации</p>
          </div>
          <div class='text-center'>
            <div
              class='w-12 h-12 rounded-full bg-purple-100 mx-auto mb-3 flex items-center justify-center'
            >
              <svg
                class='w-6 h-6 text-purple-600'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z'
                ></path>
              </svg>
            </div>
            <p class='text-sm text-slate-700 font-medium'>100% конфиденциально</p>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class='flex flex-col sm:flex-row gap-4 justify-center'>
          <button
            class='btn-primary inline-flex items-center gap-2 px-8 py-4 text-lg'
