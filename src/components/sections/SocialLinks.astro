---
import siteData from '../../core/config/site.json';
import SocialLinksComponent from '../../islands/shared/interactive/social-links.tsx';

export interface Props {
  enableTracking?: boolean;
  openInNewTab?: boolean;
  showLabels?: boolean;
  size?: 'small' | 'medium' | 'large' | 'xl';
  className?: string;
}

const {
  enableTracking = true,
  openInNewTab = true,
  showLabels = false,
  size = 'medium',
  className = '',
} = Astro.props;

// Platform configuration
const platforms = {
  telegram: {
    name: 'Telegram',
    icon: '📱',
    color: '#0088cc',
    className: 'social-link--telegram',
  },
  vk: {
    name: 'VK',
    icon: '💬',
    color: '#4a76a8',
    className: 'social-link--vk',
  },
  whatsapp: {
    name: 'WhatsApp',
    icon: '💬',
    color: '#25D366',
    className: 'social-link--whatsapp',
  },
};

// Get social links from site data
const socialLinks = siteData.company?.social || {};

// Get enabled platforms
const enabledPlatforms = Object.keys(socialLinks).filter(
  (platform) => socialLinks[platform] && platforms[platform]
);
---

<div
  class:list={`social-links social-links--${size} ${className}`}
  data-social-links
  data-enable-tracking={enableTracking}
>
  {
    enabledPlatforms.length > 0 ? (
      enabledPlatforms.map((platform) => {
        const platformConfig = platforms[platform];
        const url = socialLinks[platform];

        return (
          <a
            href={url}
            class:list={[
              `social-link ${platformConfig.className} `,
              { 'social-link--new-tab': openInNewTab },
            ]}
            target={openInNewTab ? '_blank' : '_self'}
            rel={openInNewTab ? 'noopener noreferrer' : ''}
            data-platform={platform}
            aria-label={`Написать в ${platformConfig.name}`}
            title={`Написать в ${platformConfig.name}`}
          >
            <span class='social-link__icon' aria-hidden='true'>
              {platformConfig.icon}
            </span>
            {showLabels && <span class='social-link__label'>{platformConfig.name}</span>}
          </a>
        );
      })
    ) : (
      <div class='social-links__empty'>{/* Empty state handled by CSS if needed */}</div>
    )
  }
</div>

<!-- Load interactive logic -->
<SocialLinksComponent client:load />
