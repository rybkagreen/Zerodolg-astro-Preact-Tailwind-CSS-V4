---
// OnlineSticker component with improved functionality
---

<!-- Online Visitors Sticker -->
<div class="online-sticker" aria-live="polite" aria-atomic="true">
  <div class="online-sticker__pulse"></div>
  <svg class="online-sticker__icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5" opacity="0.7"/>
    <circle cx="8" cy="8" r="2" fill="currentColor"/>
  </svg>
  <span class="online-sticker__text">Сейчас на сайте:</span>
  <span class="online-sticker__count">5</span>
  <span class="online-sticker__suffix">человек</span>
</div>

<style>
  /* Online Sticker Styles */
  .online-sticker {
    position: fixed;
    left: 20px;
    bottom: 20px;
    background: rgba(99, 102, 241, 0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 50px;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: #ffffff;
    font-size: 14px;
    font-weight: 500;
    box-shadow: 0 4px 20px rgba(99, 102, 241, 0.15);
    z-index: 9999;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  /* Active state */
  .online-sticker--visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Pulse animation */
  .online-sticker__pulse {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
    }
  }

  /* Icon */
  .online-sticker__icon {
    margin-left: 12px;
    flex-shrink: 0;
    color: #10b981;
  }

  /* Text */
  .online-sticker__text {
    color: rgba(255, 255, 255, 0.9);
    white-space: nowrap;
  }

  /* Count */
  .online-sticker__count {
    font-weight: 700;
    color: #ffffff;
    min-width: 12px;
    text-align: center;
    transition: all 0.3s ease;
  }

  /* Count animation */
  .online-sticker__count--updating {
    animation: countUpdate 0.3s ease;
  }

  @keyframes countUpdate {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.2);
    }
    100% {
      transform: scale(1);
    }
  }

  /* Suffix */
  .online-sticker__suffix {
    color: rgba(255, 255, 255, 0.9);
    margin-left: 4px;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .online-sticker {
      left: 10px;
      bottom: 70px; /* Above mobile navigation */
      padding: 10px 16px;
      font-size: 13px;
    }

    .online-sticker__text {
      display: none; /* Hide text on mobile to save space */
    }

    .online-sticker__icon {
      margin-left: 8px;
    }
  }

  /* Very small screens */
  @media (max-width: 480px) {
    .online-sticker {
      left: 10px;
      bottom: 60px;
      padding: 8px 14px;
      font-size: 12px;
    }
  }

  /* Landscape mobile */
  @media (max-width: 768px) and (orientation: landscape) {
    .online-sticker {
      bottom: 10px;
    }
  }

  /* Ensure visibility above other elements */
  .online-sticker {
    z-index: 99999 !important;
  }
</style>

<script>
  class OnlineSticker {
    constructor() {
      this.element = document.querySelector('.online-sticker');
      this.countElement = document.querySelector('.online-sticker__count');
      this.minVisitors = 2;
      this.maxVisitors = 7;
      this.showDuration = 3000; // 3 seconds
      this.hideDuration = 45000; // 45 seconds
      this.isVisible = false;
      
      this.init();
    }

    init() {
      // Initial delay before first show
      setTimeout(() => {
        this.show();
        this.startCycle();
      }, 5000); // Start after 5 seconds
    }

    getRandomCount() {
      return Math.floor(Math.random() * (this.maxVisitors - this.minVisitors + 1)) + this.minVisitors;
    }

    updateCount() {
      const newCount = this.getRandomCount();
      
      // Add animation class
      this.countElement?.classList.add('online-sticker__count--updating');
      
      // Update count
      setTimeout(() => {
        if (this.countElement) {
          this.countElement.textContent = newCount.toString();
        }
      }, 150);
      
      // Remove animation class
      setTimeout(() => {
        this.countElement?.classList.remove('online-sticker__count--updating');
      }, 300);
    }

    show() {
      if (!this.element || this.isVisible) return;
      
      this.updateCount();
      this.element.classList.add('online-sticker--visible');
      this.isVisible = true;
      
      // Hide after duration
      setTimeout(() => {
        this.hide();
      }, this.showDuration);
    }

    hide() {
      if (!this.element || !this.isVisible) return;
      
      this.element.classList.remove('online-sticker--visible');
      this.isVisible = false;
    }

    startCycle() {
      setInterval(() => {
        if (!this.isVisible) {
          this.show();
        }
      }, this.hideDuration + this.showDuration);
    }

    // Check if user is scrolling near bottom
    handleScroll() {
      const scrollPosition = window.scrollY + window.innerHeight;
      const documentHeight = document.documentElement.scrollHeight;
      
      // Hide if user is near footer
      if (documentHeight - scrollPosition < 200) {
        this.hide();
      }
    }
  }

  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    const sticker = new OnlineSticker();
    
    // Optional: Hide when scrolling near footer
    let scrollTimeout;
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        sticker.handleScroll();
      }, 100);
    });
  });

  // Analytics tracking (optional)
  document.addEventListener('DOMContentLoaded', () => {
    const stickerElement = document.querySelector('.online-sticker');
    
    stickerElement?.addEventListener('transitionend', (e) => {
      if (e.propertyName === 'opacity' && stickerElement.classList.contains('online-sticker--visible')) {
        // Track sticker display
        if (typeof gtag !== 'undefined') {
          gtag('event', 'online_sticker_shown', {
            event_category: 'engagement',
            event_label: 'sticker_display'
          });
        }
      }
    });
  });
</script>