---
export interface Props {
  formId: string;
  formType: 'callback' | 'consultation' | 'hero' | 'cta';
  className?: string;
}

const { formId, formType, className = '' } = Astro.props;
---

<form class={`form form--${formType} ${className}`} data-form={formId} method="POST" action="/api/form">
  <input type="hidden" name="formType" value={formType} />
  <input type="hidden" name="formId" value={formId} />
  
  <slot />
</form>

<!-- Form logic will be handled by parent components -->

