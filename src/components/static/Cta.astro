---
// Cta.astro
import CTAForm from '../forms/CTAForm.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  data?: any;
  [key: string]: any;
}

const { title, subtitle } = Astro.props;

// Данные для CTA секции
const cta = {
  title: title || 'Готовы начать жизнь без долгов?',
  subtitle: subtitle || 'Оставьте заявку и получите бесплатную консультацию юриста в течение 15 минут',
  form: {
    fields: {
      name: {
        label: 'Ваше имя',
        placeholder: 'Введите ваше имя',
        required: true
      },
      phone: {
        label: 'Телефон',
        placeholder: '+7 (___) ___-__-__',
        required: true
      },
      debt: {
        label: 'Сумма долга (необязательно)',
        placeholder: 'Например: 500 000 руб'
      }
    },
    button: 'Получить консультацию бесплатно',
    agreement: 'Нажимая кнопку, вы соглашаетесь с условиями'
  }
};
---

<!-- Final CTA Section -->
<section class="cta section" id="contact" aria-labelledby="cta-title">
    <!-- Декоративные плавающие элементы -->
    <div class="cta__decorations" aria-hidden="true">
        <div class="cta__decoration"></div>
        <div class="cta__decoration"></div>
        <div class="cta__decoration"></div>
        <div class="cta__decoration"></div>
    </div>
    
    <div class="container">
        <header class="section__header section__header--white">
            <h2 id="cta-title" class="section__title">{cta.title}</h2>
            <p class="section__subtitle">{cta.subtitle}</p>
        </header>
        
        <!-- CTA Content Wrapper with Form and Manager Info -->
        <div class="cta__wrapper">
            <!-- Left Column: Form -->
            <div class="cta__form-container">
                <CTAForm 
                    formId="cta-consultation-form"
                    showDebtField={true}
                    submitText="Получить консультацию бесплатно"
                    variant="stacked"
                    className="cta__form"
                />
            </div>
            
            <!-- Right Column: Manager Info with Emblem -->
            <div class="cta__manager-info">
                <!-- Emblem -->
                <div class="cta__emblem">
                    <img src="/icons/ui/emblem.webp"
                         alt="Герб Российской Федерации" 
                         class="cta__emblem-img"
                         loading="lazy"
                         width="100"
                         height="100">
                </div>
                
                <!-- Manager Card Link -->
                <div class="cta__manager-card">
                    <h3 class="cta__manager-title">Арбитражный финансовый управляющий</h3>
                    <p class="cta__manager-name">Масхулиа Леван Зурабович</p>
                    <p class="cta__manager-details">
                        Регистрационный номер: 14320<br>
                        Член СРО арбитражных управляющих<br>
                        Стаж работы: более 11 лет
                    </p>
                    
                    <a href="https://old.bankrot.fedresurs.ru/ArbitrManagerCard.aspx?ID=0fe01101-9000-45a5-9a14-31d86002b6ba" 
                       class="cta__manager-link"
                       target="_blank"
                       rel="noopener nofollow"
                       title="Карточка арбитражного управляющего в Едином федеральном реестре сведений о банкротстве">
                        <svg class="cta__manager-link-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                            <polyline points="15 3 21 3 21 9"></polyline>
                            <line x1="10" y1="14" x2="21" y2="3"></line>
                        </svg>
                        Посмотреть карточку в реестре Федресурс
                    </a>
                    
                    <div class="cta__manager-trust">
                        <p class="cta__manager-trust-text">
                            ✓ Официальный реестр арбитражных управляющих<br>
                            ✓ Проверенные данные Федресурс<br>
                            ✓ Более 1000 успешных дел
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
