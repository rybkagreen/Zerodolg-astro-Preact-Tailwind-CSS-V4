---
import BaseForm from './BaseForm.astro';

export interface Props {
  className?: string;
  id?: string;
}

const { className = '', id = 'consultation-form' } = Astro.props;
---

<div id={id} class:list={`space-y-6 ${className}`}>
  <!-- Form Header -->
  <div class='text-center'>
    <h3 class='text-2xl font-bold text-white mb-2'>
      Узнайте стоимость <span class='text-amber-400 font-semibold'>за 2 минуты</span>
    </h3>
    <p class='text-white/90'>Ответим сразу — без навязчивости</p>
  </div>

  <BaseForm
    formId={id}
    formType='hero'
    showDebtField={true}
    submitText='Готов к консультации? Нажми здесь!'
    variant='stacked'
  />
</div>
