---
import Form from './BaseForm.astro';

export interface Props {
  formId?: string;
  showDebtField?: boolean;
  submitText?: string;
  variant?: 'inline' | 'stacked';
  className?: string;
}

const {
  formId = 'cta-form',
  showDebtField = false,
  submitText = 'Отправить заявку',
  variant = 'inline',
  className = '',
} = Astro.props;
---

<div class='cta-form'>
  <Form
    formId={formId}
    formType='cta'
    submitText={submitText}
    showDebtField={showDebtField}
    variant={variant}
    className={className}
  />
</div>
