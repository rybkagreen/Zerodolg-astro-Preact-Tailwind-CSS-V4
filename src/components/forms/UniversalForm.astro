---
import Form from '../preact/form-logic.tsx';

export interface Props {
  formId: string;
  formType: 'hero' | 'cta' | 'consultation' | 'callback' | 'lead';
  submitText?: string;
  showDebtField?: boolean;
  className?: string;
  variant?: 'inline' | 'stacked';
}

const { 
  formId, 
  formType, 
  submitText = 'Получить консультацию',
  showDebtField = true,
  className = '',
  variant = 'stacked'
} = Astro.props;

const formClass = `universal-form universal-form--${variant} ${className}`;
---

<form
  id={formId}
  class={formClass}
  data-form={formType}
  novalidate
>
  <div class="universal-form__fields">
    <!-- Name Field -->
    <div class="universal-form__field">
      <label for={`${formId}-name`} class="universal-form__label">
        Ваше имя <span class="required">*</span>
      </label>
      <input
        type="text"
        id={`${formId}-name`}
        name="name"
        class="universal-form__input"
        placeholder="Введите ваше имя"
        required
        data-validate="name"
        aria-required="true"
        aria-describedby={`${formId}-name-error`}
      />
      <span id={`${formId}-name-error`} class="universal-form__error" role="alert"></span>
    </div>

    <!-- Phone Field -->
    <div class="universal-form__field">
      <label for={`${formId}-phone`} class="universal-form__label">
        Телефон <span class="required">*</span>
      </label>
      <input
        type="tel"
        id={`${formId}-phone`}
        name="phone"
        class="universal-form__input"
        placeholder="+7 (___) ___-__-__"
        required
        data-mask="phone"
        aria-required="true"
        aria-describedby={`${formId}-phone-error`}
      />
      <span id={`${formId}-phone-error`} class="universal-form__error" role="alert"></span>
    </div>

    <!-- Debt Field (optional) -->
    {showDebtField && (
      <div class="universal-form__field">
        <label for={`${formId}-debt`} class="universal-form__label">
          Сумма долга
        </label>
        <input
          type="text"
          id={`${formId}-debt`}
          name="debtAmount"
          class="universal-form__input"
          placeholder="Например: 500 000 руб"
          data-mask="currency"
          aria-describedby={`${formId}-debt-error`}
        />
        <span id={`${formId}-debt-error`} class="universal-form__error" role="alert"></span>
      </div>
    )}
  </div>

  <!-- Privacy Agreement -->
  <div class="universal-form__privacy">
    <label class="universal-form__checkbox">
      <input
        type="checkbox"
        name="privacy"
        required
        aria-required="true"
      />
      <span class="universal-form__checkbox-mark"></span>
      <span class="universal-form__checkbox-label">
        Я согласен с <a href="/privacy" target="_blank">политикой конфиденциальности</a>
      </span>
    </label>
    <span class="universal-form__error" role="alert"></span>
  </div>

  <!-- Submit Button -->
  <button type="submit" class="universal-form__submit btn btn--primary">
    <span class="btn__text">{submitText}</span>
    <span class="btn__loader" aria-hidden="true">
      <svg class="spinner" width="20" height="20" viewBox="0 0 20 20" aria-label="Загрузка" role="status">
        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" />
      </svg>
    </span>
  </button>

  <!-- Success Message (hidden by default) -->
  <div class="universal-form__success" aria-live="polite" aria-atomic="true">
    <div class="universal-form__success-icon">✓</div>
    <h3 class="universal-form__success-title">Заявка отправлена!</h3>
    <p class="universal-form__success-text">
      Мы свяжемся с вами в течение 15 минут для бесплатной консультации
    </p>
  </div>
</form>

<!-- Form Logic Component -->
<Form 
  client:load
  formId={formId}
  formType={formType}
/>

