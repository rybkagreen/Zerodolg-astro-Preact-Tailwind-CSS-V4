---
/**
 * RelatedPosts - Блок связанных статей
 * Умная система подбора статей по категориям и тегам
 */
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
  currentTags: string[];
  currentCategory?: string;
  limit?: number;
}

const { currentSlug, currentTags, currentCategory, limit = 3 } = Astro.props;

const allPosts = await getCollection('blog');

// Находим связанные статьи с системой оценки
const relatedPosts = allPosts
  .filter((post) => post.slug !== currentSlug && !post.data.draft)
  .map((post) => {
    let score = 0;

    // +3 балла за совпадение категории
    if (currentCategory && post.data.category === currentCategory) {
      score += 3;
    }

    // +1 балл за каждый совпадающий тег
    const commonTags = (post.data.tags || []).filter((tag) => currentTags.includes(tag));
    score += commonTags.length;

    return { post, score };
  })
  .filter((item) => item.score > 0) // Только релевантные статьи
  .sort((a, b) => b.score - a.score) // Сортируем по релевантности
  .slice(0, limit)
  .map((item) => item.post);
---

{
  relatedPosts.length > 0 && (
    <section class='mt-16 pt-16 border-t-2 border-gray-200'>
      <div class='max-w-7xl mx-auto'>
        <h2 class='text-3xl font-bold mb-8 text-gray-800 flex items-center gap-3'>
          <svg class='w-8 h-8 text-blue-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              stroke-width='2'
              d='M13 10V3L4 14h7v7l9-11h-7z'
            />
          </svg>
          Читайте также
        </h2>

        <div class='grid md:grid-cols-2 lg:grid-cols-3 gap-6'>
          {relatedPosts.map((post) => (
            <article class='group bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-blue-300 flex flex-col'>
              {/* Заголовок с иконкой категории */}
              <div class='relative h-48 bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center overflow-hidden'>
                <div class='absolute inset-0 opacity-20'>
                  <div class='absolute top-0 left-0 w-32 h-32 bg-white rounded-full filter blur-2xl' />
                  <div class='absolute bottom-0 right-0 w-32 h-32 bg-white rounded-full filter blur-2xl' />
                </div>
                <svg
                  class='relative z-10 w-16 h-16 text-white/90'
                  fill='none'
                  stroke='currentColor'
                  viewBox='0 0 24 24'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                  />
                </svg>
                {/* Категория */}
                {post.data.category && (
                  <div class='absolute top-4 left-4 bg-white/20 backdrop-blur-sm text-white px-3 py-1 rounded-full text-xs font-semibold'>
                    {post.data.category}
                  </div>
                )}
              </div>

              {/* Контент карточки */}
              <div class='p-6 flex-1 flex flex-col'>
                {/* Теги */}
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class='flex flex-wrap gap-2 mb-3'>
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <span class='inline-block bg-blue-50 text-blue-600 px-2 py-1 rounded text-xs font-medium'>
                        {tag}
                      </span>
                    ))}
                  </div>
                )}

                {/* Заголовок */}
                <h3 class='text-xl font-bold mb-2 group-hover:text-blue-600 transition-colors line-clamp-2 flex-1'>
                  <a href={`/blog/${post.slug}.html`} class='hover:underline'>
                    {post.data.title}
                  </a>
                </h3>

                {/* Описание */}
                {post.data.description && (
                  <p class='text-gray-600 mb-4 line-clamp-3 text-sm'>{post.data.description}</p>
                )}

                {/* Метаинформация */}
                <div class='flex items-center justify-between text-sm text-gray-500 mt-auto pt-4 border-t border-gray-100'>
                  <div class='flex items-center gap-3'>
                    {post.data.pubDate && (
                      <time
                        datetime={post.data.pubDate.toISOString()}
                        class='flex items-center gap-1'
                      >
                        <svg class='w-4 h-4' fill='currentColor' viewBox='0 0 20 20'>
                          <path
                            fill-rule='evenodd'
                            d='M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z'
                            clip-rule='evenodd'
                          />
                        </svg>
                        {new Date(post.data.pubDate).toLocaleDateString('ru-RU', {
                          day: 'numeric',
                          month: 'short',
                        })}
                      </time>
                    )}
                    {post.data.readingTime && (
                      <span class='flex items-center gap-1'>
                        <svg class='w-4 h-4' fill='currentColor' viewBox='0 0 20 20'>
                          <path
                            fill-rule='evenodd'
                            d='M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z'
                            clip-rule='evenodd'
                          />
                        </svg>
                        {post.data.readingTime} мин
                      </span>
                    )}
                  </div>
                  <a
                    href={`/blog/${post.slug}.html`}
                    class='text-blue-600 hover:text-blue-700 font-medium flex items-center gap-1'
                  >
                    Читать
                    <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M9 5l7 7-7 7'
                      />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
