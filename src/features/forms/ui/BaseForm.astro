---
import Form from '../../../components/preact/form-logic.tsx';

export interface Props {
  formId: string;
  formType: 'hero' | 'cta' | 'consultation' | 'callback' | 'lead' | 'footer' | 'section';
  submitText?: string;
  showDebtField?: boolean;
  showNameField?: boolean;
  showPhoneField?: boolean;
  showEmailField?: boolean;
  showPrivacyCheckbox?: boolean;
  variant?: 'inline' | 'stacked' | 'compact';
  className?: string;
  title?: string;
  subtitle?: string;
}

const {
  formId,
  formType,
  submitText = 'Получить консультацию',
  showDebtField = false,
  showNameField = true,
  showPhoneField = true,
  showEmailField = false,
  showPrivacyCheckbox = true,
  variant = 'stacked',
  className = '',
  title = '',
  subtitle = '',
} = Astro.props;

const variantClasses = {
  inline: 'flex flex-wrap gap-4',
  stacked: 'space-y-4',
  compact: 'space-y-3'
};

const baseClasses = `max-w-md mx-auto ${className}`;
---

<div class={baseClasses}>
  {title && <h3 class="text-xl font-semibold text-gray-900 mb-2">{title}</h3>}
  {subtitle && <p class="text-gray-600 mb-4">{subtitle}</p>}

  <form id={formId} class={`space-y-4 ${variantClasses[variant]}`} data-form={formType} novalidate>
    <div class={`${variant === 'inline' ? 'flex-1 min-w-[200px]' : ''}`}>
      <!-- Name Field -->
      {
        showNameField && (
          <div class={`${variant === 'inline' ? 'flex-1 min-w-[200px]' : ''}`}>
            <label for={`${formId}-name`} class="block text-sm font-medium text-gray-700 mb-1">
              Ваше имя <span class="text-red-500"> *</span>
            </label>
            <input
              type="text"
              id={`${formId}-name`}
              name="name"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
              placeholder="Введите ваше имя"
              required
              data-validate="name"
              aria-required="true"
              aria-describedby={`${formId}-name-error`}
            />
            <span id={`${formId}-name-error`} class="text-sm text-red-600 mt-1 block" role="alert" />
          </div>
        )
      }

      <!-- Phone Field -->
      {
        showPhoneField && (
          <div class={`${variant === 'inline' ? 'flex-1 min-w-[200px]' : ''}`}>
            <label for={`${formId}-phone`} class="block text-sm font-medium text-gray-700 mb-1">
              Телефон <span class="text-red-500"> *</span>
            </label>
            <input
              type="tel"
              id={`${formId}-phone`}
              name="phone"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
              placeholder="+7 (___) ___-__-__"
              required
              data-mask="phone"
              aria-required="true"
              aria-describedby={`${formId}-phone-error`}
            />
            <span id={`${formId}-phone-error`} class="text-sm text-red-600 mt-1 block" role="alert" />
          </div>
        )
      }

      <!-- Email Field -->
      {
        showEmailField && (
          <div class={`${variant === 'inline' ? 'flex-1 min-w-[200px]' : ''}`}>
            <label for={`${formId}-email`} class="block text-sm font-medium text-gray-700 mb-1">
              Email {showEmailField && !showPhoneField ? <span class="text-red-500"> *</span> : ''}
            </label>
            {(() => {
              if (showEmailField && !showPhoneField) {
                return (
                  <input
                    type="email"
                    id={`${formId}-email`}
                    name="email"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
                    placeholder="example@mail.com"
                    required
                    data-validate="email"
                    aria-required="true"
                    aria-describedby={`${formId}-email-error`}
                  />
                );
              } else {
                return (
                  <input
                    type="email"
                    id={`${formId}-email`}
                    name="email"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
                    placeholder="example@mail.com"
                    data-validate="email"
                    aria-required="false"
                    aria-describedby={`${formId}-email-error`}
                  />
                );
              }
            })()}
            <span id={`${formId}-email-error`} class="text-sm text-red-600 mt-1 block" role="alert" />
          </div>
        )
      }

      <!-- Debt Field (optional) -->
      {
        showDebtField && (
          <div class={`${variant === 'inline' ? 'flex-1 min-w-[200px]' : ''}`}>
            <label for={`${formId}-debt`} class="block text-sm font-medium text-gray-700 mb-1">
              Сумма долга
            </label>
            <input
              type="text"
              id={`${formId}-debt`}
              name="debtAmount"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
              placeholder="Например: 500 000 руб"
              data-mask="currency"
              aria-describedby={`${formId}-debt-error`}
            />
            <span id={`${formId}-debt-error`} class="text-sm text-red-600 mt-1 block" role="alert" />
          </div>
        )
      }
    </div>

    <!-- Privacy Agreement -->
    {
      showPrivacyCheckbox && (
        <div class="flex items-start">
          <div class="flex items-center h-5">
            <input 
              type="checkbox" 
              name="privacy" 
              required 
              aria-required="true" 
              class="h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded"
            />
          </div>
          <div class="ml-3 text-sm">
            <label class="font-medium text-gray-700">
              Я согласен с{' '}
              <a href="/privacy" target="_blank" class="text-primary hover:underline">
                политикой конфиденциальности
              </a>
            </label>
            <span class="text-red-600 block" role="alert" />
          </div>
        </div>
      )
    }

    <!-- Submit Button -->
    <button type="submit" class="w-full py-3 px-6 bg-primary text-white rounded-lg hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors duration-200 font-medium">
      <span class="flex items-center justify-center">
        {submitText}
        <span class="ml-2 loader hidden">
          <svg
            class="animate-spin h-5 w-5 text-white"
            viewBox="0 0 20 20"
            aria-label="Загрузка"
            role="status"
          >
            <circle
              cx="10"
              cy="10"
              r="8"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
              stroke-linecap="round"></circle>
          </svg>
        </span>
      </span>
    </button>

    <!-- Success Message (hidden by default) -->
    <div class="hidden bg-green-50 border border-green-200 rounded-lg p-4 mt-4" aria-live="polite" aria-atomic="true">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-green-800">Заявка отправлена!</h3>
          <p class="text-sm text-green-700 mt-1">
            Мы свяжемся с вами в течение 15 минут для бесплатной консультации
          </p>
        </div>
      </div>
    </div>
  </form>

  <!-- Form Logic Component -->
  <Form client:idle formId={formId} formType={formType} />
</div>
