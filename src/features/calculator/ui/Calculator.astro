---
// Calculator.astro - Redesigned Calculator with Hero-style gradient background
import CalculatorInteractive from '../../../islands/features/calculator/CalculatorInteractive.tsx';

export interface Props {
  title?: string;
  subtitle?: string;
  className?: string;
}

const {
  title = 'Калькулятор стоимости банкротства',
  subtitle = 'Ответьте на несколько вопросов и узнайте точную стоимость процедуры',
  className = '',
} = Astro.props;
---

<!-- Hero-Style Calculator Section with Animated Gradient Background -->
<section
  class:list={`relative min-h-screen overflow-hidden flex items-center pt-24 md:pt-32 lg:pt-40 ${className}`}
  id='calculator'
  aria-labelledby='calculator-title'
>
  <!-- Animated Gradient Background - Similar to original -->
  <div
    class='absolute inset-0 animate-gradient-rotate'
    style='background: linear-gradient(to right, #0f172a, #1e3a8a, #312e81) !important; background-size: 400% 400% !important;'
  >
  </div>

  <!-- Dark overlay for contrast -->
  <div
    class='absolute inset-0 bg-gradient-to-br from-transparent via-black/20 to-black/40 pointer-events-none'
  >
  </div>

  <!-- Animated mesh pattern overlay -->
  <div
    class='absolute inset-0 opacity-30'
    style='background-image: radial-gradient(circle at 30% 70%, rgba(245, 158, 11, 0.15) 0%, transparent 50%), radial-gradient(circle at 70% 30%, rgba(37, 99, 235, 0.15) 0%, transparent 50%), radial-gradient(circle at 50% 50%, rgba(255, 215, 0, 0.1) 0%, transparent 50%); animation: mesh-float 30s ease-in-out infinite;'
  >
  </div>

  <div class='relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-20'>
    <!-- Section Header -->
    <header class='text-center mb-16'>
      <div
        class='inline-flex items-center gap-2 rounded-full bg-white/20 backdrop-blur-sm px-6 py-3 text-sm font-semibold text-white ring-1 ring-white/30 mb-8'
        aria-label='Расчет стоимости банкротства онлайн'
        style='animation: fadeInUp 0.6s ease-out;'
      >
        <svg
          class='h-4 w-4 text-white'
          fill='none'
          viewBox='0 0 24 24'
          stroke='currentColor'
          aria-hidden='true'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z'
          ></path>
        </svg>
        <span itemscope itemtype='https://schema.org/WebApplication'>
          <meta itemprop='name' content='Калькулятор стоимости банкротства' />
          <meta itemprop='applicationCategory' content='FinanceApplication' />
          <meta itemprop='operatingSystem' content='Any' />
          Расчет стоимости
        </span>
      </div>
      <h2
        id='calculator-title'
        class='text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight leading-tight'
        style='text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3); animation: fadeInUp 0.8s ease-out;'
      >
        {title}
      </h2>
      <p
        class='text-xl md:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed font-medium'
        style='animation: fadeInUp 0.8s ease-out 0.2s; animation-fill-mode: both;'
      >
        {subtitle}
      </p>
    </header>

    <!-- Glass Morphism Calculator Form Container -->
    <div
      class='bg-white/10 backdrop-blur-lg rounded-3xl p-8 md:p-12 max-w-4xl mx-auto border border-white/20 shadow-2xl'
      style='box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.5); animation: slideInUp 0.8s ease-out 0.4s; animation-fill-mode: both;'
    >
      <!-- Top accent line -->
      <div
        class='h-1 w-full bg-gradient-to-r from-orange-400 via-yellow-500 to-red-500 rounded-t-3xl mx-0 -mt-8 md:-mt-12 mb-8'
        style='animation: shimmer 3s ease-in-out infinite;'
      >
      </div>

      <!-- Interactive Calculator Component -->
      <CalculatorInteractive client:visible />
    </div>
  </div>
</section>
