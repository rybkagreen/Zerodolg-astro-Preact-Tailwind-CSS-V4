        type='tel'
        class='form__input'
        id='assessment-phone'
        name='phone'
        placeholder='+7 (___) ___-__-__'
        data-mask='phone'
        required
        autocomplete='tel'
      />
      <span class='form__error' data-error='phone'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='assessment-debt'>
        Сумма долгов <span class='form__required'>*</span>
      </label>
      <input
        type='number'
        class='form__input'
        id='assessment-debt'
        name='debt_amount'
        placeholder='Введите общую сумму долгов'
        required
        min='100000'
        autocomplete='off'
      />
      <span class='form__error' data-error='debt_amount'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='assessment-situation'>
        Краткое описание ситуации <span class='form__required'>*</span>
      </label>
      <textarea
        class='form__textarea'
        id='assessment-situation'
        name='situation'
        placeholder='Опишите вашу ситуацию, виды долгов, кредиторы...'
        rows='4'
        required
        autocomplete='off'></textarea>
      <span class='form__error' data-error='situation'></span>
    </div>

    <div class='form__group'>
      <label class='form__checkbox' for='assessment-agreement'>
        <input type='checkbox' id='assessment-agreement' name='agreement' required />
        <span class='form__checkbox-text'>
          Я согласен на обработку
          <a href='/privacy' target='_blank'>персональных данных</a>
        </span>
      </label>
      <span class='form__error' data-error='agreement'></span>
    </div>

    <button type='submit' class='btn btn--primary btn--block form__submit'>
      <span class='btn__text'>Получить оценку</span>
      <span class='btn__loader'>
        <svg class='spinner' viewBox='0 0 50 50' aria-label='Загрузка' role='status'>
          <circle cx='25' cy='25' r='20' fill='none' stroke-width='5'></circle>
        </svg>
      </span>
    </button>

    <p class='form__note'>
      Нажимая кнопку, вы соглашаетесь с
      <a href='/terms' target='_blank'>условиями обработки данных</a>
    </p>
  </BaseForm>
</Modal>

<!-- Webinar Registration Modal -->
<Modal
  id='webinar-registration'
  title='Записаться на вебинар'
  subtitle='Еженедельный вебинар "Банкротство без ошибок". Разбор реальных кейсов и ответы на вопросы.'
>
  <div class='webinar-info mb-6 p-4 bg-blue-50 border border-blue-200 rounded-lg'>
    <div class='text-center'>
      <div class='text-2xl mb-2'>📅</div>
      <div class='font-semibold text-blue-800 mb-1'>Следующий вебинар</div>
      <div class='text-blue-600'>Каждый четверг в 19:00 МСК</div>
    </div>
  </div>

  <BaseForm formId='webinar' formType='webinar'>
    <div class='form__group'>
      <label class='form__label' for='webinar-name'>
        Ваше имя <span class='form__required'>*</span>
      </label>
      <input
        type='text'
        class='form__input'
        id='webinar-name'
        name='name'
        placeholder='Введите ваше имя'
        required
        autocomplete='name'
      />
      <span class='form__error' data-error='name'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='webinar-email'>
        Email для отправки ссылки <span class='form__required'>*</span>
      </label>
      <input
        type='email'
        class='form__input'
        id='webinar-email'
        name='email'
        placeholder='example@mail.com'
        required
        autocomplete='email'
      />
      <span class='form__error' data-error='email'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='webinar-phone'> Телефон для SMS-напоминания </label>
      <input
        type='tel'
        class='form__input'
        id='webinar-phone'
        name='phone'
        placeholder='+7 (___) ___-__-__'
        data-mask='phone'
        autocomplete='tel'
      />
    </div>

    <div class='form__group'>
      <label class='form__checkbox' for='webinar-agreement'>
        <input type='checkbox' id='webinar-agreement' name='agreement' required />
        <span class='form__checkbox-text'>
          Я согласен на обработку
          <a href='/privacy' target='_blank'>персональных данных</a>
        </span>
      </label>
      <span class='form__error' data-error='agreement'></span>
    </div>

    <button type='submit' class='btn btn--primary btn--block form__submit'>
      <span class='btn__text'>Записаться на вебинар</span>
      <span class='btn__loader'>
        <svg class='spinner' viewBox='0 0 50 50' aria-label='Загрузка' role='status'>
          <circle cx='25' cy='25' r='20' fill='none' stroke-width='5'></circle>
        </svg>
      </span>
    </button>

    <p class='form__note'>
      Нажимая кнопку, вы соглашаетесь с
      <a href='/terms' target='_blank'>условиями обработки данных</a>
    </p>
  </BaseForm>
</Modal>
