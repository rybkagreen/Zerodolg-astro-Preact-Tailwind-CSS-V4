---
import Modal from './Modal.astro';
import BaseForm from '../../../components/forms/BaseForm.astro';
---

<!-- Consultation Modal -->
<Modal
  id='consultation'
  title='Бесплатная консультация юриста'
  subtitle='30-минутный разбор вашей ситуации с юристом по банкротству. Получите экспертную оценку и план действий.'
>
  <BaseForm formId='consultation' formType='consultation'>
    <div class='form__group'>
      <label class='form__label' for='consultation-name'>
        Ваше имя <span class='form__required'>*</span>
      </label>
      <input
        type='text'
        class='form__input'
        id='consultation-name'
        name='name'
        placeholder='Введите ваше имя'
        required
        autocomplete='name'
      />
      <span class='form__error' data-error='name'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='consultation-phone'>
        Телефон <span class='form__required'>*</span>
      </label>
      <input
        type='tel'
        class='form__input'
        id='consultation-phone'
        name='phone'
        placeholder='+7 (___) ___-__-__'
        data-mask='phone'
        required
        autocomplete='tel'
      />
      <span class='form__error' data-error='phone'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='consultation-time'> Удобное время для звонка </label>
      <select class='form__select' id='consultation-time' name='preferred_time' autocomplete='off'>
        <option value=''>Выберите время</option>
        <option value='morning'>Утром (9:00 - 12:00)</option>
        <option value='afternoon'>Днем (12:00 - 17:00)</option>
        <option value='evening'>Вечером (17:00 - 21:00)</option>
      </select>
    </div>

    <div class='form__group'>
      <label class='form__label' for='consultation-situation'>
        Краткое описание ситуации (необязательно)
      </label>
      <textarea
        class='form__textarea'
        id='consultation-situation'
        name='situation'
        placeholder='Опишите вашу ситуацию...'
        rows='3'
        autocomplete='off'></textarea>
    </div>

    <div class='form__group'>
      <label class='form__checkbox' for='consultation-agreement'>
        <input type='checkbox' id='consultation-agreement' name='agreement' required />
        <span class='form__checkbox-text'>
          Я согласен на обработку
          <a href='/privacy' target='_blank'>персональных данных</a>
        </span>
      </label>
      <span class='form__error' data-error='agreement'></span>
    </div>

    <button type='submit' class='btn btn--primary btn--block form__submit'>
      <span class='btn__text'>Получить консультацию</span>
      <span class='btn__loader'>
        <svg class='spinner' viewBox='0 0 50 50' aria-label='Загрузка' role='status'>
          <circle cx='25' cy='25' r='20' fill='none' stroke-width='5'></circle>
        </svg>
      </span>
    </button>

    <p class='form__note'>
      Нажимая кнопку, вы соглашаетесь с
      <a href='/terms' target='_blank'>условиями обработки данных</a>
    </p>
  </BaseForm>
</Modal>

<!-- Calculator Modal -->
<Modal
  id='calculator'
  title='Калькулятор банкротства'
  subtitle='Узнайте точную стоимость процедуры банкротства. Получите персональный расчет без регистрации.'
>
  <BaseForm formId='calculator' formType='calculator'>
    <div class='form__group'>
      <label class='form__label' for='calculator-debt'>
        Общая сумма долгов <span class='form__required'>*</span>
      </label>
      <input
        type='number'
        class='form__input'
        id='calculator-debt'
        name='debt_amount'
        placeholder='Введите сумму долгов'
        required
        min='100000'
        max='10000000'
        step='50000'
        autocomplete='off'
      />
      <span class='form__error' data-error='debt_amount'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='calculator-creditors'>
        Количество кредиторов <span class='form__required'>*</span>
      </label>
      <select
        class='form__select'
        id='calculator-creditors'
        name='creditors_count'
        required
        autocomplete='off'
      >
        <option value=''>Выберите количество</option>
        <option value='1-3'>1-3 кредитора</option>
        <option value='4-7'>4-7 кредиторов</option>
        <option value='8+'>8 и более кредиторов</option>
      </select>
      <span class='form__error' data-error='creditors_count'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='calculator-property'>
        Наличие имущества <span class='form__required'>*</span>
      </label>
      <select
        class='form__select'
        id='calculator-property'
        name='property'
        required
        autocomplete='off'
      >
        <option value=''>Выберите вариант</option>
        <option value='none'>Нет имущества</option>
        <option value='apartment'>Единственное жилье</option>
        <option value='multiple'>Несколько объектов</option>
      </select>
      <span class='form__error' data-error='property'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='calculator-name'>
        Ваше имя <span class='form__required'>*</span>
      </label>
      <input
        type='text'
        class='form__input'
        id='calculator-name'
        name='name'
        placeholder='Введите ваше имя'
        required
        autocomplete='name'
      />
      <span class='form__error' data-error='name'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='calculator-phone'>
        Телефон для получения результата <span class='form__required'>*</span>
      </label>
      <input
        type='tel'
        class='form__input'
        id='calculator-phone'
        name='phone'
        placeholder='+7 (___) ___-__-__'
        data-mask='phone'
        required
        autocomplete='tel'
      />
      <span class='form__error' data-error='phone'></span>
    </div>

    <div class='form__group'>
      <label class='form__checkbox' for='calculator-agreement'>
        <input type='checkbox' id='calculator-agreement' name='agreement' required />
        <span class='form__checkbox-text'>
          Я согласен на обработку
          <a href='/privacy' target='_blank'>персональных данных</a>
        </span>
      </label>
      <span class='form__error' data-error='agreement'></span>
    </div>

    <button type='submit' class='btn btn--primary btn--block form__submit'>
      <span class='btn__text'>Рассчитать стоимость</span>
      <span class='btn__loader'>
        <svg class='spinner' viewBox='0 0 50 50' aria-label='Загрузка' role='status'>
          <circle cx='25' cy='25' r='20' fill='none' stroke-width='5'></circle>
        </svg>
      </span>
    </button>

    <p class='form__note'>
      Нажимая кнопку, вы соглашаетесь с
      <a href='/terms' target='_blank'>условиями обработки данных</a>
    </p>
  </BaseForm>
</Modal>

<!-- Guide Download Modal -->
<Modal
  id='guide-download'
  title='Скачать гид по банкротству 2025'
  subtitle='47 страниц полезной информации. Актуальные изменения в законах. Шаблоны документов.'
>
  <div class='guide-preview mb-6'>
    <div class='guide-preview__features grid grid-cols-1 md:grid-cols-3 gap-4'>
      <div class='guide-feature text-center p-4 bg-gray-50 rounded-lg'>
        <span class='guide-feature__icon text-2xl block mb-2'>📖</span>
        <span class='guide-feature__text text-sm text-gray-600'>47 страниц полезной информации</span
        >
      </div>
      <div class='guide-feature text-center p-4 bg-gray-50 rounded-lg'>
        <span class='guide-feature__icon text-2xl block mb-2'>⚖️</span>
        <span class='guide-feature__text text-sm text-gray-600'>Актуальные изменения в законах</span
        >
      </div>
      <div class='guide-feature text-center p-4 bg-gray-50 rounded-lg'>
        <span class='guide-feature__icon text-2xl block mb-2'>📄</span>
        <span class='guide-feature__text text-sm text-gray-600'>Шаблоны всех документов</span>
      </div>
    </div>
  </div>

  <BaseForm formId='guide' formType='guide'>
    <div class='form__group'>
      <label class='form__label' for='guide-name'>
        Ваше имя <span class='form__required'>*</span>
      </label>
      <input
        type='text'
        class='form__input'
        id='guide-name'
        name='name'
        placeholder='Введите ваше имя'
        required
        autocomplete='name'
      />
      <span class='form__error' data-error='name'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='guide-email'>
        Email для отправки гида <span class='form__required'>*</span>
      </label>
      <input
        type='email'
        class='form__input'
        id='guide-email'
        name='email'
        placeholder='example@mail.com'
        required
        autocomplete='email'
      />
      <span class='form__error' data-error='email'></span>
    </div>

    <div class='form__group'>
      <label class='form__checkbox' for='guide-agreement'>
        <input type='checkbox' id='guide-agreement' name='agreement' required />
        <span class='form__checkbox-text'>
          Я согласен на обработку
          <a href='/privacy' target='_blank'>персональных данных</a>
        </span>
      </label>
      <span class='form__error' data-error='agreement'></span>
    </div>

    <button type='submit' class='btn btn--primary btn--block form__submit'>
      <span class='btn__text'>Скачать гид бесплатно</span>
      <span class='btn__loader'>
        <svg class='spinner' viewBox='0 0 50 50' aria-label='Загрузка' role='status'>
          <circle cx='25' cy='25' r='20' fill='none' stroke-width='5'></circle>
        </svg>
      </span>
    </button>

    <p class='form__note'>
      Нажимая кнопку, вы соглашаетесь с
      <a href='/terms' target='_blank'>условиями обработки данных</a>
    </p>
  </BaseForm>
</Modal>

<!-- Checklist Download Modal -->
<Modal
  id='checklist-download'
  title='Получить чек-лист должника'
  subtitle='Пошаговый план подготовки к банкротству с 25 пунктами для проверки.'
>
  <BaseForm formId='checklist' formType='checklist'>
    <div class='form__group'>
      <label class='form__label' for='checklist-name'>
        Ваше имя <span class='form__required'>*</span>
      </label>
      <input
        type='text'
        class='form__input'
        id='checklist-name'
        name='name'
        placeholder='Введите ваше имя'
        required
        autocomplete='name'
      />
      <span class='form__error' data-error='name'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='checklist-email'>
        Email <span class='form__required'>*</span>
      </label>
      <input
        type='email'
        class='form__input'
        id='checklist-email'
        name='email'
        placeholder='example@mail.com'
        required
        autocomplete='email'
      />
      <span class='form__error' data-error='email'></span>
    </div>

    <div class='form__group'>
      <label class='form__checkbox' for='checklist-agreement'>
        <input type='checkbox' id='checklist-agreement' name='agreement' required />
        <span class='form__checkbox-text'>
          Я согласен на обработку
          <a href='/privacy' target='_blank'>персональных данных</a>
        </span>
      </label>
      <span class='form__error' data-error='agreement'></span>
    </div>

    <button type='submit' class='btn btn--primary btn--block form__submit'>
      <span class='btn__text'>Получить чек-лист</span>
      <span class='btn__loader'>
        <svg class='spinner' viewBox='0 0 50 50' aria-label='Загрузка' role='status'>
          <circle cx='25' cy='25' r='20' fill='none' stroke-width='5'></circle>
        </svg>
      </span>
    </button>

    <p class='form__note'>
      Нажимая кнопку, вы соглашаетесь с
      <a href='/terms' target='_blank'>условиями обработки данных</a>
    </p>
  </BaseForm>
</Modal>

<!-- Emergency Modal -->
<Modal
  id='emergency'
  title='Экстренная правовая помощь'
  subtitle='Экстренная консультация в течение 2 часов'
>
  <div class='emergency-notice mb-6 text-center p-4 bg-red-50 border border-red-200 rounded-lg'>
    <div class='emergency-notice__icon text-3xl mb-2'>🚨</div>
    <div class='emergency-notice__text font-semibold text-red-800'>
      Экстренная консультация в течение 2 часов
    </div>
  </div>

  <BaseForm formId='emergency' formType='emergency'>
    <div class='form__group'>
      <label class='form__label' for='emergency-name'>
        Ваше имя <span class='form__required'>*</span>
      </label>
      <input
        type='text'
        class='form__input'
        id='emergency-name'
        name='name'
        placeholder='Введите ваше имя'
        required
        autocomplete='name'
      />
      <span class='form__error' data-error='name'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='emergency-phone'>
        Телефон <span class='form__required'>*</span>
      </label>
      <input
        type='tel'
        class='form__input'
        id='emergency-phone'
        name='phone'
        placeholder='+7 (___) ___-__-__'
        data-mask='phone'
        required
        autocomplete='tel'
      />
      <span class='form__error' data-error='phone'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='emergency-situation'>
        Опишите срочную ситуацию <span class='form__required'>*</span>
      </label>
      <textarea
        class='form__textarea'
        id='emergency-situation'
        name='emergency_situation'
        placeholder='Коллекторы угрожают, арестованы счета, завтра суд...'
        rows='3'
        required
        autocomplete='off'></textarea>
      <span class='form__error' data-error='emergency_situation'></span>
    </div>

    <div class='form__group'>
      <label class='form__checkbox' for='emergency-agreement'>
        <input type='checkbox' id='emergency-agreement' name='agreement' required />
        <span class='form__checkbox-text'>
          Я согласен на обработку
          <a href='/privacy' target='_blank'>персональных данных</a>
        </span>
      </label>
      <span class='form__error' data-error='agreement'></span>
    </div>

    <button type='submit' class='btn btn--danger btn--block form__submit'>
      <span class='btn__text'>Получить помощь сейчас</span>
      <span class='btn__loader'>
        <svg class='spinner' viewBox='0 0 50 50' aria-label='Загрузка' role='status'>
          <circle cx='25' cy='25' r='20' fill='none' stroke-width='5'></circle>
        </svg>
      </span>
    </button>

    <p class='form__note'>
      Нажимая кнопку, вы соглашаетесь с
      <a href='/terms' target='_blank'>условиями обработки данных</a>
    </p>
  </BaseForm>
</Modal>

<!-- Test Modal -->
<Modal
  id='test'
  title='Тест на возможность банкротства'
  subtitle='Пройдите тест из 10 вопросов и узнайте, подходит ли вам процедура банкротства.'
>
  <BaseForm formId='test' formType='test'>
    <div class='form__group'>
      <label class='form__label' for='test-debt'>
        Сумма задолженности <span class='form__required'>*</span>
      </label>
      <select class='form__select' id='test-debt' name='debt' required autocomplete='off'>
        <option value=''>Выберите сумму</option>
        <option value='less_300k'>Менее 300 000 ₽</option>
        <option value='300k_500k'>300 000 - 500 000 ₽</option>
        <option value='500k_1m'>500 000 - 1 000 000 ₽</option>
        <option value='more_1m'>Более 1 000 000 ₽</option>
      </select>
      <span class='form__error' data-error='debt'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='test-name'>
        Ваше имя <span class='form__required'>*</span>
      </label>
      <input
        type='text'
        class='form__input'
        id='test-name'
        name='name'
        placeholder='Введите ваше имя'
        required
        autocomplete='name'
      />
      <span class='form__error' data-error='name'></span>
    </div>

    <div class='form__group'>
      <label class='form__label' for='test-phone'>
        Телефон <span class='form__required'>*</span>
      </label>
      <input
        type='tel'
        class='form__input'
        id='test-phone'
        name='phone'
        placeholder='+7 (___) ___-__-__'
        data-mask='phone'
        required
        autocomplete='tel'
      />
      <span class='form__error' data-error='phone'></span>
    </div>

    <div class='form__group'>
      <label class='form__checkbox' for='test-agreement'>
        <input type='checkbox' id='test-agreement' name='agreement' required />
        <span class='form__checkbox-text'>
          Я согласен на обработку
          <a href='/privacy' target='_blank'>персональных данных</a>
        </span>
      </label>
      <span class='form__error' data-error='agreement'></span>
    </div>

    <button type='submit' class='btn btn--primary btn--block form__submit'>
      <span class='btn__text'>Получить результат теста</span>
      <span class='btn__loader'>
        <svg class='spinner' viewBox='0 0 50 50' aria-label='Загрузка' role='status'>
          <circle cx='25' cy='25' r='20' fill='none' stroke-width='5'></circle>
        </svg>
      </span>
    </button>

    <p class='form__note'>
      Нажимая кнопку, вы соглашаетесь с
      <a href='/terms' target='_blank'>условиями обработки данных</a>
    </p>
  </BaseForm>
</Modal>

<!-- Assessment Modal -->
<Modal
  id='assessment'
  title='Экспресс-оценка дела'
  subtitle='Получите предварительную оценку перспектив вашего дела за 24 часа. Бесплатно и конфиденциально.'
>
  <BaseForm formId='assessment' formType='assessment'>
    <div class='form__group'>
      <label class='form__label' for='assessment-name'>
        Ваше имя <span class='form__required'>*</span>
      </label>
      <input
        type='text'
        class='form__input'
        id='assessment-name'
        name='name'
        placeholder='Введите ваше имя'
        required
        autocomplete='name'
      />
      <span class='form__error' data-error='name'></span>
