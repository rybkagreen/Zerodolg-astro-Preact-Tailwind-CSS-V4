---
import Modal from './Modal.astro';
import BaseForm from '../../../components/forms/BaseForm.astro';
---

<!-- Consultation Modal -->
<Modal
  id='consultation'
  title='Бесплатная консультация юриста'
  subtitle='30-минутный разбор вашей ситуации с юристом по банкротству. Получите экспертную оценку и план действий.'
>
  <BaseForm
    formId='consultation'
    formType='consultation'
    showNameField={true}
    showPhoneField={true}
    showEmailField={false}
    showDebtField={false}
    submitText='Получить консультацию'
    variant='stacked'
  />
</Modal>

<!-- Calculator Modal -->
<Modal
  id='calculator'
  title='Калькулятор банкротства'
  subtitle='Узнайте точную стоимость процедуры банкротства. Получите персональный расчет без регистрации.'
>
  <BaseForm
    formId='calculator'
    formType='calculator'
    showNameField={true}
    showPhoneField={true}
    showEmailField={false}
    showDebtField={true}
    submitText='Рассчитать стоимость'
    variant='stacked'
  />
</Modal>

<!-- Guide Download Modal -->
<Modal
  id='guide-download'
  title='Скачать гид по банкротству 2025'
  subtitle='47 страниц полезной информации. Актуальные изменения в законах. Шаблоны документов.'
>
  <div class='guide-preview mb-6'>
    <div class='guide-preview__features grid grid-cols-1 md:grid-cols-3 gap-4'>
      <div class='guide-feature text-center p-4 bg-gray-50 rounded-lg'>
        <span class='guide-feature__icon text-2xl block mb-2'>📖</span>
        <span class='guide-feature__text text-sm text-gray-600'>47 страниц полезной информации</span
        >
      </div>
      <div class='guide-feature text-center p-4 bg-gray-50 rounded-lg'>
        <span class='guide-feature__icon text-2xl block mb-2'>⚖️</span>
        <span class='guide-feature__text text-sm text-gray-600'>Актуальные изменения в законах</span
        >
      </div>
      <div class='guide-feature text-center p-4 bg-gray-50 rounded-lg'>
        <span class='guide-feature__icon text-2xl block mb-2'>📄</span>
        <span class='guide-feature__text text-sm text-gray-600'>Шаблоны всех документов</span>
      </div>
    </div>
  </div>

  <BaseForm
    formId='guide'
    formType='guide'
    showNameField={true}
    showPhoneField={false}
    showEmailField={true}
    showDebtField={false}
    submitText='Скачать гид бесплатно'
    variant='stacked'
  />
</Modal>

<!-- Checklist Download Modal -->
<Modal
  id='checklist-download'
  title='Получить чек-лист должника'
  subtitle='Пошаговый план подготовки к банкротству с 25 пунктами для проверки.'
>
  <BaseForm
    formId='checklist'
    formType='checklist'
    showNameField={true}
    showPhoneField={false}
    showEmailField={true}
    showDebtField={false}
    submitText='Получить чек-лист'
    variant='stacked'
  />
</Modal>

<!-- Emergency Modal -->
<Modal
  id='emergency'
  title='Экстренная правовая помощь'
  subtitle='Экстренная консультация в течение 2 часов'
>
  <div class='emergency-notice mb-6 text-center p-4 bg-red-50 border border-red-200 rounded-lg'>
    <div class='emergency-notice__icon text-3xl mb-2'>🚨</div>
    <div class='emergency-notice__text font-semibold text-red-800'>
      Экстренная консультация в течение 2 часов
    </div>
  </div>

  <BaseForm
    formId='emergency'
    formType='emergency'
    showNameField={true}
    showPhoneField={true}
    showEmailField={false}
    showDebtField={false}
    submitText='Получить помощь сейчас'
    variant='stacked'
  />
</Modal>

<!-- Test Modal -->
<Modal
  id='test'
  title='Тест на возможность банкротства'
  subtitle='Пройдите тест из 10 вопросов и узнайте, подходит ли вам процедура банкротства.'
>
  <BaseForm
    formId='test'
    formType='test'
    showNameField={true}
    showPhoneField={true}
    showEmailField={false}
    showDebtField={true}
    submitText='Получить результат теста'
    variant='stacked'
  />
</Modal>

<!-- Assessment Modal -->
<Modal
  id='assessment'
  title='Экспресс-оценка дела'
  subtitle='Получите предварительную оценку перспектив вашего дела за 24 часа. Бесплатно и конфиденциально.'
>
  <BaseForm
    formId='assessment'
    formType='assessment'
    showNameField={true}
    showPhoneField={true}
    showEmailField={false}
    showDebtField={true}
    submitText='Получить оценку'
    variant='stacked'
  />
</Modal>

<!-- Webinar Registration Modal -->
<Modal
  id='webinar-registration'
  title='Записаться на вебинар'
  subtitle='Еженедельный вебинар "Банкротство без ошибок". Разбор реальных кейсов и ответы на вопросы.'
>
  <div class='webinar-info mb-6 p-4 bg-blue-50 border border-blue-200 rounded-lg'>
    <div class='text-center'>
      <div class='text-2xl mb-2'>📅</div>
      <div class='font-semibold text-blue-800 mb-1'>Следующий вебинар</div>
      <div class='text-blue-600'>Каждый четверг в 19:00 МСК</div>
    </div>
  </div>

  <BaseForm
    formId='webinar'
    formType='webinar'
    showNameField={true}
    showPhoneField={true}
    showEmailField={true}
    showDebtField={false}
    submitText='Записаться на вебинар'
    variant='stacked'
  />
</Modal>
