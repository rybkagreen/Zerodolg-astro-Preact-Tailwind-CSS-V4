---
import Modal from './Modal.astro';
import BaseForm from '../../../components/forms/BaseForm.astro';

interface Props {
  modalId?: string;
}

const { modalId = 'callback-modal' } = Astro.props;
---

<Modal
  id={modalId}
  title='Заказать обратный звонок'
  subtitle='Оставьте свой номер телефона, и наш специалист свяжется с вами в течение 15 минут'
>
  <BaseForm
    formId='callback'
    formType='callback'
    showNameField={true}
    showPhoneField={true}
    showEmailField={false}
    showDebtField={false}
    submitText='Заказать звонок'
    variant='stacked'
  />
</Modal>
