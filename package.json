{
  "name": "zerodolg-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/dev/validate-env.js && astro build",
    "build:prod": "npm run prebuild:prod && node scripts/dev/validate-env.js && astro build --config astro.config.prod.mjs",
    "build:production": "node scripts/build/build-production.js",
    "prebuild:prod": "npm run clean && npm run type-check",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "npx eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "npx rimraf dist .astro",
    "prepare": "husky",
    "env:validate": "node scripts/dev/validate-env.js",
    "env:setup": "node scripts/dev/setup-env.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:coverage:report": "node scripts/test/run-tests-with-coverage.js",
    "test:env": "node scripts/test/test-env-validation.js",
    "test:e2e": "node scripts/test/run-puppeteer-tests.cjs",
    "deploy:checklist": "node scripts/deploy/deployment-checklist-complete.js",
    "deploy:verify": "node scripts/deploy/post-build-verification.js",
    "deploy:rollback": "node scripts/deploy/rollback.js",
    "deploy:backup": "node scripts/deploy/create-backup.js",
    "deploy": "node scripts/deploy/deploy-complete.js",
    "maintenance:audit": "node scripts/maintenance/audit-deps.cjs",
    "maintenance:optimize-images": "node scripts/maintenance/optimize-images.js",
    "maintenance:lighthouse": "node scripts/maintenance/lighthouse-audit.cjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "puppeteer:setup": "npx puppeteer browsers install",
    "mcp:server": "node tools/mcp-puppeteer-server.js",
    "mcp:demo": "node tools/demo-mcp-puppeteer.js",
    "tools:compare-sites": "node tools/compare-sites.js",
    "tools:semgrep": "node tools/semgrep-scan.js",
    "tools:trufflehog": "node tools/trufflehog-scan.js"
  },
  "dependencies": {
    "@astrojs/preact": "^4.1.1",
    "@astrojs/sitemap": "^3.6.0",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "astro": "^5.13.7",
    "astro-mcp": "^0.4.2",
    "astro-robots-txt": "^1.0.0",
    "preact": "^10.27.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.36.0",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.8.0",
    "@types/node": "^24.5.2",
    "@types/puppeteer": "^5.4.7",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/expect": "^3.2.4",
    "@vitest/runner": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "astro-eslint-parser": "^1.2.2",
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.1",
    "eslint": "^9.36.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.4.0",
    "happy-dom": "^18.0.1",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.2.0",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^13.0.2",
    "postcss-preset-env": "^10.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "puppeteer": "^24.23.0",
    "rimraf": "^6.0.1",
    "sharp": "^0.34.4",
    "tailwindcss": "^3.4.17",
    "terser": "^5.44.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,pcss}": [
      "prettier --write"
    ],
    "*.{json,jsonc,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.17.1"
  }
}
