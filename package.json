{
  "name": "zerodolg-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/dev/validate-env.js && astro build",
    "build:prod": "node scripts/dev/validate-env.js && astro build --config astro.config.prod.mjs",
    "build:production": "node scripts/build/build-production.js",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "npx eslint . --ext .js,.ts,.tsx,.astro",
    "lint:fix": "eslint . --ext .js,.ts,.tsx,.astro --fix",
    "type-check": "tsc --noEmit",
    "clean": "npx rimraf dist .astro",
    "prebuild": "npm run clean && npm run type-check",
    "postbuild": "echo 'Build completed successfully'",
    "prepare": "husky",
    "env:validate": "node scripts/dev/validate-env.js",
    "env:setup": "node scripts/dev/setup-env.js",
    "test": "jest --config=jest.config.cjs",
    "test:watch": "jest --watch --config=jest.config.cjs",
    "test:coverage": "jest --coverage --config=jest.config.cjs",
    "test:coverage:report": "node scripts/test/run-tests-with-coverage.js",
    "test:env": "node scripts/test/test-env-validation.js",
    "test:e2e": "node scripts/test/run-puppeteer-tests.js",
    "deploy:checklist": "node scripts/deploy/deployment-checklist-complete.js",
    "deploy:verify": "node scripts/deploy/post-build-verification.js",
    "deploy:rollback": "node scripts/deploy/rollback.js",
    "deploy:backup": "node scripts/deploy/create-backup.js",
    "deploy": "node scripts/deploy/deploy-complete.js",
    "maintenance:audit": "node scripts/maintenance/audit-deps.cjs",
    "maintenance:optimize-images": "node scripts/maintenance/optimize-images.js",
    "maintenance:lighthouse": "node scripts/maintenance/lighthouse-audit.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "puppeteer:setup": "npx puppeteer browsers install",
    "mcp:info": "echo 'MCP (Multi-Channel Publisher) is configured in astro.config.mjs'",
    "mcp:puppeteer": "node tools/mcp-puppeteer.js",
    "mcp:server": "node tools/mcp-puppeteer-server.js",
    "mcp:demo": "node tools/demo-mcp-puppeteer.js",
    "tools:compare-sites": "node tools/compare-sites.js",
    "tools:diagnose-css": "node tools/diagnose-local-styles.js",
    "tools:debug-css": "node tools/debug-css-loading.js"
  },
  "dependencies": {
    "@astrojs/preact": "^4.1.1",
    "@astrojs/sitemap": "^3.6.0",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "astro": "^5.13.7",
    "astro-mcp": "^0.4.2",
    "astro-robots-txt": "^1.0.0",
    "preact": "^10.27.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/tailwind": "^6.0.2",
    "@eslint/js": "^9.36.0",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.18",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.10",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "astro-eslint-parser": "^1.2.2",
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.1",
    "eslint": "^9.35.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "imagemagick": "^0.1.3",
    "jest": "^30.1.3",
    "jest-raw-loader": "^1.0.1",
    "jsdom": "^27.0.0",
    "lightningcss": "^1.28.0",
    "lint-staged": "^15.4.3",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^10.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "puppeteer": "^24.22.2",
    "rimraf": "^6.0.1",
    "sharp": "^0.34.4",
    "svg2png": "^4.1.1",
    "tailwindcss": "^4.1.13",
    "terser": "^5.39.0",
    "ts-jest": "^29.4.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{astro}": [
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.17.1"
  }
}
